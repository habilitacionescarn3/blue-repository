              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: Volatility
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 57TNhfCPohyptzE8EPedTDH19ZH7MkzMEo4S8VWeQ9Ck
            attributesAdded: []
      - status: stable
