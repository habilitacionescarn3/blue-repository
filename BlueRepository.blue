                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: ZeroInterestRateExcludingSpreadMethod
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: ZeroInterestRateMethod
