                  value: PerOption
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: PercentageOfNotional
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 5oss5vAthfdDyx4i1CUcAgeHxzWsk2SCDGWtrZ76qZzi
            attributesAdded: []
      - status: stable
        content:
          name: cdm/observable/asset/PriceOperandEnum
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
