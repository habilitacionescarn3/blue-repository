                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].allOps=true and singleOps are mutually exclusive'
                            - $if:
                                cond:
                                  $eq:
                                    items:
                                      - $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: anchorCount
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: links must have at least one anchor entry
                            - $if:
                                cond:
                                  $gt:
                                    items:
                                      - $size:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: issues
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: Cm9gL7QQ4CDhi18VKg5PfK11Xy6CLVJawoa88BTTy9ZU
                                        issues:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: issues
