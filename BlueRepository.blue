      - status: dev
        content:
          name: Change Workflow
          description: Applies a requested changeset immediately to the document.
          type:
            blueId: B5mVH4caQv9Hmzeb5ZmCtzYomooFzTdoCQ4mZVwHY3MS
          request:
            description: Expected request payload for this workflow.
            type:
              blueId: Em6YA77iVnnRaScCrkZr9C9VkQF14i2pk5fA8KNiHS41
          steps:
            items:
              - name: Prepare
                type:
                  blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                entry:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: prepare
                functions:
                  invalid:
                    args:
                      reason:
                        description: BEX helper argument.
                    expr:
                      changeset:
                        items: []
                      events:
                        items:
                          - type:
                              blueId: 8oEU9ysLsGJJeeCDsEgnHbyu8vuWTwogExHmNc7t512n
                            reason:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: reason
                  asList:
                    args:
                      val:
                        description: BEX helper argument.
                    expr:
                      $choose:
                        cond:
                          $isKind:
                            val:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: val
                            kind:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: list
                        then:
                          $var:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: val
                        else:
                          items: []
                  asObject:
                    args:
                      val:
                        description: BEX helper argument.
                    expr:
                      $choose:
                        cond:
                          $isKind:
                            val:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: val
                            kind:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: object
                        then:
                          $var:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: val
                        else:
                          $emptyObject:
                            type:
                              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                            value: true
                  isMetaKey:
                    args:
                      key:
                        description: BEX helper argument.
                    expr:
                      $or:
                        items:
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: key
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: type
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: key
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: keyType
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: key
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: valueType
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: key
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: description
                  contractKeys:
                    args:
                      contractsMap:
                        description: BEX helper argument.
                    expr:
                      $filter:
                        in:
                          $keys:
                            $call:
                              function:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: asObject
                              args:
                                val:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: contractsMap
                        item:
                          type:
                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                          value: contractKey
                        where:
                          $not:
                            $call:
                              function:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: isMetaKey
                              args:
                                key:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: contractKey
                  keySetObject:
                    args:
                      keys:
                        description: BEX helper argument.
                    expr:
                      $objectFromEntries:
                        $map:
                          in:
                            $call:
                              function:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: asList
                              args:
                                val:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: keys
                          item:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: key
                          expr:
                            key:
                              $text:
                                $var:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: key
                            val:
                              type:
                                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                              value: true
                  contractPath:
                    args:
                      key:
                        description: BEX helper argument.
                    expr:
                      $pointerJoin:
                        items:
                          - type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: contracts
                          - $var:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: key
                  isContractsPatchEntry:
                    args:
                      entry:
                        description: BEX helper argument.
                    expr:
                      $or:
                        items:
                          - $eq:
                              items:
                                - $text:
                                    $default:
                                      items:
                                        - $var:
                                            name: entry
                                            path:
                                              type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: /path
                                        - type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: ''
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: /contracts
                          - $startsWith:
                              items:
                                - $text:
                                    $default:
                                      items:
                                        - $var:
                                            name: entry
                                            path:
                                              type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: /path
                                        - type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: ''
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: /contracts/
                  isProposedChangePatchEntry:
                    args:
                      entry:
                        description: BEX helper argument.
                    expr:
                      $startsWith:
                        items:
                          - $text:
                              $default:
                                items:
                                  - $var:
                                      name: entry
                                      path:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: /path
                                  - type:
