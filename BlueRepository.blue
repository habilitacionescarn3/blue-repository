      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/IssuerTypeEnum
          description: Represents an enumeration list to identify the type of entity issuing the asset.
          type:
            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          schema:
            enum:
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: Corporate
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: Fund
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: QuasiGovernment
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: RegionalGovernment
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: SovereignCentralBank
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: SpecialPurposeVehicle
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: SupraNational
