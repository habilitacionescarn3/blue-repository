                items:
                  - name: MergeTransactionDetailsUpdate
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    entry:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: merge
                    functions:
                      asObject:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: val
                                kind:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: object
                            then:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: val
                            else:
                              $emptyObject:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
                      merge:
                        do:
                          items:
                            - $let:
                                order:
                                  items:
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: request
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: patch
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: nextTransactionDetails
                                vars:
                                  request:
                                    $event:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: /message/request
                                  patch:
                                    $event:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: /message/request/transactionDetails
                                  nextTransactionDetails:
                                    $merge:
                                      items:
                                        - $call:
                                            function:
                                              type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: asObject
                                            args:
                                              val:
                                                $choose:
                                                  cond:
                                                    $exists:
                                                      $document:
                                                        type:
                                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                        value: /transactionDetails
                                                  then:
                                                    $document:
                                                      type:
                                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                      value: /transactionDetails
                                                  else:
                                                    $emptyObject:
                                                      type:
                                                        blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                                      value: true
                                        - $call:
                                            function:
                                              type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: asObject
                                            args:
                                              val:
                                                $event:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: /message/request/transactionDetails
                            - $if:
                                cond:
                                  $not:
                                    $isKind:
                                      val:
                                        $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: request
                                      kind:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: object
                                then:
                                  items:
                                    - $fail:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: Transaction details update payload must be an object.
                            - $if:
                                cond:
                                  $not:
                                    $isKind:
                                      val:
                                        $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: patch
                                      kind:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: object
                                then:
                                  items:
                                    - $fail:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: Transaction details update payload must include transactionDetails object.
                            - $appendEvent:
                                $var:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: request
                            - $appendChange:
                                op:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: replace
                                path:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: /transactionDetails
                                val:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: nextTransactionDetails
                            - $return:
