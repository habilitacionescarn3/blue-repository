                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: contracts
                      cleanMap:
                        args:
                          object:
                            description: BEX helper argument.
                        expr:
                          $objectFromEntries:
                            $filter:
                              in:
                                $entries:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: object
                              item:
