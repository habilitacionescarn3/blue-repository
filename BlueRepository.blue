            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/Asset
          description: |
            An Asset is defined as something that can be owned and transferred in the financial markets. As a choice data type, one and only one of the attributes must be used.
          Cash:
            description: An Asset that consists solely of a monetary holding in a currency.
            type:
              blueId: DHpHHdiJGEagTPm7Y9Vz6cdsbKwjXg8HjJkoUjpRra2Y
          Commodity:
            description: An Asset comprised of raw or refined materials or agricultural products, eg gold, oil or wheat.
            type:
              blueId: H5njvRER8CjtGtwUC4FooQuqnXpt8hpw2oZAAAuCW8Dn
          DigitalAsset:
            description: |
              An Asset that exists only in digital form, eg Bitcoin or Ethereum; excludes the digital representation of other Assets.
            type:
              blueId: GekwBuYCVfkr4sCyWTFmw8QtYrXx7zDE8G5YwHkaRVL
          Instrument:
            description: An asset that is issued by one party to one or more others; Instrument is also a choice data type.
            type:
              blueId: J1Lgg2ajU8Qy4mgpL5ELeryh9L63Mk2B9paZPCz5bsp8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: B3bsNNAr8QJpJA8r84kgZrHLE5PZREBGxXWYJdtaDRJ7
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/AssetBase
          description: The base data type to specify common attributes for all Assets.
          exchange:
            description: If the Asset is listed, defines the public exchange of the listing.
            type:
              blueId: 6NmyTe5CqfuusJQg46VWDV5a5FXqiZnkQmXduwAjC73o
          identifier:
            description: Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: EFYo6JAQMRJEAg6yzzafESRVFXGTiNSjmy9ehctCH3Y4
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 1
          isExchangeListed:
            description: Defines whether the Asset is listed on a public exchange.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
          relatedExchange:
            description: Provides the related Exchanges, if applicable.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 6NmyTe5CqfuusJQg46VWDV5a5FXqiZnkQmXduwAjC73o
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          taxonomy:
            description: |
              Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 9iqdbfahQtNXNenCSE8hAFbq298MVvdACauLx1FZWRQt
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6pVLqA5jCBFn1xFmznDn8hRDyzaHRvRQ5XjxvAEEXKy1
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/AssetClassEnum
          description: The enumerated values to specify the FpML asset class categorization.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
