      - status: stable
        content:
          name: cdm/product/asset/FinalPrincipalExchangeCalculationEnum
          description: To be specified only for products that embed a redemption payment.
          type:
            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          schema:
            enum:
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: Floored
              - type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
