              blueId: 3UQyaunu7noHsnkXtFNJHuwdv1AH6Uq6MZ1bZSHN9hYW
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: ENR8ZMb3BXhAA9nevcEyKgFFFrZ2fgr7kuxCniYTsx1w
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/common/settlement/PrincipalPayment
          description: Any kind of principal payments when the amount is known and thus fixed.
          discountFactor:
            description: |
              The value representing the discount factor used to calculate the present value of the principal payment amount.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          payerReceiver:
            description: Specifies the parties responsible for making and receiving payments defined by this structure.
            type:
              blueId: Cx2eHN58eqWKXnZwn6JDYBzAfG95QSEAWjQhbX1R5An3
          presentValuePrincipalAmount:
            description: The amount representing the present value of the principal payment.
            type:
              blueId: 5RCy7NwpdTs7j96evsc93hof8nESXDM5u4q3ykG6dXvE
          principalAmount:
            description: When known at the time the transaction is made, the cash amount to be paid.
            type:
              blueId: 5RCy7NwpdTs7j96evsc93hof8nESXDM5u4q3ykG6dXvE
          principalPaymentDate:
            description: The date where the PrincipalPayment shall be settled.
            type:
              blueId: 4Ro4tKrST2yaBWNytCjLJMhx3DMoAXwqU1W6HBKrnfRn
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 9cWWHV5DRe4SuejnEf6PBEsFWjw5RA8u3n2yKvLwXzMS
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/common/settlement/PrincipalPayments
          description: A class defining which principal exchanges occur for the stream.
          finalPayment:
            description: A true/false flag to indicate whether there is a final exchange of principal on the termination date.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          initialPayment:
            description: A true/false flag to indicate whether there is an initial exchange of principal on the effective date.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          intermediatePayment:
            description: |
              A true/false flag to indicate whether there are intermediate or interim exchanges of principal during the term of the swap.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          principalPaymentSchedule:
            description: Describe dates schedules for Principal Exchanges and related role of the parties when known.
            type:
              blueId: 4FTqK6vYmEpdwWnDuD2EjcJ7sLWWdhgeB2duLV8aA5bC
          varyingLegNotionalCurrency:
            description: |
              Indicate the Payout legs which nominal amount may vary in regards of FX Fixing dates as determined in the product terms.
            type:
