                                                                            value: itemPath
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: .permissions.read must be true
                                            - $if:
                                                cond:
                                                  $call:
                                                    function:
                                                      type:
                                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                      value: hasBadSingleOps
                                                    args:
                                                      ops:
                                                        $var:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: singleOps
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - $var:
                                                                            type:
                                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                            value: itemPath
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: .permissions.singleOps must contain only non-empty strings
                                            - $if:
                                                cond:
                                                  $and:
                                                    items:
                                                      - $eq:
                                                          items:
                                                            - $var:
                                                                name: perms
                                                                path:
                                                                  type:
                                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                  value: /allOps
                                                            - type:
                                                                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                                              value: true
                                                      - $var:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: hasSingle
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - $var:
                                                                            type:
                                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                            value: itemPath
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: .permissions.allOps=true and
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: ' '
                                                                        - $var:
                                                                            type:
                                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                            value: itemPath
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: .permissions.singleOps are mutually exclusive
                            - $if:
                                cond:
                                  $gt:
                                    items:
                                      - $size:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                      - type:
                                          blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                                        value: 0
                                then:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: 5eDTUokCWbu8Sp1PRZewh7wkdwwdrvpQZcweiMjaHd6m
                                        issues:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                else:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: 8EcfEBSmZUTp73AjLNaCQQRrdQzzdxebG1QUpGe95im2
                            - $return:
                                events:
                                  $events:
                                    type:
                                      blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                    value: true
