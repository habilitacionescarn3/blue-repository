                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
                      isNonEmptyText:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $and:
                            items:
                              - $isKind:
                                  val:
                                    $var:
