            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/asset/ReturnTermsBase
          description: Contains all common elements in variance, volatility and correlation return Terms.
          annualizationFactor:
            description: |
              This specifies the numerator of an annualization factor. Frequently this number is equal to the number of observations of prices in a year e.g. 252.
            type:
              blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
          dividendApplicability:
