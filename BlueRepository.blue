      - status: stable
        content:
          name: ReturnTermsBase
          description: Contains all common elements in variance, volatility and correlation return Terms.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/product/asset
          annualizationFactor:
