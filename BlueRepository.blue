            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/OptionExerciseStyleEnum
          description: The enumerated values to specify the option exercise style. i.e., European, Bermuda or American.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: American
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Bermuda
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: European
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: E4R8utNSd78UCdxdMrishhhpVuyncUtJGCKUfNBVnBqu
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/OptionFeature
          description: Defines additional optional features that can be included in an option contract.
          averagingFeature:
            description: |
              Defines an option feature in which an average market observation price is determined on valuation and compared to the strike to determine a settlement amount.
            type:
              blueId: DgMT9GvGPfVpoxATLX7UH2QtPrCD7csg3P5rdgiQxAUg
          barrier:
            description: Specifies a barrier feature.
            type:
              blueId: BEbFVsDjqqvf3dVeshgGzf9rW4xPdk4DnECxRAcKSJ3M
          fxFeature:
            description: Describes a quanto or composite FX feature.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 4vFVJ5RzFY4D7trKTFXSjcQJv9vQk2V1fzpSsA4MHF3u
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          knock:
            description: Specifies a knock in or knock out feature.
            type:
              blueId: CL3hBXyGabfmMpYHcZYWQxP93Xs1YFHL6AcsrLfzFqtB
          passThrough:
            description: Specifies the rules for pass-through payments from the underlier, such as dividends.
            type:
              blueId: 4d4qPzCq4LAzZkhP87mw5hoXewnyCnGKrdjgtMcZYXWc
          strategyFeature:
            description: Defines a simple strategy feature.
            type:
              blueId: DgYhTvKZWcbsWAJhHrAdY7ihYDMtyVr2mPxUjDnwHkUN
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: JDGRPFj4wNXyhxtXXFrhaCacWSCaiZeP3YHSLDZxPpj1
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/OptionPayout
          description: |
            The option payout specification terms. The associated globalKey denotes the ability to associate a hash value to the respective OptionPayout instantiation for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage.
          buyerSeller:
            type:
              blueId: ATD4mngyB7ULwUSU6DbEMVcLMyFeZxXRKDJrTsFAJ1dx
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          delivery:
            description: Contains the information relative to the delivery of the asset.
            type:
              blueId: DFCwxwyJL859yeqbrr3oY7vncLWeadysD9VJGA6LGJgK
          exerciseTerms:
            description: |
              The terms for exercising the option, which include the option style (e.g. American style option), the exercise procedure (e.g. manual exercise) and the settlement terms (e.g. physical vs. cash).
            type:
              blueId: Chheuq1dPEWCj7bsdGkRo52qY4nscUb7oURn3FKrqFtS
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          feature:
            description: The option feature, such as quanto, Asian, barrier, knock.
            type:
              blueId: JDGRPFj4wNXyhxtXXFrhaCacWSCaiZeP3YHSLDZxPpj1
          observationTerms:
            description: |
              Class containing terms that are associated with observing a price/benchmark/index across either single or multple observations. To be used for option contracts that reference a benchmark price.
            type:
              blueId: 3wwdVKCEN7pSLG9mPnXFiizaAo59qz2yQnNHrzGhT59K
          optionType:
            description: |
              The type of option transaction. From a usage standpoint, put/call is the default option type, while payer/receiver indicator is used for options on index credit default swaps, consistently with the industry practice. Straddle is used for the case of straddle strategy, that combine a call and a put with the same strike.
            type:
              blueId: J4ZdDBZPY9VTNearpD8S9gntq7sM6egJXSCgbUSuBopC
          payerReceiver:
            description: Canonical representation of the payer and receiver parties applicable to each payout leg.
            type:
              blueId: Cx2eHN58eqWKXnZwn6JDYBzAfG95QSEAWjQhbX1R5An3
          priceQuantity:
            description: |
              Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products).
            type:
              blueId: F4ihqR7D44ZpGGutb98mpsdE6QNtkrVZM4oiK6Vuzcsy
          principalPayment:
            description: |
              The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment.
            type:
              blueId: 79fSZCgPXnnm5bsD9s4XCQXn5MaCb8UAVq6ybHFbLdpq
          schedule:
            description: |
              Allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way.
            type:
              blueId: 4W1R4RHyg7dDwmQXUBPtdq2118vcYaxmhXXpAsyJ45iG
          settlementTerms:
            description: |
              Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any.
            type:
              blueId: 7zkmbj4175pTZ3exYCBnCyVdiSaAT2SEfkxhDTus8iLY
          strike:
            description: Specifies the strike of the option
            type:
              blueId: Ah265ohZqxFXsWTp62UC3yWMvZAwGymx5y9Hu55yG4MN
          underlier:
            description: |
              The financial product underlying the option, which can be of any type including an Asset, Basket, Index or a NonTransferableProduct.
            type:
              blueId: this#5
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DQtAbxe1tLy9aRaawabAsHzDGXiQUiSvjt76ym1myncb#7
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/OptionStrike
          description: Defines the strike price of an option.
          averagingStrikeFeature:
            description: Defines an  option strike that is calculated from an average of observed market prices.
            type:
              blueId: 2ivieRnuYvgJa1vamkzsA1moey8Co6QwbcHzZLJtw432
          referenceSwapCurve:
            description: |
              Defines the strike of an option when expressed by reference to a swap curve (Typically the case for a convertible bond option).
            type:
              blueId: 3ePuoisseC1LPtuzJDr9A1SpUkuyfzKiDPwFQS4DtH7h
          strikePrice:
            description: |
              Defines the strike of an option in the form of a price that could be a cash price, interestRate, or other types.
            type:
              blueId: wuC3RHpv6ahucWwxTgdeQyeUP8ecWQQqgMvSpx3Z543
          strikeReference:
            description: |
              Defines the strike of an option in reference to the spread of the underlying swap (typical practice in the case of an option on a credit single name swaps).
            type:
              blueId: BBgcbEXC2m59J1z1f2zctaxNzuEUosaMi3HLNPPMLwAt
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Ah265ohZqxFXsWTp62UC3yWMvZAwGymx5y9Hu55yG4MN
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/OptionTypeEnum
          description: The enumerated values to specify the type or strategy of the option.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Call
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Payer
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Put
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Receiver
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Straddle
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: J4ZdDBZPY9VTNearpD8S9gntq7sM6egJXSCgbUSuBopC
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/PartialExercise
          description: |
            A class defining partial exercise. As defined in the 2000 ISDA Definitions, Section 12.3 Partial Exercise, the buyer of the option may exercise all or less than all the notional amount of the underlying swap but may not be less than the minimum notional amount (if specified) and must be an integral multiple of the integral multiple amount if specified.
          integralMultipleAmount:
            description: |
              A notional amount which restricts the amount of notional that can be exercised when partial exercise or multiple exercise is applicable. The integral multiple amount defines a lower limit of notional that can be exercised and also defines a unit multiple of notional that can be exercised, i.e. only integer multiples of this amount can be exercised.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          minimumNotionalAmount:
            description: The minimum notional amount that can be exercised on a given exercise date. See multipleExercise.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          minimumNumberOfOptions:
            description: The minimum number of options that can be exercised on a given exercise date.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
          notionaReference:
            description: |
              A pointer style reference to the associated notional schedule defined elsewhere in the document. This element has been made optional as part of its integration in the OptionBaseExtended, because not required for the options on securities.
            type:
              blueId: B6z4sPE6mbrDKZ212dEzdy8bC6F5DNgR8Eh4KK623JA
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3DEqhNWWEiUQB1fLiPm2kEPVVpQNPPb4ygac1EcsPw5C
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/PassThrough
          description: Type which contains pass through payments.
          passThroughItem:
            description: One to many pass through payment items.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: Hqwa8X7pvMZZRLdwwa5Cj15xwqMknn63xJyvR4RdpXvF
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 1
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 4d4qPzCq4LAzZkhP87mw5hoXewnyCnGKrdjgtMcZYXWc
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/template/PassThroughItem
          description: Class to represent a single pass through payment.
          passThroughPercentage:
            description: Percentage of payments from the underlier which are passed through.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          payerReceiver:
            description: This attribute doesn't exists in the FpML construct, which makes use of the PayerReceiver.model group.
            type:
              blueId: Cx2eHN58eqWKXnZwn6JDYBzAfG95QSEAWjQhbX1R5An3
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
