      - status: dev
        content:
          name: Payment Mandate
          description: |
            Payment mandate authorizing a grantee to execute payment requests on behalf of a granter, under explicit limits, with deterministic spend tracking and optional linked PayNote bootstrap rules.
          contracts:
            granterChannel:
              description: Granting party timeline channel.
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            granteeChannel:
              description: Grantee timeline channel (party allowed to use the mandate).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            guarantorChannel:
              description: Bank/admin channel executing mandate checks and settlement updates.
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            initLifecycleChannel:
              type:
                blueId: 2DXGQUiQBQ6CT89jwAsTAXaEPhLgiSXhKCGh9Q7Hv3MQ
              event:
                type:
                  blueId: Ht1o66MTLKf7JmnEiR27rRLSwdz8FUTgf2mGPNuLSDUL
            initialize:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: initLifecycleChannel
              steps:
                items:
                  - name: Initialize mandate runtime state
                    type:
                      blueId: 6bU2jWm3F6GaCXSLpdxiNjRbf9XcQDzH1NUsroHz4x8U
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /chargeAttempts
            authorizeSpend:
              description: Validate a charge attempt against mandate policy and reserve capacity.
              type:
                blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: guarantorChannel
              request:
                type:
                  blueId: 8jsJ7UY8wiQvDtpsjqXvnrQUMhqXZhfF6EKBzhtkUKqo
            authorizeSpendImpl:
              type:
                blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
              operation:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: authorizeSpend
              steps:
                items:
                  - name: DecideSpendAuthorization
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    functions:
                      isLanguageKey:
                        args:
                          key:
                            description: BEX helper argument.
                        expr:
                          $or:
                            items:
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: blueId
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: type
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: name
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: description
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: schema
                              - $eq:
