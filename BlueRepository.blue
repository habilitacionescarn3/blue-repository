      - status: stable
        content:
          name: BondReference
          description: Reference to a bond underlier to represent an asset swap or Condition Precedent Bond.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/product/asset
          bond:
            description: Reference to a bond underlier.
            type:
              blueId: 63T48TnoQTtqwqJhapzoroXE67oBew8rTpLWkaMbEoWt
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          conditionPrecedentBond:
            description: |
              To indicate whether the Condition Precedent Bond is applicable. The swap contract is only valid if the bond is issued and if there is any dispute over the terms of fixed stream then the bond terms would be used.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          couponRate:
            description: Specifies the coupon rate (expressed in percentage) of a fixed income security or convertible bond.
            type:
              blueId: H8tMLZL5utB9T5XRaXiQnSR5Gj394a364cNM72rjWtuY
          discrepancyClause:
            description: To indicate whether the Discrepancy Clause is applicable.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: 8KZ4GSY9TZHadh3ABZYJW37CHWch8JV9tCwdP7qUjrVq
            attributesAdded: []
      - status: stable
        content:
          name: BoundedCorrelation
          description: Describes correlation bounds, which form a cap and a floor on the realized correlation.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/product/asset
          maximumBoundaryPercent:
            description: Maximum Boundary as a percentage of the Strike Price.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          minimumBoundaryPercent:
            description: Minimum Boundary as a percentage of the Strike Price.
