      - status: dev
        content:
          name: PayNote
          description: |
            A document attached to exactly one transaction that governs what should happen with that transaction.
          kind:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: PayNote
          status:
            description: |
              Current lifecycle state of this PayNote. Expected values include: Pending, Accepted, Initiated, Secured, Completed, Cancelled, Reversed, Rejected, Failed.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          currency:
            description: ISO 4217 currency code.
            type:
              blueId: CBnZ7aaNetj9KEqXpUWj5jvjKbmviLivP98T2EiyxiYc
          amount:
            description: Amount values associated with this PayNote.
            expectedTotal:
              description: |
                The initially expected total amount in minor units.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            finalResolved:
              description: |
                The final resolved amount for completion, if known.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            secured:
              description: |
                Amount currently secured / under guarantor control.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            completed:
              description: |
                Amount already completed / finalized.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            reversed:
              description: |
                Amount already reversed after completion.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
          transactionDetails:
            description: |
              Transaction attachment information confirmed by the Guarantor.
          controls:
            completionLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            reversalLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            transactionDetailsUpdateLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
          payNoteInitialStateDescription:
            summary:
              description: |
                Short explanation of what this PayNote is for.
              type:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            details:
              description: |
                Full explanation of the process, conditions, and special rules. Markdown recommended.
              type:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          contracts:
            search:
              type:
                blueId: 5KdjguBmn7AwB9d8tjKxRh4xUHU9T8WDJ4dbaY6qgPvx
              kv:
                kind:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: /kind
            payerChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            payeeChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            guarantorChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            initLifecycleChannel:
              type:
                blueId: H2aCCTUcLMTJozWkn7HPUjyFBFxamraw1q8DyWk87zxr
              event:
                type:
                  blueId: BrpmpNt5JkapeUvPqYcxgXZrHNZX3R757dRwuXXdfNM2
            initialize:
              type:
                blueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: initLifecycleChannel
              steps:
                items:
                  - name: ResolveRuntimeDefaults
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
