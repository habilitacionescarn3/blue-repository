                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].singleOps must contain only non-empty strings'
                                            - $if:
                                                cond:
                                                  $and:
                                                    items:
                                                      - $eq:
                                                          items:
                                                            - $var:
                                                                name: perms
                                                                path:
