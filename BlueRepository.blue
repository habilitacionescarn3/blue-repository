name: Blue Repository
packages:
  - name: Common
    types:
      - status: dev
        content:
          name: Crypto Ed25519 Verify
          description: Verifies an Ed25519 signature over the exact UTF-8 bytes of message.
          publicKey:
            description: base64url raw 32-byte Ed25519 public key
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          message:
            description: canonical UTF-8 message text
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          signature:
            description: base64url raw 64-byte Ed25519 signature
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 8wu86DtNarAvJYkPY6iKKYVBFAPedStVtDyjnwZ7xnCw
            attributesAdded: []
      - status: dev
        content:
          name: Currency
          description: ISO 4217 currency code (e.g., USD, EUR).
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: CBnZ7aaNetj9KEqXpUWj5jvjKbmviLivP98T2EiyxiYc
            attributesAdded: []
      - status: dev
        content:
          name: Document
          description: |
            Broad base type for semantic documents that describe what they are directly.
            Use the top-level `kind` field for business-level meaning on top of the
            concrete document family type.
          kind:
            description: Human-readable business meaning for this document.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
            attributesAdded: []
      - status: dev
        content:
          name: Document Anchor
          description: |
            One named connection point where matching documents can link in.
            Anchor entries are typically used inline inside `Common/Document Anchors`
            and can describe the expected matching document shape through `template`.
          template:
            description: |
              Optional Blue document-shaped template describing what matches this anchor.
              It may be a minimal `{ type, kind }` hint or a richer nested document shape.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Bu4KzxxpJuHvET1RTBzioDXpWcqmvYzmqGRiDKmktHUo
            attributesAdded: []
      - status: dev
        content:
          name: Document Anchors
          description: |
            Dictionary-like container of named document anchors.
            The container is typed, while named entries can stay inline and do not need
            to repeat `type: Common/Document Anchor` in public document shape.
          type:
            blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          keyType:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          valueType:
            blueId: Bu4KzxxpJuHvET1RTBzioDXpWcqmvYzmqGRiDKmktHUo
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3KRfhgbFdvyW9SGuKiq3WxWF9bHSATEb8tMso8Pykpre
            attributesAdded: []
      - status: dev
        content:
          name: Named Event
          description: |
            Lightweight coordination event identified by the instance `name` field.
            Use it to emit, forward, or match a well-known signal
            without introducing a dedicated repository event type.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FWb3C8okT5wMqZVHCH4e3RAKLSk2EDw8ryxoonQY1pKz
            attributesAdded: []
      - status: dev
        content:
          name: Payment
          description: |
            Broad document family for a value-moving or value-committing document.
            Use the top-level `kind` to describe the payment intent,
            such as `Invoice Settlement`, `Payout`, or `Milestone Payment`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DoDF7Hm2Ss7ikirPwXZ7KFiWNmdwtb53vHCSwYFbCdPk
            attributesAdded: []
      - status: dev
        content:
          name: PermissionGrant
          description: |
            Broad document family for documents whose main purpose is granting or revoking authority.
            Use the top-level `kind` to describe the business permission shape,
            such as `Single Document Permission Grant` or `Linked Documents Permission Grant`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EHTR6jFrqbmjPf7dNSJUsGUJrgr5kLh62QiT2bxD6KRp
            attributesAdded: []
      - status: dev
        content:
          name: Profile
          description: |
            Broad document family for a public-facing identity or presence.
            Use the top-level `kind` to describe the specific profile,
            such as `Business Profile`, `Creator Profile`, or `Directory Listing`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EWfk8qkKZYqqTyeLs4wLJTfPCLufZBiNGFQY4M4PLv99
            attributesAdded: []
      - status: dev
        content:
          name: Record
          description: |
            Broad document family for a single item that belongs somewhere.
            Use the top-level `kind` to express the specific business meaning, such as
            `Shopping Order`, `Comment`, `Invoice`, or `Report`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: J18rFf6VX3ADe5gTnqmL4wXtivLkzrRXLPPhnoghnjzB
            attributesAdded: []
      - status: dev
        content:
          name: Relationship
          description: |
            Broad document family for a shared document between parties.
            Use the top-level `kind` to describe the specific relationship shape,
            such as `Service Agreement`, `Partnership Proposal`, or `Legal Engagement`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 29BmTvgmhh9x7t2tGd38GqTH3b9v9rgqsuE21K73i86g
            attributesAdded: []
      - status: dev
        content:
          name: Request
          description: |
            Broad document family for a request for something from a provider or participant.
            Use the top-level `kind` to describe the specific request,
            such as `Legal Review Request`, `Service Request`, or `Intake Request`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Ccj91K18JfH77i8bawJzR9GpRWXYf598uPjggxZU7Shd
            attributesAdded: []
      - status: dev
        content:
          name: Response
          description: |
            Broad document family for a response to a request.
            Use the top-level `kind` to describe the specific response,
            such as `Legal Review Response`, `Report Delivery`, or `Intake Response`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: cLkohDeea8vefzVvUwsQ56BwUfedXpqeoD66PvRe7LB
            attributesAdded: []
      - status: dev
        content:
          name: Service
          description: |
            Broad document family for a document that is itself a service offering.
            Use the top-level `kind` to describe the specific offering,
            such as `Legal Service`, `Tutoring Service`, or `Analytics Service`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
          categories:
            description: Optional broad categories used to help humans discover the service.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: ALFnjBeqP1hupQrZGddqbi276GkwnuPtkQjiFLjU716A
            attributesAdded: []
      - status: dev
        content:
          name: Space
          description: |
            Broad document family for a long-lived place in some reality.
            Use it directly as the document `type` and express business meaning through
            the top-level `kind`, such as `Online Shop`, `Legal Office`, or `Research Lab`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
          website:
            description: Optional primary website or canonical public URL for this space.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          anchors:
            description: Optional named connection points where matching documents can link in.
            type:
              blueId: 3KRfhgbFdvyW9SGuKiq3WxWF9bHSATEb8tMso8Pykpre
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Bdyasci5huobiunZqkShQUiWzCyHLhY4fpMkG4YF5BiS
            attributesAdded: []
      - status: dev
        content:
          name: Task
          description: |
            Broad document family for a bounded unit of work over time.
            Use the top-level `kind` to describe the business task,
            such as `Weekly Report`, `Inbox Monitoring`, or `Order Triage`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FfJjBeSAe4JWfA5FVnPDgL9pzLPYELskQnBSanPC9E8L
            attributesAdded: []
      - status: dev
        content:
          name: Timestamp
          description: ISO 8601 timestamp with timezone offset (for example, 2025-01-10T09:30:00Z, 2025-01-10T10:30:00+01:00, or 2025-01-10T09:30:00.123456Z).
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
            attributesAdded: []
  - name: Coordination
    types:
      - status: dev
        content:
          name: Accept Change Operation
          description: |
            Operation marker for accepting a previously stored proposed change. Acceptance means the document should apply the
            changes contained in proposal state and remove the proposal record once the processor has committed the change.

            This operation is part of the proposal/accept/reject workflow family. It separates review from mutation: Propose Change
            captures a request, Accept Change applies it, and Reject Change discards it. The corresponding Accept Change Workflow
            performs validation, policy checks, translation of sectionChanges, and final Update Document patching.
          type:
            blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GTLbwh5uUUHSoxVv6NcUneYmoryfPSBbcFejj9UX96Nt
            attributesAdded: []
      - status: stable
        content:
          name: Actor
          description: |
            Base coordination type for verifiable actor attribution. An Actor describes the person, organization, AI agent,
            service, device, or other accountable source on whose authority an event was created or a request was made. In the
            Coordination model, actor attribution is not merely display metadata: it is the semantic claim that lets workflows,
            policies, auditors, and participants distinguish direct human-principal actions from delegated agent actions and
            other specialized provider-defined actor forms.

            A Timeline Provider or other trusted event source is responsible for assigning actor information accurately. The
            provider's assertion establishes the practical trust boundary: processors do not infer whether an action was taken by
            a human or an agent from the message body; they read the actor node supplied by the provider. Concrete actor types
            refine this base type. A Principal Actor means the timeline owner or another principal acted directly under their own
            authority. An Agent Actor means a non-human or delegated process acted on behalf of a principal and should carry
            enough information to audit that delegation.

            Actor nodes are intentionally passive Blue content. They do not execute logic and do not grant permission by
            themselves. Runtime enforcement is performed by separate policies, usually Actor Policy markers or operation-specific
            rules, which compare the incoming event's actor to the actor requirements for an operation. Because actor descriptions
            are part of identity, a specialized actor type should describe exactly what the provider is asserting, how authority is
            established, and what an observer can rely on when processing the event.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: CFPWz2TX7a1xq6xZYnx93Cu7MqEdMzumr3Zgnx6TrVtd
            attributesAdded: []
      - status: dev
        content:
          name: Actor Policy
          description: |
            Processor-visible policy marker that constrains which actor and source categories may invoke named operations. Actor
            Policy is intended to make actor attribution actionable. It lets a document say, for example, that authorizing funds,
            capturing funds, cancelling a binding agreement, or changing sensitive contract terms must be performed by a principal
            actor, while lower-risk operations such as adding notes or requesting information may be performed by either a
            principal or an agent.

            The policy is keyed by operation name. Each entry may require an actor category, require a source category, and/or
            exclude a source category. `requiresActor` is typically `principal`, `agent`, or `any`. `requiresSource` and
            `excludeSource` are source-class constraints such as `browserSession`, `apiCall`, or `documentRequest`. Provider- or
            application-specific policies may refine these broad categories using specialized actor or source types, for example a
            UI Principal Actor with strong authentication or an API Principal Actor tied to a particular credential.

            Actor Policy is a marker: it does not itself handle events or emit patches. A supported operation/channel runtime reads
            it when evaluating an Operation Request or other event. If the incoming event's actor or source does not meet the
            policy for the requested operation, the operation is rejected or treated as invalid according to the hosting processor
            and channel semantics. This marker should be used to preserve human oversight while still allowing safe delegated
            automation.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          operations:
            description: Per-operation actor/source constraints keyed by operation name.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            valueType:
              requiresActor:
                description: Required actor category ("principal" | "agent" | "any").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              requiresSource:
                description: Required source category ("browserSession" | "apiCall" | "documentRequest").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              excludeSource:
                description: Disallowed source category ("browserSession" | "apiCall" | "documentRequest").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 4cT4usY9ogaFS93DnWrM3uL4orD6VEtNaDVTmPwvSkYM
            attributesAdded: []
      - status: dev
        content:
          name: Agent Actor
          description: |
            Actor specialization representing a non-human, delegated, automated, or AI-driven actor acting under authority granted
            by another actor. An Agent Actor is not the principal; it is an automation participant operating on behalf of a
            principal according to delegation rules maintained by a Timeline Provider, identity provider, platform, or other trust
            anchor. This distinction is critical for safe AI-agent participation: the document can allow routine operations to be
            automated while still requiring principal authorization for high-risk operations.

            The `onBehalfOf` field identifies the actor whose authority the agent is using. Concrete agent types should add
            identity-bearing fields describing the agent, the delegation document or grant, the permitted scope of action, the
            provider that verified the delegation, and any session or execution context useful for audit. A document processor or
            actor policy can then classify the event as delegated automation and decide whether the specific operation is allowed.

            Agent Actor does not imply that every action by the agent is valid. The Timeline Provider is expected to reject agent
            entries outside the delegation it recognizes, and Blue documents may independently enforce stricter actor policies. The
            value of this type is verifiable attribution: observers can see that an action was automated, trace the principal on
            whose behalf it was taken, and inspect the delegation chain without pretending the agent was the principal.
          type:
            blueId: CFPWz2TX7a1xq6xZYnx93Cu7MqEdMzumr3Zgnx6TrVtd
          onBehalfOf:
            description: Actor whose authority this agent is using.
            type:
              blueId: CFPWz2TX7a1xq6xZYnx93Cu7MqEdMzumr3Zgnx6TrVtd
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HokwnQS9btAnSkJ4CuTqydH98mtsYj1SnCGTrRQh47Rw
            attributesAdded: []
      - status: dev
        content:
          name: API Call
          description: |
            Source specialization describing a programmatic API request. An API Call source means the Timeline Provider or event
            source received the action through an API credential or programmatic integration rather than an interactive browser
            session. This distinction is important because many policies allow programmatic requests for low-risk or automated
            tasks but require an interactive principal actor for high-risk operations.

            The `apiKeyId` identifies the credential, integration, or client registration used for the request. It may be opaque to
            third parties, but it should be meaningful to the provider and account owner for audit, revocation, and incident
            investigation. A provider-specific API Call subtype may include additional fields such as client application,
            authentication strength, IP/session metadata, signing key reference, or delegation scope.

            API Call describes the transport/source of the request, not the actor category. A programmatic request may still be
            attributed to a Principal Actor if the credential is treated as direct principal control, or to an Agent Actor if the
            provider recognizes the caller as delegated automation. Actor Policy may combine both dimensions.
          type:
            blueId: 52ECLkcYGohcQEaora7hAbd5ve7Uz85DjE2nEARr55Lk
          apiKeyId:
            description: Identifier of the API credential used for the request.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7Dt3HSHtcQGwkooCctWByNL1mgZnNfAnw2s8BHRx9vDK
            attributesAdded: []
      - status: dev
        content:
          name: Browser Session
          description: |
            Source specialization describing an authenticated interactive browser or UI session. A Browser Session source means the
            event source observed the action through a user-facing session rather than a background API call. This source is often
            used together with Principal Actor to express that the principal acted through an interactive interface and may have
            satisfied UI-specific authentication requirements.

            The `uiSessionNonce` is an opaque provider-generated identifier for the session. It is not meant to reveal private UI
            details to every observer, but it gives the provider and authorized auditors a stable handle for tracing the login,
            authentication method, device binding, challenge, or user-interface flow associated with the action. Provider-specific
            subtypes may add strong-authentication indicators, biometric proof references, device information, or regulatory
            assurance levels.

            Browser Session is passive provenance content. It does not prove by itself that a policy is satisfied; supported
            policies and operation runtimes interpret it together with the actor type and the operation being requested.
          type:
            blueId: 52ECLkcYGohcQEaora7hAbd5ve7Uz85DjE2nEARr55Lk
          uiSessionNonce:
            description: Opaque nonce identifying the UI session.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Xh1LE67PgvpB6S9cRoGLkCsYSc6c1uCxqmp5oMfDxXE
            attributesAdded: []
      - status: dev
        content:
          name: Change Operation
          description: |
            Operation marker for applying a Change Request immediately rather than first storing it as a proposal. It is intended
            for contexts where the caller is already authorized to request the change and the document policy allows direct
            application.

            The operation's `request` shape is Coordination/Change Request. The corresponding Change Workflow validates the request,
            blocks forbidden `/contracts` modifications when Contracts Change Policy requires sectionChanges, rejects attempts to
            mutate proposal state recursively, and then applies the changes through Update Document.

            Use this operation when immediate mutation is acceptable. Use Propose Change Operation followed by Accept or Reject when
            changes must be reviewed before becoming document state.
          type:
            blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
          request:
            type:
              blueId: Em6YA77iVnnRaScCrkZr9C9VkQF14i2pk5fA8KNiHS41
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HvZZ3XFVNQvq8ca5XLrMmkwHZrDUTz68dstkAQHU3Aj4
            attributesAdded: []
      - status: dev
        content:
          name: Change Request
          description: |
            Payload type for direct and proposed document-change operations. A Change Request describes what the caller wants to
            change, why it is being changed, and—when contract mutation is governed by section policy—how the change maps to
            logical document sections.

            `summary` is the human-readable explanation required when a proposal is stored for later acceptance. `changeset` is the
            list of patch entries for ordinary selected-document fields. `sectionChanges` is the structured form for modifying the
            document's `contracts` map through Document Section markers when Contracts Change Policy is enabled. This split exists
            so participants can review contract changes by section instead of accepting arbitrary low-level `/contracts` patches.

            A Change Request is data. It does not mutate by itself. Change Workflow, Propose Change Workflow, Accept Change
            Workflow, and Reject Change Workflow interpret it and produce processor patches or invalid-proposal events.
          summary:
            description: Human-readable summary of the requested change. Required when proposal is created.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          changeset:
            description: RFC 6902 patch entries outside /contracts (blocked by policy if it touches /contracts).
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: Bz49DbfqKC1yJeCfv5RYPZUKTfb7rtZnmreCaz4RsXn5
          sectionChanges:
            description: Section-based /contracts mutations (required when Contracts Change Policy is enabled).
            type:
              blueId: 3WUHev4EbhT1WUTikdZTPaXnapwvgmepVfV3KzYwJDzh
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Em6YA77iVnnRaScCrkZr9C9VkQF14i2pk5fA8KNiHS41
            attributesAdded: []
      - status: stable
        content:
          name: Chat Message
          description: |
            Simple coordination event representing a human-readable message exchanged through a document or timeline. Chat Message
            is useful for informal communication, notifications, and audit-visible commentary when the message itself is not a
            structured operation request.

            The `message` field contains the text shown to participants. Because it is Blue content, exact text, whitespace, and
            Unicode code points are identity-bearing. If a chat message is placed in a Timeline Entry, actor and source attribution
            belong to the Timeline Entry, not to this event type.

            Chat Message should not be used when the document needs deterministic machine-actionable semantics. In that case, use a
            concrete Operation Request, Status Change, Customer Action event, or domain-specific event type with typed fields.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          message:
            description: The textual content of the chat message.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 8ffEpcuZ7V1xnrxaW4PFTjBTfKKB6dxVF9HHoc5HqBM1
            attributesAdded: []
      - status: stable
        content:
          name: Composite Timeline Channel
          description: |
            Channel contract that composes several same-scope Timeline Channel contracts into a single union channel. It matches an
            incoming event when any child channel named in `channels` would match. This is useful when a workflow should react to a
            group of timelines through one handler binding while preserving each child timeline's individual identity,
            checkpointing, and provider semantics.

            Composite Timeline Channel does not create a new global timeline and does not impose consensus over the child
            timelines. It is a routing convenience inside a document scope. Completeness and ordering must still be handled by the
            feeder/provider layer and by the underlying child channels. The composite channel should adapt or pass through the
            matched child channel's payload in a deterministic way defined by the concrete implementation or profile.

            The `channels` list contains contract-map keys in the same scope. The keys are ordered list content, but matching should
            remain deterministic regardless of notification arrival order. If more than one child channel could accept the same
            event, the processor must use the supported channel semantics and deterministic ordering rules to choose or deliver
            consistently.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          channels:
            description: |
              List of contracts-map keys (Text) of channels in the same scope to compose (union). Each entry must name an existing Channel contract.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: ByQY8CFbj5JVoSuoutRmG5wJWfvAidg7q83zsQ3GTgD4
            attributesAdded: []
      - status: stable
        content:
          name: Compute
          description: |
            Workflow step that evaluates Blue Expression Objects (BEX) and returns a deterministic result object. Compute is the
            preferred way for workflows to read document state, inspect the event, calculate booleans or numbers, build a
            changeset, build events, or choose one of several simple branches. The compute program is written as Blue data, so it
            is part of the document identity and can be inspected without executing a separate scripting language.

            Compute is read-only with respect to the document. It can read the processing context: `$document` for the immutable or
            working document view, `$event` for the triggering event, `$steps` for prior step results, `$currentContract` for the
            executing workflow contract, `$var` for local variables, and `$const` for constants. It can produce data, including an
            object with `changeset` and `events`, but it does not itself mutate the selected document. A separate Update Document
            step must apply a changeset, and event emission must go through the workflow/processor result rules.

            BEX operators are explicit Blue objects whose single key begins with `$`. Core operators include data access
            (`$document`, `$event`, `$steps`, `$currentContract`, `$var`, `$const`, `$binding`, `$resultValue`), type conversion
            (`$text`, `$integer`, `$number`, `$boolean`, `$object`, `$list`, `$unwrap`, `$kind`, `$isKind`), logic and comparison
            (`$eq`, `$ne`, `$gt`, `$gte`, `$lt`, `$lte`, `$and`, `$or`, `$not`, `$truthy`, `$empty`, `$exists`, `$default`,
            `$coalesce`), string/list/object utilities (`$concat`, `$join`, `$split`, `$startsWith`, `$sliceAfter`, `$keys`,
            `$entries`, `$size`, `$merge`, `$listConcat`, `$listGet`, `$objectSet`, `$objectFromEntries`, `$pointerJoin`,
            `$pointerGet`, `$pointerSet`), collection operations (`$map`, `$filter`, `$flatMap`, `$reduce`, `$some`, `$find`,
            `$findEntry`, `$includes`, `$hasKey`), branching (`$choose`, `$returnIf`, `$fail`, `$failIf`), function calls, and
            explicit result construction (`$changeset`, `$events`, `$appendChange`, `$appendEvent`). Statement forms include
            `$let`, `$set`, `$if`, `$forEach`, and `$return`.

            BEX is deterministic and bounded. It has no wall-clock time, randomness, file/network access, hidden mutable state,
            promises, asynchronous execution, or unbounded recursion. Loops iterate over concrete lists or object entries and object
            keys are processed in canonical order. Evaluation is gas-metered: each expression, operator, read, loop iteration,
            output construction, change construction, and event construction has a deterministic cost. BEX gas charges only the
            computation and construction of result data; the Blue Contracts processor separately charges patch application,
            Document Update cascades, emitted-event delivery, checkpoints, lifecycle, and termination.

            A conforming Compute step should use frozen/snapshot-backed document reads. In a sequential workflow, if an earlier
            Update Document step previewed patches, later BEX `$document` reads should observe the workflow's frozen working
            document state. Materializing the entire document to mutable Node form should be reserved for hard boundaries such as
            debug/export. This keeps Compute fast while preserving read-your-writes behavior and processor type-soundness
            guarantees.
          type:
            blueId: 99AomnUQTnL52YVYXwEbGNeKnV6u1cjm73xLFSAt7mwe
          expr:
            description: |
              Optional single BEX expression. If present without a `do` body, evaluating this expression is the step result. This is
              useful for read-only calculations, predicates, projections, or compact one-value compute steps.
          do:
            description: |
              Ordered list of BEX statements. Statements run sequentially and may declare variables, branch, iterate over bounded
              collections, append changes/events to the result, or return a value. They do not directly mutate the document.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
          definition:
            description: |
              Optional reference to a reusable Coordination/Compute Definition. In a coordination document this is commonly a
              contract-map key in the current scope, but a concrete implementation may also support BlueId references or other
              deterministic definition lookup mechanisms.
          entry:
            description: |
              Entry function name to execute when `definition` or local `functions` are used.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          constants:
            description: |
              Named constants available to BEX through `$const`. Keys are constant names; values are arbitrary Blue values.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          functions:
            description: |
              Named reusable BEX functions. Keys are function names; values are function definitions. Function objects are intentionally not strongly typed in this repository version.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          emitEvents:
            description: |
              When true, a result object containing an `events` list requests emission of those events through the workflow result.
              The compute step still does not deliver events directly; the Blue Contracts processor validates, charges, enqueues,
              bridges, and routes emitted events.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            value: true
          returnResult:
            description: |
              If true, the computed result is stored under the workflow step name and can be referenced by later steps.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            value: true
          gasLimit:
            description: Optional maximum gas allowed for this Compute step. If omitted, the host processor chooses the applicable default.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
            attributesAdded: []
      - status: dev
        content:
          name: Compute Definition
          description: |
            Reusable package of BEX constants and functions for Coordination/Compute steps. A Compute Definition lets several
            workflow steps share deterministic logic while keeping that logic in Blue content rather than in a host-language module
            or source string. A Compute step may reference this definition and choose an `entry` function, or it may use local
            functions and constants directly.

            `constants` is a dictionary of literal or structured Blue values available through `$const`. `functions` is a dictionary
            of named BEX function definitions. A function may declare arguments, evaluate statements, return a value, and use
            constants or other permitted functions according to the BEX specification. Functions must be deterministic, bounded,
            and gas-metered just like inline compute programs.

            This type intentionally treats function bodies and operators as data. Their exact Blue structure is identity-bearing.
            The type does not attempt to model every BEX operator as field-level schema; the BEX processor and BEX conformance
            fixtures define the executable semantics. A reader should understand that a Compute Definition is a reusable, hashed,
            inspectable compute library embedded in the document.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          constants:
            description: |
              Named constants available through `$const`. Keys are constant names; values are arbitrary Blue values.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          functions:
            description: Named reusable BEX functions. Keys are function names; values are function definitions.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7PXuvwLmdB8SaN8AYzL9rRE5cPsGJ7tbTn3iZxsisQnH
            attributesAdded: []
      - status: dev
        content:
          name: Contracts Change Policy
          description: |
            Marker contract that controls how the document's `contracts` map may be changed by coordination workflows. When
            `requireSectionChanges` is present and not false, workflows such as Change Workflow and Accept Change Workflow must
            reject raw changeset entries that directly target `/contracts`; callers must instead use structured `sectionChanges`.

            The purpose is reviewability and safety. Contract entries define runtime behavior, channels, handlers, policies,
            sections, and operations. Arbitrary low-level patches to `/contracts` are hard for humans and agents to audit. By
            requiring Document Section Changes, this marker forces contract edits to be grouped by section with explicit related
            contracts and section metadata.

            This marker is interpreted by the coordination change workflows, not by the Blue Language. A processor or workflow that
            does not support this policy should treat it according to its must-understand and contract capability rules.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          requireSectionChanges:
            description: Policy flag; when present and not false, /contracts changes must use sectionChanges. Set false to allow direct changeset edits.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 2NyPMQjBh9LPugCWq8bAyvsisd6WWhCBQBXyuJswjvPR
            attributesAdded: []
      - status: dev
        content:
          name: Customer Action Requested
          description: |
            Request event asking a customer-facing provider, such as a bank or wallet UI, to present one or more actions to the
            customer and return the selected response. It is used when a document cannot proceed until a person makes a decision,
            supplies input, or explicitly confirms/rejects an action.

            `title` and `message` describe the pending action. `actions` lists the buttons or choices available to the customer,
            each with label, visual variant, optional input schema, required-input flag, input title, and placeholder text. The
            provider should render these choices faithfully enough that the customer's response can be interpreted as the intended
            action.

            This request is often used with actor attribution. A response to high-risk actions may need to be attributed to a
            Principal Actor and a Browser Session source, rather than an Agent Actor or API Call. The document's Actor Policy or
            operation-specific logic should enforce that distinction.
          type:
            blueId: 3PWiqPYvDfSrPGh1YnuRPGjaXL7YytfBcgfrn9WydqCg
          title:
            description: Short title for the pending action.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          message:
            description: Human-readable message describing what is expected.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          actions:
            description: List of available user actions for this pending action request.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              label:
                description: User-facing action label shown in the pending action card.
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              variant:
                description: 'Optional button style variant. Supported values: primary | secondary | reject.'
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              inputSchema:
                description: Optional input schema. If present, the selected action may collect user input.
              inputRequired:
                description: Optional flag indicating whether input is required for this action.
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
              inputTitle:
                description: Optional title displayed above the action input control.
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              inputPlaceholder:
                description: Optional placeholder/help text shown in the action input control.
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 4GCPHTfduFn3xD6KZuRqS1qEG4mA6Ro3Eey3GKB1VCa3
            attributesAdded: []
      - status: dev
        content:
          name: Customer Action Responded
          description: |
            Response event returned after a customer-facing provider handled a Customer Action Requested event. It records which
            action label the customer chose, any input collected from the user, and when the provider says the response occurred.

            `actionLabel` should correspond to one of the requested action labels. `input` carries optional structured user input.
            `respondedAt` records provider-supplied response time. The response should be correlated to the original request using
            the inherited Response correlation fields when available.

            This event is evidence that the provider obtained a customer decision. It does not by itself prove that the action is
            authorized under every document policy; workflows may still inspect actor, source, input, and response details before
            applying state changes.
          type:
            blueId: 7aeKdDTceCVYDtyYZRdK7eQ8UU6PWn6X26Uea3XrGZdX
          actionLabel:
            description: Label of the action selected by the user.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          input:
            description: Optional user-provided payload for the selected action.
          respondedAt:
            description: Timestamp when the user decision was recorded by the bank.
            type:
              blueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DDMHvqmyKrM1PHesWV3rYU454viEkYpzNkywt3fobj9M
            attributesAdded: []
      - status: dev
        content:
          name: Customer Consent Revoked
          description: |
            Event indicating that a Customer Consent document has been revoked. It carries the revocation reason and timestamp
            supplied by the revocation workflow. Observers should treat this as the domain-level signal that the grantee should no
            longer rely on the consent, subject to whatever propagation and processing guarantees are provided by the surrounding
            timelines and channels.

            The event does not itself modify the consent document. The revoke workflow emits the event and applies the document
            patches that set consent status, revocation reason, and revocation time. This separation preserves auditability and
            deterministic processor behavior.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          reason:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          revokedAt:
            type:
              blueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FGgYcn3phzJUoBfDJzV1QxeGKGbaH7zUEj1trRbBpmmJ
            attributesAdded: []
      - status: dev
        content:
          name: Document Bootstrap Completed
          description: |
            Response event indicating that a requested document bootstrap succeeded. The `documentId` identifies the newly created
            or registered document instance according to the surrounding storage or provider system.

            Completion means the bootstrap provider believes the document has been created and is ready for further interaction.
            The exact meaning of `documentId` is application-defined: it may be a BlueId, session ID, storage key, timeline entry,
            provider URI, or another stable identifier. Consumers should use the provider's documented lookup rules.
          type:
            blueId: 7aeKdDTceCVYDtyYZRdK7eQ8UU6PWn6X26Uea3XrGZdX
          documentId:
            description: Document ID of the bootstrapped document.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: G7uhpNRg1akaZN1TMYdxbrYsdk324G4KjLDvP671ULmK
            attributesAdded: []
      - status: dev
        content:
          name: Document Bootstrap Failed
          description: |
            Response event indicating that a requested document bootstrap failed. The `reason` field explains why the provider
            could not create or prepare the document, such as invalid input, missing channel binding, unsupported participant,
            authorization failure, or provider error.

            This event is a domain-level failure response. It does not necessarily imply a processor fatal error in the requesting
            document. Workflows can use it to notify users, retry, store failure state, or select an alternate provider.
          type:
            blueId: 7aeKdDTceCVYDtyYZRdK7eQ8UU6PWn6X26Uea3XrGZdX
          reason:
            description: Failure reason.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Abuh2wgFh9xPrSuSixT2K7upS9cQVp9YpveABuTKJgg4
            attributesAdded: []
      - status: dev
        content:
          name: Document Bootstrap Requested
          description: |
            Request event asking a participant or service to bootstrap a new Blue document from a provided document template or
            initial document. Bootstrapping means creating a processable document instance, binding participant channels, sending
            initial messages, and returning a response that indicates whether the new document is ready.

            The `document` field contains the Blue document to bootstrap. `channelBindings` maps channel names in that document to
            participant identifiers or channel definitions. `initialMessages` provides invitation text, optionally customized per
            channel. `bootstrapAssignee` identifies which participant in the requesting document is expected to perform the
            bootstrap. `onBehalfOf` identifies the account or participant for whom the new document is being created.

            This event is a request, not the resulting document. A provider may respond with Document Bootstrap Completed,
            Document Bootstrap Failed, or Document Bootstrap Responded depending on the outcome and the response model used.
          type:
            blueId: 3PWiqPYvDfSrPGh1YnuRPGjaXL7YytfBcgfrn9WydqCg
          document:
            description: Target Blue document to bootstrap.
          channelBindings:
            description: Maps channel names to participant identifiers.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            valueType:
              blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          initialMessages:
            description: Messages sent to participants when inviting them to the bootstrapped document.
            defaultMessage:
              description: Default invitation message sent to all participants.
              type:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            perChannel:
              description: Per-channel custom invitation messages.
              type:
                blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
              keyType:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              valueType:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          bootstrapAssignee:
            description: Channel name of a participant in the requesting document which is asked to bootstrap the requested document
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          onBehalfOf:
            description: account (channe name) on whose behalf the document is being created
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DRKHv2QVLQneubWYELKCoHcfen76T7KxDk5pdCT9w8Bw
            attributesAdded: []
      - status: dev
        content:
          name: Document Bootstrap Responded
          description: |
            Generic response event for a document bootstrap request. It carries a `status` and optional `reason` so a provider can
            report success, failure, pending state, or another coarse result without choosing a more specific completed/failed
            response type.

            Use this type when the bootstrap protocol needs a compact status response. Use Document Bootstrap Completed or Document
            Bootstrap Failed when the outcome should be semantically specific and easier for workflows to match.
          type:
            blueId: 7aeKdDTceCVYDtyYZRdK7eQ8UU6PWn6X26Uea3XrGZdX
          status:
            description: Decision for the bootstrap request ("accepted" | "rejected").
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          reason:
            description: Details when rejected or additional context.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3LwvmEfS1ojewVrqihmAHYSduHmwQsSfeg8fQZnqM9wQ
            attributesAdded: []
      - status: dev
        content:
          name: Document Request
          description: |
            Source type describing an event or request that originated from another Blue document. A Document Request source lets a
            provider or processor say that an action was not initiated directly by a browser session or API credential, but by a
            document process identified by `documentId` and optionally an `epoch` or version.

            This is useful for document-to-document workflows where one Blue document asks another to perform an operation, create a
            child document, request information, or respond to an embedded process. Actor and Source policies can use Document
            Request to distinguish autonomous document orchestration from direct principal UI actions.

            `documentId` identifies the sending or requesting document. `epoch` can distinguish versions, processing epochs, or
            replay windows according to the provider's protocol.
          type:
            blueId: 52ECLkcYGohcQEaora7hAbd5ve7Uz85DjE2nEARr55Lk
          documentId:
            description: Identifier of the document that triggered the request.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          epoch:
            description: Epoch of the source document when the request was emitted.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 77wa49Ro2LrktFQGrTGvJw1sRLV2wbrybikJHQA1QRuc
            attributesAdded: []
      - status: dev
        content:
          name: Document Section
          description: |
            Marker contract that identifies a logical section of a document and links that section to the fields and contracts
            responsible for it. A section gives humans, agents, and change-management workflows a coherent unit of meaning such as
            payment setup, shipping details, consent terms, participant configuration, or embedded-order handling.

            `title` and `summary` describe the section in user-facing terms. `relatedFields` lists absolute document pointers for
            state fields covered by the section. `relatedContracts` lists same-scope contract keys that implement, enforce, or
            affect the section. Section-aware workflows use this information to group proposed contract changes, validate that
            contract edits belong to the right section, and present changes for review.

            Document Section is metadata with runtime relevance only for workflows that understand it. It is also identity-bearing
            document content. Changing a section's title, summary, fields, or related contracts changes what the document says
            about its own structure and review surface.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          title:
            description: Short, human-readable title shown in UI summaries.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          summary:
            description: Brief functional summary of the section's purpose and behavior.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          relatedFields:
            description: Absolute JSON Pointer paths of fields covered by this section.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          relatedContracts:
            description: Contract keys in the same scope that implement or affect the section.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EQipmtzeTjY7JhgBQWWAhsjBAXsTT2SDu2gv1rXeXSpb
            attributesAdded: []
      - status: dev
        content:
          name: Document Section Change Entry
          description: |
            One entry in a structured Document Section Changes request. It supplies the section key to add or modify, the Document
            Section marker to store at that key, and the contracts that belong to the section. Change-management workflows convert
            this structured entry into deterministic `/contracts` patches.

            The `sectionKey` is the key under `/contracts` for the Document Section marker. The `section` node should be a
            Coordination/Document Section whose `relatedContracts` corresponds to the keys in `contracts`, unless the workflow
            fills or normalizes that relationship. The `contracts` map contains the actual contract nodes to add or replace for
            the section.

            This representation is intentionally higher-level than raw JSON patch. It lets policies require that behavioral changes
            be reviewed as sections rather than as arbitrary pointer edits.
          sectionKey:
            description: Contracts key under /contracts for the Document Section marker.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          section:
            description: Document Section contract node; must include type Coordination/Document Section and relatedContracts should list keys in contracts.
            type:
              blueId: EQipmtzeTjY7JhgBQWWAhsjBAXsTT2SDu2gv1rXeXSpb
          contracts:
            description: Map of contractKey -> contract node to add or replace for this section.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            valueType:
              blueId: AERp8BWnuUsjoPciAeNXuUWS9fmqPNMdWbxmKn3tcitx
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FZcw2teui9fx29nn8eSX9YiePZPxfWPJYCjnyVX1iWc1
            attributesAdded: []
      - status: dev
        content:
          name: Document Section Changes
          description: |
            Structured collection of section-based contract mutations. It divides `/contracts` changes into `add`, `modify`, and
            `remove` lists so a workflow can validate and apply them coherently under Contracts Change Policy.

            `add` creates new Document Section markers and their related contracts. `modify` replaces an existing section's marker
            and related contracts with a full new section definition. `remove` deletes a section key and the contracts listed as
            related to that section. The exact patch sequence is produced by the supporting workflow, but the semantic intent is
            section-level contract evolution rather than low-level pointer editing.

            This type is useful for human review, AI-agent proposal validation, and audit trails because it preserves why a set of
            contract changes belong together.
          add:
            description: New sections to create with their Document Section and contracts.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: FZcw2teui9fx29nn8eSX9YiePZPxfWPJYCjnyVX1iWc1
          modify:
            description: Existing sections to update with a full contracts map.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: FZcw2teui9fx29nn8eSX9YiePZPxfWPJYCjnyVX1iWc1
          remove:
            description: Section keys to remove (also removes the section's related contracts).
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3WUHev4EbhT1WUTikdZTPaXnapwvgmepVfV3KzYwJDzh
            attributesAdded: []
      - status: stable
        content:
          name: Document Status
          description: |
            Base type for document lifecycle/status indicators used by coordination documents. A Document Status communicates the
            high-level state of a document to participants, user interfaces, agents, and workflows. It is not the same as the Blue
            Contracts processor's internal lifecycle markers; it is application-level state chosen by the document author.

            The `mode` field gives a coarse lifecycle phase. `pending` means the document is waiting for a prerequisite or initial
            action. `active` means the document is currently operating and processing events. `terminated` means the application
            process represented by the document has reached a final conclusion. Concrete statuses refine these categories with
            domain-specific meaning.

            Status nodes are Blue content and can be used in patches, events, and workflow conditions. A document may use custom
            status types as long as downstream workflows and participants understand them.
          mode:
            description: |
              Defines the high-level phase of the document's lifecycle. Must be one of:
                pending: The document is waiting for a pre-condition before its core logic begins.
                active: The document is in its main operational phase, actively processing events.
                terminated: The document has reached a final, conclusive state.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
            attributesAdded: []
      - status: stable
        content:
          name: Event
          description: |
            Base coordination type for Blue events delivered to channels, emitted by handlers, or recorded inside timeline entries.
            An Event is a piece of meaning that may cause a document to react. It is not itself a transport envelope, a timeline
            entry, or a processing result; those are separate structures. Concrete event subtypes define the semantic fields
            necessary for matching and handling.

            Events are identity-bearing Blue content. If an event is emitted, stored in a checkpoint, or included in a timeline
            entry, its content and type determine its identity. The Coordination model treats events as read-only during
            processing. Handlers may emit new event nodes, but document mutation must happen through Update Document patches rather
            than by mutating event objects.

            Event is intentionally broad. Request, Response, Lifecycle Event, Status Change, Chat Message, Customer Action events,
            and domain-specific operation messages can all refine it. A concrete channel or workflow should describe which event
            subtype it accepts and which fields are required for deterministic processing.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
            attributesAdded: []
      - status: stable
        content:
          name: Inform User About Pending Action
          description: |
            Event requesting that a user or user-facing system be informed about a pending action required by the document. It is
            designed for workflows that need human intervention: signing, approval, authorization, input collection, consent,
            payment setup, selection, or another operation exposed by the document.

            The event names the `operation` the user should run, supplies a `title` and `message` suitable for UI display, names the
            `channel` on which the follow-up is expected, and may include an `expectedRequest` shape. A UI, bank, assistant, or
            agent can use this event to render a pending-action card and later submit an Operation Request through the correct
            channel.

            This event does not force the user to act and does not mutate the document. It is a communication artifact that makes a
            workflow's next required external action explicit and auditable.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          operation:
            description: The name of the operation defined in the document that the user is required to run to fulfill the pending action.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          title:
            description: A short, user-facing title describing the required action (e.g., "Payment Setup Required", "Agreement Required").
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          message:
            description: Human-readable explanation of what is needed and relevant context.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          channel:
            description: |
              Contracts-map key of the channel in this scope expected to receive the follow-up that triggers the required operation.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          expectedRequest:
            description: The expected request payload structure for the operation’s request.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6NYHvtkmfNakoMEpb1ECFBiC2gmQqaD45DXfuTFEGC4Y
            attributesAdded: []
      - status: stable
        content:
          name: Lifecycle Event
          description: |
            Coordination event representing a processor lifecycle transition such as document processing initiation or termination.
            Lifecycle Event is distinct from application-level status changes. It is produced or routed by the processor or by
            lifecycle-aware workflow logic to indicate that a processing scope entered a lifecycle phase.

            Concrete lifecycle event types should define the specific phase and fields. A lifecycle event may be useful for
            initialization workflows, audit logs, parent-scope bridging, or user notifications. It should not be confused with the
            Blue Contracts processor's internal marker state, although lifecycle events often correspond to marker writes.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HjjcpRqJHBk3gjiyrNNmBPhcpXdnAzU7UfsG2CAR5yMZ
            attributesAdded: []
      - status: stable
        content:
          name: Operation
          description: |
            Marker contract declaring a named operation that a document exposes to participants or other documents. An Operation
            defines the expected request shape and the channel through which Operation Request events are delivered. It is the
            document's public action surface: users, services, agents, or other documents invoke operations rather than patching
            internal state directly.

            The `request` field is the Blue shape that invocation payloads should conform to. The `channel` field names the
            scope-local channel contract on which Operation Request events are expected. A corresponding handler, commonly a
            Sequential Workflow Operation, implements the behavior for this operation by binding to that channel and running the
            configured steps.

            Operation itself is a marker. It does not execute. Runtime behavior emerges only when a supported channel accepts an
            Operation Request and a supported handler implements the operation. The marker is still identity-bearing document
            content and may be inspected by UIs, agents, policy engines, and other participants to understand what actions the
            document allows.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          request:
            description: |
              The request schema for this operation (any Blue node). Invocation payloads MUST conform to this shape.
          channel:
            description: |
              Contracts-map key of the Channel in this scope on which Operation Request events are sent to invoke this operation.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
            attributesAdded: []
      - status: stable
        content:
          name: Operation Request
          description: |
            Coordination type `Operation Request`. This type is identity-bearing Blue content in the coordination package. It defines the
            semantic role named by its `name` field and, when used as a contract/event/marker/source/status specialization,
            should be interpreted according to its declared parent type `none` and its field definitions. The
            description is intentionally part of the type identity: changing it changes what this type claims to mean.

            A reader should treat this type as a precise domain term, not a loose label. Concrete processors, workflows, and
            user interfaces should use the type BlueId and the fields declared on this node to decide compatibility, routing,
            display, and audit behavior. If a document needs different semantics, it should define a different type rather
            than reuse this one with incompatible meaning.
          operation:
            description: The name of the operation to invoke (must exist on the target).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          request:
            description: |
              Payload for the operation. Shape MUST match the target Operation’s `request` contract (scalars or structured nodes).
          document:
            description: Specifies the target document for the operation, typically containing the blueId of the document to operate on.
          allowNewerVersion:
            description: Controls concurrent modification handling. When true, processes the operation on the latest document version even if it changed. When false, only processes if the document still has the same blueId as specified.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6MWZuzuavJuh9FiPJBN7mgVmAVH8buKN2vRdmm5NjF4T
            attributesAdded: []
      - status: dev
        content:
          name: Principal Actor
          description: |
            Actor specialization representing direct action by a principal exercising their own authority. A principal is the
            person, organization, account holder, or other primary identity that owns or controls the timeline, channel, account,
            or document context in which the event was produced. A Principal Actor means the Timeline Provider or event source is
            asserting that the action was initiated through a mechanism it treats as direct principal control, such as an
            authenticated user interface session, a principal-owned API credential, or another provider-approved direct-control
            channel.

            This type is the base identity for policies that require human or principal authorization. A policy that says an
            operation requires a principal actor is saying that delegated automation is not enough: the action must be attributed
            to the principal themselves or to a provider-defined specialization of Principal Actor. Provider-specific principal
            actor types should refine this type and include enough evidence for auditing, such as UI session details,
            authentication strength, API credential identity, or regulatory identity verification level.

            This type does not itself prove that the principal was physically present, that a particular authentication method was
            used, or that a legal signature occurred. Those assertions belong in concrete subtypes. This base type only provides
            the nominal category used by actor-policy matching and by documents that need to distinguish principal authority from
            delegated agent authority.
          type:
            blueId: CFPWz2TX7a1xq6xZYnx93Cu7MqEdMzumr3Zgnx6TrVtd
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: QpJs5D2xRNzmEqXvra312z1fXkyyJehdJUs4ZTwUnD3
            attributesAdded: []
      - status: dev
        content:
          name: Propose Change Operation
          description: |
            Operation marker for proposing a Change Request without applying it immediately. The operation records a proposed
            change under proposal state so another participant or policy-controlled workflow can later accept or reject it.

            Propose Change is used when a document requires review, approval, negotiation, or human consent before applying a
            mutation. The request shape is Coordination/Change Request, including a summary and optional structured sectionChanges.
            The operation itself only declares the action; the paired Propose Change Workflow implements storage and validation.
          type:
            blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
          request:
            type:
              blueId: Em6YA77iVnnRaScCrkZr9C9VkQF14i2pk5fA8KNiHS41
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: vWt8Hw4xjk6KuL6uz9726d9xazaKvYWAthdAyXH4by8
            attributesAdded: []
      - status: dev
        content:
          name: Proposed Change Invalid
          description: |
            Event emitted when a proposed, accepted, rejected, or direct change request cannot be processed under the document's
            change-management rules. The event communicates a deterministic reason such as missing summary, missing proposal,
            duplicate proposal, forbidden `/contracts` mutation, malformed sectionChanges, or another validation failure.

            This event is intended to be observable by users, agents, and audit tools. It signals that the requested change did not
            become document state. The `reason` field should be human-readable and stable enough for diagnostics, but it is not a
            substitute for the processor's formal error category when the processor itself terminates fatally.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          reason:
            description: Human-readable reason for the failure.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 8oEU9ysLsGJJeeCDsEgnHbyu8vuWTwogExHmNc7t512n
            attributesAdded: []
      - status: dev
        content:
          name: Reject Change Operation
          description: |
            Operation marker for rejecting a previously proposed change. Rejection removes proposal state without applying the
            requested changes. It is used when a reviewer, participant, or policy decides that the proposed mutation should not
            become part of the document.

            Reject Change complements Propose Change and Accept Change. The operation itself declares the action; the paired Reject
            Change Workflow checks that proposal state exists and removes it through an Update Document step. If no proposal exists
            at the expected path, the workflow emits Proposed Change Invalid.
          type:
            blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 9EdyRb2ssCWhbc1uoNxpS1fygKwSz6392vd8tMhcGcEt
            attributesAdded: []
      - status: stable
        content:
          name: Request
          description: |
            Base event type for a specific, trackable request made by one participant, document, service, or timeline actor to
            another. A Request carries a caller-generated `requestId` so that responses, checkpoints, user-interface prompts, and
            audit trails can correlate later activity back to the original request.

            Request is intended for workflows where the recipient may respond asynchronously or where multiple similar requests may
            be in flight. The `requestId` should be unique within the caller's relevant conversation or timeline. It is not
            necessarily globally unique unless the surrounding protocol makes it so. A Response should copy the relevant requestId
            into its correlation structure.

            Concrete Request subtypes define the actual payload and authorization semantics. For example, an Operation Request
            invokes a named document operation; a Document Bootstrap Requested event asks a participant to create a new document;
            a Customer Action Requested event asks a bank or UI provider to obtain a user's decision.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          requestId:
            description: |
              A caller-generated ID for this specific request. This ID is used by the recipient to correlate their response.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3PWiqPYvDfSrPGh1YnuRPGjaXL7YytfBcgfrn9WydqCg
            attributesAdded: []
      - status: stable
        content:
          name: Response
          description: |
            Base event type for a response to a prior Request. A Response links back to the request it answers through the
            `inResponseTo` correlation object. This lets documents match an asynchronous answer to the original action, detect
            stale or duplicate responses, and keep audit trails across multiple participants and timelines.

            The correlation should include at least the original requestId, and may include the incoming event or a reference to it
            when the whole workflow was triggered by another event. The response payload is defined by concrete response subtypes,
            such as Customer Action Responded, Document Bootstrap Completed, or Document Bootstrap Failed.

            Response is not a guarantee that the requested action succeeded. It only says this event is semantically an answer to a
            request. Concrete response fields and type names must indicate whether the result was successful, failed, partial,
            rejected, or still pending.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          inResponseTo:
            type:
              name: Correlation
              description: A structured reference linking this response back to the original action and trigger.
              requestId:
                description: The 'requestId' from the specific Request event this is a response to.
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              incomingEvent:
                description: An event which initiated the entire workflow. Normally just blueId of it.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7aeKdDTceCVYDtyYZRdK7eQ8UU6PWn6X26Uea3XrGZdX
            attributesAdded: []
      - status: stable
        content:
          name: Sequential Workflow
          description: |
            Handler contract that implements deterministic workflow logic by executing a list of workflow steps in order after the
            bound channel delivers a matching event. Sequential Workflow is the coordination workhorse: it lets a document express
            behavior as Blue content, run computation steps, apply document updates, and emit follow-up events while still using
            the Blue Contracts processor for patch validation, cascades, checkpoints, generalization, and gas.

            Each step receives the same triggering event, the current contract context, and the results of earlier steps. Step
            results are keyed by step name when a name is supplied. Steps are evaluated sequentially, so later steps can read
            earlier step outputs. When an Update Document step previews or applies patches, later workflow steps must see the
            updated working document state according to the host processor's working-document semantics; the final document commit
            still occurs through the Blue Contracts processor and must preserve type soundness.

            Workflow steps are not arbitrary side effects. Compute steps read and return data. Update Document steps request
            patches. Trigger Event steps request event emission. Evaluate is a deterministic escape hatch. The handler's
            observable effects are buffered and applied by the processor in the contract-result order defined by Blue Contracts.
          type:
            blueId: 9ZE5pGjtSGJgWJG7iAVz4iPEz5CatceX3yb3qp5MpAKJ
          steps:
            description: |
              Ordered workflow steps. List order is execution order. Each step may read prior named step results. Mutation-producing
              steps must use processor patch/event mechanisms rather than hidden side effects.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 99AomnUQTnL52YVYXwEbGNeKnV6u1cjm73xLFSAt7mwe
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
            attributesAdded: []
      - status: stable
        content:
          name: Sequential Workflow Operation
          description: |
            Convenience handler pattern that implements a named Operation using a Sequential Workflow. The `operation` field names
            the Operation marker in the same scope that this workflow implements. When the operation's channel delivers an
            Operation Request for that operation, this handler runs its configured steps to validate the request, compute results,
            update document state, and emit follow-up events.

            This type ties the document's public action surface to executable workflow logic. The Operation marker explains what
            request shape the document accepts and which channel receives invocations; Sequential Workflow Operation supplies the
            deterministic implementation. Keeping those pieces as Blue content lets participants inspect and hash both the API
            surface and the implementation.

            The workflow remains subject to all Blue Contracts processor rules: same-scope handler binding, dispatch snapshots,
            boundary checks, Update Document cascades, type generalization, actor/source policies, checkpoints, termination, and gas.
          type:
            blueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
          operation:
            description: |
              The name of the Operation this handler implements. Must reference an Operation defined in the same scope.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: B5mVH4caQv9Hmzeb5ZmCtzYomooFzTdoCQ4mZVwHY3MS
            attributesAdded: []
      - status: stable
        content:
          name: Sequential Workflow Step
          description: |
            Abstract base type for a single step in a Sequential Workflow. A step is a deterministic unit of workflow behavior. It
            may compute data, request document patches, or request event emission depending on its concrete subtype. This base
            type exists so workflow step lists can be typed uniformly while allowing concrete steps such as Compute, Update
            Document, and Trigger Event to define their own fields and semantics.

            A step executes in the context of a workflow invocation. It can read the triggering event, previous step results, the
            current contract, and the current working document view made available by the workflow processor. A step must not
            bypass the processor's mutation rules. If it wants to change the document, it must produce patches consumed by an
            Update Document step or by the handler result machinery.

            Step identity matters. The exact step type, fields, compute program, and descriptions are Blue content and affect the
            document's BlueId. A processor must execute only supported step subtypes and must fail or treat unsupported step types
            according to the surrounding handler/runtime semantics.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 99AomnUQTnL52YVYXwEbGNeKnV6u1cjm73xLFSAt7mwe
            attributesAdded: []
      - status: dev
        content:
          name: Source
          description: |
            Base type describing the delivery mechanism or access path through which a request, timeline entry, or event reached a
            Timeline Provider or document processor. Source is complementary to Actor: Actor answers who or what performed the
            action, while Source answers how the action was delivered. Examples include an authenticated browser session, an API
            call, a document-to-document request, a webhook, or a blockchain transaction.

            Source nodes are used for auditability and policy decisions. An Actor Policy or operation-specific rule may require a
            request to come from a browser session, exclude API calls, or distinguish between a direct user action and an automated
            document request. Concrete Source subtypes should describe what the provider is attesting to and what fields observers
            can rely on, such as session nonce, API key identifier, upstream document reference, transaction hash, or proof of
            delivery.

            Source is not a runtime channel by itself and does not execute. It is identity-bearing content attached to events or
            timeline entries so processors and auditors can evaluate provenance and trust assumptions deterministically.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 52ECLkcYGohcQEaora7hAbd5ve7Uz85DjE2nEARr55Lk
            attributesAdded: []
      - status: stable
        content:
          name: Status Change
          description: |
            Event indicating that a document's application-level status has changed. The `status` field carries the new
            Coordination/Document Status node. Status Change is useful for notifying participants, timelines, embedded parent
            scopes, or external observers when a workflow transitions between pending, active, completed, failed, or custom status
            states.

            This event is descriptive. It does not itself change status; a workflow must still apply the corresponding Update
            Document patch if the document state should change. Emitting Status Change alongside a patch creates an auditable event
            that mirrors the state transition.
          type:
            blueId: 7ugyHm8fpgvQx6pbLcW8cRNLBVDBExCp2iSYgd82ak6z
          status:
            description: The new status node.
            type:
              blueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GXbF9ycv87y69kutDUmACbmeme7dGBSPw47fMQefvDPx
            attributesAdded: []
      - status: stable
        content:
          name: Status Completed
          description: |
            Document Status specialization for successful completion. Status Completed means the document's application-level goal
            has been achieved and the process represented by the document has finished as expected.

            This is an application status, not necessarily a Blue Contracts termination marker. A document may be completed while
            the processor still permits further events, or a workflow may also choose to terminate the scope. The exact runtime
            consequence is defined by the document's contracts.
          type:
            blueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
          mode:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: terminated
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Pzdwn6mQJT2qFDaF4V1dzpcyu4ejRqDv8neLPnbHRGi
            attributesAdded: []
      - status: stable
        content:
          name: Status Failed
          description: |
            Document Status specialization for an unsuccessful final application state. Status Failed means the document's intended
            process could not complete due to an error, rejection, timeout, invalid input, policy failure, or other domain-specific
            reason.

            This status is not the same as processor fatal termination, although a processor fatal may cause a document to set a
            failed status if its workflows do so. It is a domain-level signal to participants that the document's goal was not
            achieved.
          type:
            blueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
          mode:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: terminated
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Fh7VjkS1XTg9BzQWBQrvD9ePLUEZVR86FAhVbttw1Wxs
            attributesAdded: []
      - status: stable
        content:
          name: Status In Progress
          description: |
            Document Status specialization for active processing. Status In Progress means the document is in its main operational
            phase and may continue to accept events, update state, emit requests, wait for responses, and process embedded scopes.

            This status is appropriate for workflows that involve multiple sequential or asynchronous steps over time. It does not
            imply success or failure; it means the document has work underway and has not reached a final application-level state.
          type:
            blueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
          mode:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: active
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: E6jaeVfFuyjB4YEZyp7fvUt8AJ7BmKr8WAM9oGDmhMbM
            attributesAdded: []
      - status: stable
        content:
          name: Status Pending
          description: |
            Document Status specialization for a generic initial or waiting state. Status Pending means the document has not yet
            entered its main operational phase because it is waiting for an initial event, prerequisite, participant response,
            authorization, configuration, or other condition.

            This status should not be interpreted as failure. It is a stable state in which the document is alive but not yet
            active. Workflows may transition out of pending when the required event arrives or a precondition is satisfied.
          type:
            blueId: QHoUCCVhepZWQnSo9VfZCJWbSwyA9TuT65tBZMVtnRX
          mode:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: pending
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Gqcw51QJT9NStqo2ka3E76tQ8UZie33F4yqdjwskav79
            attributesAdded: []
      - status: stable
        content:
          name: Timeline
          description: |
            A Timeline is an append-only, tamper-evident sequence of Timeline Entries representing the actions, statements,
            observations, and commitments associated with one timeline owner or provider context. Conceptually, it is a personal or
            institutional ledger: Alice may have a timeline, a bank may have a timeline, an AI agent may have a timeline, and a
            service may have a timeline. A Blue document can interact with multiple timelines without requiring global consensus;
            each timeline remains an independently maintained perspective that composes with others through deterministic
            processing rules.

            A Timeline is expected to be maintained by a Timeline Provider or equivalent storage mechanism. The provider assigns
            monotonically ordered timestamps, stores entries immutably, verifies the timeline owner's identity, records actor and
            source attribution, and provides completeness guarantees to processors. A completeness guarantee is a binding statement
            such as: there are no entries with timestamp less than T, and future entries accepted by this provider will have
            timestamp greater than or equal to T. This is what lets independent processors know they have a complete view of all
            relevant timeline events up to a deterministic processing boundary.

            Timeline entries are hash-linked using `prevEntry`, making historical tampering detectable. A blockchain, managed
            platform, bank, government identity service, or local provider may all serve as timeline storage, provided they define
            how entries are ordered, how finality/completeness is established, and how actor attribution is guaranteed. The
            `timelineId` field is the stable application-defined identifier used by channels and providers to locate this timeline.
          timelineId:
            description: |
              Stable provider- or application-defined identifier of this timeline. A Timeline Channel uses this value, together with
              provider-specific context, to locate entries. The identifier should not be reused for a different actor or history
              because processors and auditors treat the timeline as one append-only perspective.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DFycCEHaAuMXptCMxQ4N5M1UW2yyddgi5xa3TPWDTNAZ
            attributesAdded: []
      - status: stable
        content:
          name: Timeline Channel
          description: |
            Channel contract that accepts Timeline Entry events belonging to one configured timeline. A Timeline Channel is the
            bridge between append-only timeline storage and Blue contract processing: when a Timeline Provider signals or supplies
            a new entry for the configured `timelineId`, the channel can deliver that entry's message to handlers in the current
            scope.

            Timeline Channel processing is deterministic only when the feeder/provider layer supplies entries in a complete order.
            In multi-party documents, a processor must not blindly process whichever timeline notifies first if other timeline
            channels could contain earlier events. The feeder or channel environment is expected to use provider completeness
            guarantees to gather all entries before the processing boundary timestamp, then deliver them in deterministic order.
            This type identifies the timeline a channel observes; the exact provider protocol, proof format, and completeness
            query are outside this type but should be defined by a concrete channel specialization.

            The channel is a contract runtime entry point, not the timeline itself. It should be used as a scope-local contract key
            that handlers bind to. Each Timeline Channel should have its own checkpoint state so repeated entries are not processed
            twice and late or stale entries can be rejected according to the Blue Contracts checkpoint model.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          timelineId:
            description: The `timelineId` whose entries this channel delivers.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Dt8xNecxDiSYZAcmpWjPJhFwWMZ2gwgdLKK5wVE8566n
            attributesAdded: []
      - status: stable
        content:
          name: Timeline Entry
          description: |
            A Timeline Entry is one immutable event in an append-only Timeline. It records a message produced by the timeline
            owner or an authorized actor, links to the previous entry, carries a provider-assigned timestamp, and includes actor and
            source attribution. The entry is a Blue document, so its BlueId is a content address over the entry fields. The
            `prevEntry` link creates a hash chain: modifying any historical entry changes its BlueId and breaks verification for
            all subsequent entries that reference it.

            The `timeline` field identifies the timeline and provider context to which the entry belongs. The `timestamp` is an
            integer microsecond timestamp, generally assigned by the Timeline Provider. Timestamps establish deterministic ordering
            across entries. Within a single timeline they should be monotonically increasing according to the provider's rules. In
            multi-timeline documents, processors sort candidate entries by timestamp and deterministic tie-breakers such as channel
            key and provider-specific ordering fields. Completeness guarantees from providers are necessary before processors treat
            the ordering as complete.

            The `message` field is the actual Blue event content being delivered to documents, such as an Operation Request, Status
            Change, Chat Message, or domain-specific action. The `actor` field attributes the entry to a principal, agent, or
            specialized actor. The optional `source` field records how the request reached the provider, such as browser session,
            API call, document request, or blockchain transaction. A processor should never infer actor/source semantics from the
            message body when these fields are present; the provider's attribution is the auditable claim.
          timeline:
            description: The timeline this entry belongs to.
            type:
              blueId: DFycCEHaAuMXptCMxQ4N5M1UW2yyddgi5xa3TPWDTNAZ
          prevEntry:
            description: |
              Reference to the previous Timeline Entry in the same timeline. The first entry may omit this field or use an explicit
              provider-defined beginning marker. Every later entry should reference the BlueId of its immediate predecessor. This
              creates the tamper-evident chain: modifying a historical entry changes that entry's BlueId and invalidates the
              `prevEntry` reference held by its successor.
          message:
            description: |
              The event payload recorded in this entry. It may be any Blue node, but concrete Timeline Channels and workflows usually
              expect a subtype of Coordination/Event such as Operation Request, Chat Message, Status Change, or a domain event.
          timestamp:
            description: |
              Provider-assigned integer timestamp in microseconds since Unix epoch unless a concrete timeline provider defines a
              stricter compatible representation. The timestamp is used for deterministic ordering across entries and for provider
              completeness guarantees. Once a provider guarantees no entries before T, future entries must be assigned timestamps
              greater than or equal to T.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
          actor:
            description: |
              Attribution of who or what caused this entry. This field is the provider's claim about principal versus agent action
              and is the basis for Actor Policy enforcement and audit. It should be a Coordination/Actor specialization.
            type:
              blueId: CFPWz2TX7a1xq6xZYnx93Cu7MqEdMzumr3Zgnx6TrVtd
          source:
            description: |
              Optional provenance of how the action reached the provider, such as Browser Session, API Call, Document Request, or
              blockchain transaction. Source complements actor attribution and can be used by policy rules.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6ckC9avECT39tVTZ3iiKC1wRPAmxiS92bZuji4pANZCw
            attributesAdded: []
      - status: stable
        content:
          name: Trigger Event
          description: |
            Workflow step that requests emission of a Blue event from the current workflow invocation. Trigger Event constructs or
            resolves an `event` payload and adds it to the handler result so the Blue Contracts processor can record, enqueue,
            route, bridge, and gas-charge it according to the runtime event rules.

            Trigger Event does not directly deliver the event to arbitrary channels. Emitted events enter the current scope's
            Triggered FIFO or root outbox according to processor semantics. Local Triggered delivery occurs at the scope's FIFO
            drain phase, not immediately at the moment this step is evaluated. Embedded child emissions may be bridged to a parent
            through Embedded Node Channels if configured.

            The event payload must be a valid Blue node. Invalid event construction causes runtime failure before successful emit
            gas is charged. If expression/template processing is used to construct the event, that compute work is charged
            separately from the processor's event emission and routing charges.
          type:
            blueId: 99AomnUQTnL52YVYXwEbGNeKnV6u1cjm73xLFSAt7mwe
          event:
            description: The event payload to enqueue (any Blue node).
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3Rgcf7G716Y9JhCov4m72m53tqpv3yDpzcBwGrxUaQSJ
            attributesAdded: []
      - status: stable
        content:
          name: Update Document
          description: |
            Workflow step that requests selected-document mutation by applying a list of Blue Contracts patch entries. Update
            Document is the controlled gateway for state changes in a sequential workflow. It is the point where computed changeset
            data becomes actual document mutation under the processor's rules.

            Every patch must pass boundary validation, reserved-key protection, runtime insertion normalization, and Blue Language
            validity checks. Each successful patch is applied in order. After each patch, the processor must run post-patch
            type-soundness validation and dynamic generalization when required, then deliver Document Update cascades before the
            next patch. If a patch would make the document invalid and no permitted generalization can repair the declared type,
            the step fails and the processor terminates the executing scope according to the Blue Contracts fatal rules.

            In a sequential workflow, an implementation may preview Update Document patches in a frozen WorkingDocument before the
            buffered processor commit so that later steps can read the updated state without materializing the full document. That
            preview must use the same immutable patch planning, conformance, generalization policy, and boundary rules as the final
            processor commit. The step's `changeset` is therefore not a loose JSON patch list; it is a deterministic, gas-metered,
            type-sound state transition request.
          type:
            blueId: 99AomnUQTnL52YVYXwEbGNeKnV6u1cjm73xLFSAt7mwe
          changeset:
            description: |
              Ordered list of patch entries to apply through the Blue Contracts processor. The order is significant. Each patch is
              validated and applied atomically with its post-patch type-soundness/generalization work and Document Update cascade
              before the next patch is considered.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: Bz49DbfqKC1yJeCfv5RYPZUKTfb7rtZnmreCaz4RsXn5
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FuD8hYGXvwBJGBzXhFB6DVtWHawt8hbpM6yT94H4p7cZ
            attributesAdded: []
  - name: Core
    types:
      - status: stable
        content:
          name: Channel
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Abstract base for event entry points within a scope. Channels decide whether
            an incoming event matches at this scope. External channels may also use the
            scope's checkpoint to gate duplicates/stale events.
          type:
            blueId: AERp8BWnuUsjoPciAeNXuUWS9fmqPNMdWbxmKn3tcitx
          event:
            description: Optional matcher payload used by the channel's processor to further restrict which incoming events it accepts at this scope.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            attributesAdded: []
      - status: stable
        content:
          name: Channel Event Checkpoint
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Stores last-seen events per external channel at this scope to enable
            idempotent processing and ordering. Updates are Direct Writes (no Document Update).
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          lastEvents:
            description: |
              Map of channelKey (the contracts key of an external channel in this scope)
              to the entire last event node seen for that channel. Values are unconstrained
              (any Blue node) to allow channel-specific shapes.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: B7YQeYdQzUNuzaDQ4tNTd2iJqgd4YnVQkgz4QgymDWWU
            attributesAdded: []
      - status: stable
        content:
          name: Contract
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Base for all contracts (channels, handlers, markers). Contracts live under a
            scope's contracts map (keyed by Text). At runtime, contract processors execute
            deterministically and only through explicit operations; there are no implicit
            side effects.
          order:
            description: Deterministic sort key within a scope; missing ≡ 0.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: AERp8BWnuUsjoPciAeNXuUWS9fmqPNMdWbxmKn3tcitx
            attributesAdded: []
      - status: stable
        content:
          name: Document Processing Initiated
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Published once at a scope on first processing (before writing the
            Processing Initialized Marker). At root, it is also included in the run's
            triggered_events outbox.
          documentId:
            description: Stable document identifier (original BlueId).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: BrpmpNt5JkapeUvPqYcxgXZrHNZX3R757dRwuXXdfNM2
            attributesAdded: []
      - status: stable
        content:
          name: Document Processing Terminated
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Published at the terminating scope when processing ends, either gracefully
            or fatally. Bridgeable to the parent via Embedded Node Channel if configured.
          cause:
            description: One of fatal, graceful.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          reason:
            description: Optional explanation.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 5AJiAUgiSDwfCzv9rCYKNaAJu1hm8BXFu7eLNAEHNACr
            attributesAdded: []
      - status: stable
        content:
          name: Document Update
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Emitted once per participating scope for each successful patch
            (bottom-up delivery). 'op' uses lower-case enum; 'path' is scope-relative
            for the receiving scope. 'before' and 'after' are snapshots (immutable views).
          op:
            description: One of add, replace, remove.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          path:
            description: Scope-relative pointer. "/" when the receiving scope's root was affected.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          before:
            description: Snapshot before the patch at this path (may be null).
          after:
            description: Snapshot after the patch at this path (may be null).
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7htwgHAXA9FjUGRytXFfwYMUZz4R3BDMfmeHeGvpscLP
            attributesAdded: []
      - status: stable
        content:
          name: Document Update Channel
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Fires on successful patches with immediate bottom-up cascade (origin → ancestors → root).
            Matching uses subtree semantics against ABS(scope, path). Payload is the processor-emitted
            Document Update event with scope-relative path.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          path:
            description: |
              Scope-relative absolute pointer (begins with "/") defining the watched subtree.
              Match iff the absolute changed path equals or is a descendant of ABS(scope, path).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6H1iGrDAcqtFE1qv3iyMTj79jCZsMUMxsNUzqYSJNbyR
            attributesAdded: []
      - status: stable
        content:
          name: Embedded Node Channel
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Bridges a child scope's emissions (including lifecycle nodes) into the parent
            after the child finishes.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          childPath:
            description: Scope-relative absolute pointer to the child root to bridge.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Fjbu3QpnUaTruDTcTidETCX2N5STyv7KYxT42PCzGHxm
            attributesAdded: []
      - status: stable
        content:
          name: Handler
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Abstract base for logic bound to exactly one channel (same scope). At runtime,
            a handler may: (1) apply patches (list of Json Patch Entry), (2) emit events,
            (3) consume gas via consumeGas(units: Integer), and (4) terminate.
          type:
            blueId: AERp8BWnuUsjoPciAeNXuUWS9fmqPNMdWbxmKn3tcitx
          channel:
            description: The contracts-map key of the channel this handler binds to (same scope).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          event:
            description: Optional matcher payload used by the handler's processor to further restrict events.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 9ZE5pGjtSGJgWJG7iAVz4iPEz5CatceX3yb3qp5MpAKJ
            attributesAdded: []
      - status: stable
        content:
          name: Json Patch Entry
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Deterministic subset of RFC 6902 used by handlers to request document changes.
          op:
            description: One of add, replace, remove.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          path:
            description: Absolute JSON Pointer within the document (must begin with "/").
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          val:
            description: Payload for add and replace (any Blue node). Omitted for remove.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Bz49DbfqKC1yJeCfv5RYPZUKTfb7rtZnmreCaz4RsXn5
            attributesAdded: []
      - status: stable
        content:
          name: Lifecycle Event Channel
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Delivers processor lifecycle notifications at this scope, e.g.,
            Document Processing Initiated and Document Processing Terminated.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: H2aCCTUcLMTJozWkn7HPUjyFBFxamraw1q8DyWk87zxr
            attributesAdded: []
      - status: stable
        content:
          name: Marker
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Abstract base for informational/policy contracts. Markers do not run logic;
            they carry state/policy enforced by the processor.
          type:
            blueId: AERp8BWnuUsjoPciAeNXuUWS9fmqPNMdWbxmKn3tcitx
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
            attributesAdded: []
      - status: stable
        content:
          name: Process Embedded
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Declares embedded child scopes beneath the current scope. The processor reads
            this list dynamically and re-reads after each child finishes.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          paths:
            description: |
              Scope-relative absolute pointers to child roots (strings beginning with "/",
              resolved against the current scope).
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Hu4XkfvyXLSdfFNUwuXebEu3oJeWcMyhBTcRV9AQyKPC
            attributesAdded: []
      - status: stable
        content:
          name: Processing Initialized Marker
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Recorded exactly once at a scope on first processing; stores the pre-init
            identifier of the scope's subtree. Writing this marker is a patch that
            triggers a Document Update cascade.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          documentId:
            description: Stable document identifier (original BlueId) of this scope.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EVguxFmq5iFtMZaBQgHfjWDojaoesQ1vEXCQFZ59yL28
            attributesAdded: []
      - status: stable
        content:
          name: Processing Terminated Marker
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Final state for a scope (either graceful or fatal). Once present, the scope
            becomes permanently inactive both for the remainder of the current run and in
            subsequent runs until explicitly replaced by a parent. Written as a Direct
            Write (no Document Update) when termination occurs.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          cause:
            description: One of fatal, graceful.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          reason:
            description: Optional human-readable explanation.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 5NiEhupJ6uF54Q3vs4GwQX4UX4ExtwHpKRVvjKEHtvjR
            attributesAdded: []
      - status: stable
        content:
          name: Triggered Event Channel
          description: |
            Core type of Blue Language v1.0 (see https://language.blue).
            Delivers events previously enqueued by handlers into the scope's FIFO.
            One drain per scope at the end of scope processing; never drains during cascades.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: C77W4kVGcxL7Mkx9WL9QESPEFFL2GzWAe647s1Efprt
            attributesAdded: []
