            Specification of a rate based on the exchange of a pair of cash assets in specific currencies, e.g. USD versus GBP.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/observable/asset
          assetClass:
