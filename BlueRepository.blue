      - status: dev
        content:
          name: Customer Consent
          description: Generic customer consent granted to a grantee (e.g., merchant).
          consentKind:
            description: Classification of the consent (e.g., cardTransactionMonitoring).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          consentDetails:
            description: Generic scope details (merchant id, event categories, requesting contract refs, etc.).
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            valueType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          consentStatus:
            description: Consent state (granted, revoked).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          grantedAt:
            description: Timestamp when consent was granted.
            type:
              blueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
          revokedAt:
            description: Timestamp when consent was revoked.
            type:
              blueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
          revocationReason:
            description: Reason for revocation.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          contracts:
            granteeChannel:
              description: Grantee (e.g., merchant MyOS timeline).
              type:
                blueId: 9gQuMoLckgwgvAfx1X8tzdHwMNfRcraG96PfT5TDbXeh
            granterChannel:
              description: Granter (customer represented by the bank; customer has no MyOS account).
              type:
                blueId: 9gQuMoLckgwgvAfx1X8tzdHwMNfRcraG96PfT5TDbXeh
            guarantorChannel:
              description: Bank/admin channel.
              type:
                blueId: 9gQuMoLckgwgvAfx1X8tzdHwMNfRcraG96PfT5TDbXeh
            initLifecycleChannel:
              type:
                blueId: H2aCCTUcLMTJozWkn7HPUjyFBFxamraw1q8DyWk87zxr
              event:
                type:
                  blueId: BrpmpNt5JkapeUvPqYcxgXZrHNZX3R757dRwuXXdfNM2
            initialize:
              type:
                blueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: initLifecycleChannel
              steps:
                items:
                  - name: Initialize
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    do:
                      items:
                        - $appendChange:
                            op:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: replace
                            path:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: /consentStatus
                            val:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: granted
                        - $return:
                            changeset:
                              $changeset:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
                            events:
                              $events:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
            revokeConsent:
              description: Customer revokes the consent.
              type:
                blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: granterChannel
              request:
                reason:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                revokedAt:
                  type:
                    blueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
            revokeConsentImpl:
              type:
                blueId: B5mVH4caQv9Hmzeb5ZmCtzYomooFzTdoCQ4mZVwHY3MS
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: revokeConsent
              steps:
                items:
                  - name: Capture
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    do:
                      items:
                        - $let:
                            order:
                              items:
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: request
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: reason
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: revokedAt
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: canRevoke
                            vars:
                              request:
                                $event:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: /message/request
                              reason:
                                $default:
                                  items:
                                    - $event:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: /message/request/reason
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: ''
                              revokedAt:
                                $default:
                                  items:
                                    - $event:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: /message/request/revokedAt
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: ''
                              canRevoke:
                                $eq:
                                  items:
                                    - $document:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: /consentStatus
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: granted
                        - $if:
                            cond:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: canRevoke
                            then:
                              items:
                                - $appendEvent:
                                    type:
                                      blueId: FGgYcn3phzJUoBfDJzV1QxeGKGbaH7zUEj1trRbBpmmJ
                                    reason:
                                      $var:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: reason
                                    revokedAt:
                                      $var:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: revokedAt
                        - $appendChange:
                            op:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: replace
                            path:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: /consentStatus
                            val:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: revoked
                        - $appendChange:
                            op:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: replace
                            path:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: /revocationReason
                            val:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: reason
                        - $appendChange:
                            op:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: replace
                            path:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: /revokedAt
                            val:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: revokedAt
                        - $return:
                            changeset:
                              $changeset:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
                            events:
                              $events:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
