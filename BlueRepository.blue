            typeBlueId: CyvEqKQpGL1tCK33KuVNmoqqfPY41YR2zXaxhgsjDER2
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/asset/NonCashDividendTreatmentEnum
          description: The enumerated values to specify the treatment of Non-Cash Dividends.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
