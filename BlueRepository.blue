            typeBlueId: 5GwsMwbaX4fp4AD7NMb1rr8z8WDVafnPXTBwsagyzx2
            attributesAdded: []
      - status: stable
        content:
          name: cdm/observable/asset/QuoteBasisEnum
          description: The enumerated values to specify how an exchange rate is quoted.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
