          - repositoryVersionIndex: 0
            typeBlueId: 6QXysvk5wKooQQckLijtFXwzL8JzYBViFzRCkYPNJnSX
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/Loan
          description: Identifies a loan by referencing an asset identifier and through an optional set of attributes.
          borrower:
            description: |
              Specifies the borrower. There can be more than one borrower. It is meant to be used in the event that there is no Bloomberg Id or the Secured List isn't applicable.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 6NmyTe5CqfuusJQg46VWDV5a5FXqiZnkQmXduwAjC73o
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          creditAgreementDate:
            description: |
              Specifies the credit agreement date is the closing date (the date where the agreement has been signed) for the loans in the credit agreement. Funding of the facilities occurs on (or sometimes a little after) the Credit Agreement date. This underlier attribute is used to help identify which of the company's outstanding loans are being referenced by knowing to which credit agreement it belongs. ISDA Standards Terms Supplement term: Date of Original Credit Agreement.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          exchange:
            description: If the Asset is listed, defines the public exchange of the listing.
            type:
              blueId: 6NmyTe5CqfuusJQg46VWDV5a5FXqiZnkQmXduwAjC73o
          facilityType:
            description: Specifies the type of loan facility (letter of credit, revolving, ...).
            type:
              blueId: F5GfdsSNcjLAm9anbfMQqxdxAFonErhU5UXFbQzq1zXY
          identifier:
            description: Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: EFYo6JAQMRJEAg6yzzafESRVFXGTiNSjmy9ehctCH3Y4
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 1
          instrumentType:
            description: Identifies the type of an instrument using an enumerated list.
            type:
              blueId: 62KT7CCANTnUvju5nRQRPnwuRqsRPapXwdQJjLqhyo8C
          isExchangeListed:
            description: Defines whether the Asset is listed on a public exchange.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
          lien:
            description: Specifies the seniority level of the lien.
            type:
              blueId: F5GfdsSNcjLAm9anbfMQqxdxAFonErhU5UXFbQzq1zXY
          relatedExchange:
            description: Provides the related Exchanges, if applicable.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 6NmyTe5CqfuusJQg46VWDV5a5FXqiZnkQmXduwAjC73o
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          taxonomy:
            description: |
              Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 9iqdbfahQtNXNenCSE8hAFbq298MVvdACauLx1FZWRQt
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          tranche:
            description: |
              Denotes the loan tranche that is subject to the derivative transaction. It will typically be referenced as the Bloomberg tranche number. ISDA Standards Terms Supplement term: Bloomberg Tranche Number.
            type:
              blueId: F5GfdsSNcjLAm9anbfMQqxdxAFonErhU5UXFbQzq1zXY
