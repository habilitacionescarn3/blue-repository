            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          initialRate:
            description: The rate to be applied for the initial period.
            type:
              blueId: wuC3RHpv6ahucWwxTgdeQyeUP8ecWQQqgMvSpx3Z543
          multiplier:
            description: floating rate multiplier.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
          negativeTreatment:
