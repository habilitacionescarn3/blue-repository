              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 35r3StzAH6Qus8FCSpiCqqUrKHx9d4SYBCL2gEecgCJq
            schema:
              minItems: 0
