                                                          value: issues
                                                      - items:
                                                          - type:
                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                            value: permissions.allOps=true and permissions.singleOps are mutually exclusive
