          type:
            blueId: AQqdPmtKmB5VNH4rEbeKcRxsVStTTbJhS4fVF8wiTZrk
          subscriptionId:
            description: The subscription id that was revoked.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          targetSessionId:
            description: Session that is no longer being forwarded.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          reason:
            description: Optional explanation for the revocation.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6ewyxdBpb5oNdVSBkXZSDK6aUaAnzc2ad453V7vjXHu6
            attributesAdded: []
      - status: stable
        content:
          name: Subscription Update
          description: Update to a subscription.
          type:
            blueId: ENRQ621TbJpLg2cGyYkgTmPRLGKZkPqCzkBgm4yEXKF5
          subscriptionId:
            description: The ID of the subscription.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
