            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          product:
            description: product to be changed
            type:
              blueId: DQtAbxe1tLy9aRaawabAsHzDGXiQUiSvjt76ym1myncb#2
        versions:
