      - status: stable
        content:
          name: ExecutionTypeEnum
          description: The enumerated values to specify how a contract has been executed, e.g. electronically, verbally, ...
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
