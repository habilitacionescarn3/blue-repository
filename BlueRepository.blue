            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: AkUKoKY1hHY1CytCrAXDPKCd4md1QGmn1WNcQtWBsyAD
            attributesAdded: []
      - status: stable
        content:
          name: Composite Timeline Channel
          description: |
            Conversation package type.
            Channel that matches if an incoming event would match **any** of the named
            child channels in this scope (union). Useful to observe multiple timeline
            inputs through a single handler binding.
          type:
            blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
          channels:
            description: |
              List of contracts-map keys (Text) of channels in the same scope to compose (union). Each entry must name an existing Channel contract.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HsNatiPt2YvmkWQoqtfrFCbdp75ZUBLBUkWeq84WTfnr
            attributesAdded: []
      - status: dev
        content:
          name: Compute
          description: |
            Conversation workflow step that evaluates Blue Expression Objects (BEX) and returns a result.
            Compute reads the current processing context and computes data. It does not mutate the document directly. If the result contains a changeset, that changeset is still only data; a separate Conversation/Update Document step must apply it.
          type:
            blueId: HYsLiqsqk7t98d5fK6YxKEQGeqBaHNVjM4rRNdxK4yUW
          expr:
            description: |
              Optional BEX expression. If present and no `do` body is used, the step result is the evaluated expression.
          do:
            description: |
              Ordered list of BEX statements. Items are intentionally not strongly typed in this repository version.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
          definition:
            description: |
              Optional reference to reusable compute logic. In a Conversation workflow, this is commonly a contract key in the current scope pointing to a Conversation/Compute Definition.
          entry:
            description: |
              Entry function name to execute when `definition` or local `functions` are used.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          constants:
            description: |
              Named constants available to BEX through `$const`. Keys are constant names; values are arbitrary Blue values.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          functions:
            description: |
              Named reusable BEX functions. Keys are function names; values are function definitions. Function objects are intentionally not strongly typed in this repository version.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          emitEvents:
            description: |
              If true, and the computed result contains an `events` list, the Conversation workflow processor emits those events.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            value: true
          returnResult:
            description: |
              If true, the computed result is stored under the workflow step name and can be referenced by later steps.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            value: true
          gasLimit:
            description: |
              Optional maximum gas allowed for this Compute step. If omitted, the host processor chooses the applicable default.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
        versions:
          - repositoryVersionIndex: 4
            typeBlueId: 43pL2gQm5LahhsD7wGhTRxdH8DyfSEvpe2xx2rW2PHJS
            attributesAdded: []
      - status: dev
        content:
          name: Compute Definition
          description: |
            Reusable compute logic for Conversation/Compute steps.
            A Compute Definition may contain named constants and named functions. A Conversation/Compute step can reference the definition and select an entry function.
            This type intentionally does not strongly type BEX functions or operators. BEX syntax and execution semantics are defined by the Compute processor and BEX specification, not by repo.blue field-level schemas in this version.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          constants:
            description: |
              Named constants available through `$const`. Keys are constant names; values are arbitrary Blue values.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          functions:
            description: |
              Named reusable BEX functions. Keys are function names; values are function definitions.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
        versions:
          - repositoryVersionIndex: 4
            typeBlueId: 4fwPW7iJA5p7MuRhc3xpn43EsU3TkruGRpujcuwDGbw3
            attributesAdded: []
      - status: dev
        content:
          name: Contracts Change Policy
          description: |
