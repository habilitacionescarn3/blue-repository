            typeBlueId: 8MRxZTVfrVixhr1Mwqwq3sawr5v2Lab2sbAQFnsvZk6J
            attributesAdded: []
      - status: stable
        content:
          name: CounterpartyPositionBusinessEvent
          description: |
            A business event represents a life cycle event of a position. The combination of the state changes results in a qualifiable life cycle event.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/event/common
          after:
            description: Specifies the after position state(s) created.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: D7s7KyjUZgzoVri92g5VTAqQ7s9x2n41ujN4aN59vHpb
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          corporateActionIntent:
            description: The intent of a corporate action on the position.
            type:
              blueId: E4LBcLZqVXWj7bfcxZpT3WRYbSWLcVN5e56D4djByoZ3
          effectiveDate:
            description: The date on which the event contractually takes effect, when different from the event date.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          eventDate:
            description: |
              Specifies the date on which the event is taking place. This date is equal to the trade date in the case of a simple execution.  However it can be different from the trade date, for example in the case of a partial termination.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          intent:
            description: |
              The intent attribute is meant to be specified when the event qualification cannot be programmatically inferred from the event features. As a result it is only associated with those primitives that can give way to such ambiguity, the quantityChange being one of those.
            type:
              blueId: 9vURffQq9RSL6e1qGWqoqbSKX2FaW3fp4RxdMBEQJFZa
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          packageInformation:
            description: |
              Specifies the package information in case the business event represents several trades executed as a package (hence this attribute is optional). The package information is only instantiated once at the business event level to preserve referential integrity, whereas individual trades make reference to it to identify that they are part of a package.
            type:
              blueId: 9bGwcG1xp4CdRxR7ZwqoM3pw7x6ggB82bamx2KZx9B7s
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: CdMt3bHFCBhALwySEeBWATWmg2u51UjZH7cegiUh64vF
            attributesAdded: []
      - status: stable
        content:
          name: CounterpartyPositionState
          description: |
            Defines the fundamental financial information that can be changed by a Primitive Event and by extension any business or life-cycle event. Each PositionState specifies where a Position is in its life-cycle. PositionState is a root type and as such, can be created independently to any other CDM data type, but can also be used as part of the CDM Event Model.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/event/common
          counterpartyPosition:
            description: Represents the Position that has been effected by a business or life-cycle event.
            type:
              blueId: 8MRxZTVfrVixhr1Mwqwq3sawr5v2Lab2sbAQFnsvZk6J
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          observationHistory:
            description: |
              Represents the observed events related to a particular product or process, such as credit events or corporate actions.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: Dj95hckKTPjczykJqqyL67VzzgAG64yh23kMmQN7TAJy
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          state:
            description: Represents the State of the Position through its life-cycle.
            type:
              blueId: AcCvDKaqCnPYRpGz4HNC3J6LqrsDqX49v9u4gfHSdiFi
          valuationHistory:
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 67Ud3jXeu1WjJh3uXk333v2o9jPN8SRqNpRGHYZi7NLW
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: D7s7KyjUZgzoVri92g5VTAqQ7s9x2n41ujN4aN59vHpb
            attributesAdded: []
      - status: stable
        content:
          name: CounterpartyRoleEnum
          description: Defines the enumerated values to specify the two counterparties to the transaction.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
