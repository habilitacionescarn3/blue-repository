      - status: stable
        content:
          name: cdm/base/staticdata/identifier/FieldWithMetaIdentifier
          meta:
            type:
              blueId: DzqRwbzhBeAEsqWnJKowFX2zDp5bnxRrGuECR18ePGLk
          val:
            type:
              blueId: 8eDineGwQr2VXBeVEPbnJZvEcNhDbLu8HtmubDT6RBoZ
