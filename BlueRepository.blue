        versions:
          - repositoryVersionIndex: 3
            typeBlueId: D8Wak5pTkqdudSiKCqGLXoNMNzisKDD95ojKjoZuoGzL
            attributesAdded: []
      - status: stable
        content:
          name: PriceOperandEnum
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/observable/asset
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: AccruedInterest
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
