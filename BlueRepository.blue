      - status: stable
        content:
          name: EvergreenProvision
          description: |
            Specifies a transaction which automatically extends for a specified timeframe until the exercise of an embedded option.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/product/template
          extensionFrequency:
            description: The frequency with which the evergreen contract will be extended if notice is not given.
            type:
              blueId: 6NoYrXzLpXe7TDKgr7Xrnjuut4E5CwQJwWm5DHNDKxwB
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          finalPeriodFeeAdjustment:
            description: |
              An optional adjustment to the rate for the last period of the evergreen i.e. the period from when notice is given to stop rolling the contract through to the termination date.
            type:
              blueId: 34JSSaiNLZkZGJCPhZGY4wsFrAd7HeP7M2MEwHXHZp2u
          noticeDeadlineDateTime:
            description: A specific date and time for the notice deadline
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          noticeDeadlinePeriod:
            description: |
              Defines the minimum period before an evergreen is scheduled to terminate that notice can be given that it will terminate beyond the scheduled termination date.
            type:
              blueId: k9HgXaUDtMTpLPttfBXXf8LCfPgNGBwYyAkMswVBvas
          noticePeriod:
            description: The length of each evergreen extension period relative to the effective date of the preceding contract.
            type:
              blueId: k9HgXaUDtMTpLPttfBXXf8LCfPgNGBwYyAkMswVBvas
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          singlePartyOption:
            description: |
              If evergreen termination is not available to both parties then this component specifies the buyer and seller of the option.
            type:
              blueId: HjRiCP4U2kbina9KzZmsLbxfxuEKtL8de46X5Pvi5j4Q
