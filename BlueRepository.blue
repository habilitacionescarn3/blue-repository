            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 45HfgL64TRdHGgokLmTPwnhDVyVxw776BCEtmU9wpwVs
            schema:
