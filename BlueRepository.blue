      - status: stable
        content:
          name: ExecutionInstruction
          description: |
            Specifies instructions for execution of a transaction, consisting of a product, price, quantity, parties, trade identifier, execution details, and settlement terms.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/event/common
          ancillaryParty:
            description: |
              Maps any ancillary parties, e.g. parties involved in the transaction that are not one of the two principal parties.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: AVLZBE6vzpDFRWChzZg4qyuWyNhPEPveCf3GNnrZhuJb
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          collateral:
            description: Detail the collateral requirement anticipated with the transaction.
            type:
              blueId: EWq52hzth8quHstTkqnrwDn2cXXd1fDc9uSSvBJBSbWs
          counterparty:
            description: Maps two defined parties to counterparty enums for the transacted product.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: gfoywborZ3FfKnSaoNBtFq5TPCXFpfJKuQ2AD1nAs47
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 2
              maxItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 2
          executionDetails:
            description: Specifies the type and venue of execution, e.g. via voice, or electronically.
            type:
              blueId: FQTFct7VgtvDNqQWVUgLA6qStQf2vZgCDS2rivDj5sHd
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          lotIdentifier:
            description: Lot Identifier associated with the transaction.
            type:
              blueId: EdjJv5JTyG4VPv5esPYfbiA1VSWQfZA9erSSr785y3C1
          parties:
            description: Defines all parties to that execution, including agents and brokers.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: AVN4ESaeQMFu31gp5PDiR55P6nWzHRiWZR2pKxQS5d6W
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 2
          partyRoles:
            description: Defines the role(s) that party(ies) may have in relation to the execution.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: HjRiCP4U2kbina9KzZmsLbxfxuEKtL8de46X5Pvi5j4Q
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          priceQuantity:
            description: |
              Defines the prices (e.g. spread, equity price, FX rate), quantities (e.g. currency amount, no. shares) and settlement terms (e.g. initial fee, broker fee, up-front cds payment or option premium settlement) associated with the constituents of the transacted product.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: CBN4M5HDnGN1STrbkuST4PB9q5fycXW53pBBjWaBSXWZ
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 1
          product:
            description: Defines the financial product to be executed and contract formed.
            type:
              blueId: 5kXk9Uzw8zdnt3rnmXD4h4i6DVxmrWtL7ZKyDsPx9nMf#2
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          tradeDate:
            description: Denotes the trade/execution date.
            type:
              blueId: DkAAYuMhrcUQRrFdCEPKwcQDCnee3rxTu6vYVSURpWWY
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          tradeIdentifier:
            description: Denotes one or more identifiers associated with the transaction.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 3fYPqEAGPKp55ZezkKTAANdA5nVAo24xz1aUh9UChDqw
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 1
          tradeTime:
            description: Denotes the trade time and timezone as agreed by the parties to the trade.
            type:
              blueId: HVq6QEShaXeAnmgRyBUsn3Gyp6Vhp6pgdgscJVT2jtiR
