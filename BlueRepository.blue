      - status: stable
        content:
          name: cdm/observable/asset/CreditIndex
          description: |
            Specification of an index based on credit risk, typically composed using corporate debt instruments in a region or industry sector, e.g. the iTraxx indices.
          assetClass:
            description: The Asset Class of the Index.
            type:
              blueId: 7TQnexn6ZGhptp1EP3RxiJM3434J7VHgDn7cvqXRvfvh
          exchange:
            description: If the Asset is listed, defines the public exchange of the listing.
            type:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
          excludedReferenceEntity:
            description: Excluded reference entity.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 3eDfhc11LMfKiQsRKqD5mkN3csaNKJ4Yay8qPTE3sM5f
            schema:
              minItems: 0
          identifier:
            description: Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: B4oXDUH9jELDatvZSw3oWXtJefJ4ixYawEjxBMqSerth
            schema:
              minItems: 1
          indexAnnexDate:
            description: A CDS index series annex date.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          indexAnnexSource:
            description: A CDS index series annex source.
            type:
              blueId: Ertdu3BkSJQ4wFYEPS4YyzEkSnGfu7XaooXCfRXXXENY
          indexAnnexVersion:
            description: A CDS index series version identifier, e.g. 1, 2, 3 etc.
            type:
              blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
          indexFactor:
            description: |
              Index Factor is the index version factor or percent, expressed as an absolute decimal value between 0 and 1, that multiplied by the original notional amount yields the notional amount covered by the seller of protection.
            type:
              blueId: 9eWaHYz2vKrFofdHTHAizNNu8xP6QE3WQ5y7DGrGZvyJ
          indexSeries:
            description: A CDS index series identifier, e.g. 1, 2, 3 etc.
            type:
              blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
          isExchangeListed:
            description: Defines whether the Asset is listed on a public exchange.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
          provider:
            description: The organisation that creates or maintains the Index.
            type:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
          relatedExchange:
            description: Provides the related Exchanges, if applicable.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
            schema:
              minItems: 0
          seniority:
            description: Seniority of debt instruments comprising the index.
            type:
              blueId: Hu5VnYpz7ZCRzsMjDtVxSVoN2RK42N3T3a1rvcvnMAyV
          settledEntityMatrix:
            description: Used to specify the Relevant Settled Entity Matrix when there are settled entities at the time of the trade.
            type:
              blueId: 4A1qUaufcqcuzgYMrhKzobEdbwF774fdj4o1nwgmxUdJ
          taxonomy:
            description: |
              Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 9MYk7MRYjbMWPHe7v3WexZqePowTL8eRrW8TmNNEtzQJ
            schema:
              minItems: 0
          tranche:
            description: This element contains CDS tranche terms.
            type:
              blueId: AhnjPV8YNPhbAjozktmjeX2wDwUvX9j1SLMv3rUYCvk3
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EXhnZXqvEcgXZrY2VK9WqgZz87y5NwxZ4axscyrAeSBv
            attributesAdded: []
      - status: stable
        content:
          name: cdm/observable/asset/CreditNotation
          description: |
            Represents a class to specify the credit notation as the combination of agency, notation, scale and debt type qualifications.
          agency:
            description: Specifies The credit agency to which the other variables (notation, scale, debt type) refer to.
            type:
              blueId: D1H3C3xAMJv2XQNBYfethSUKDH7kngUkefwbzLwVLW1i
            schema:
              required: true
          creditWatch:
            description: |
              Indicates the potential direction of a short-term or long-term rating. It focuses on identifiable events and short-term trends that cause ratings to be placed under special surveillance.
            type:
              blueId: HaWzE4gbbhGKXJnQA29vkDyfHSkhDsje8H82PYwV2Phr
          debt:
            description: |
              Specifies the credit rating debt type (e.g. long term, high yield, deposits, ...) associated with the credit rating notation and scale.
            type:
              blueId: H8A5EpXYgdKnD1FhyTni2vHEnBp15QF3Y1Hk9y72CfzJ
          notation:
            description: |
              Specifies The credit rating notation. As it varies among credit rating agencies, FpML doesn't specify a default scheme.
            type:
              blueId: HTDqFgte5VF88dLHnCZMjvyetfxfTAKxf9r8ciErE7Vg
            schema:
              required: true
          outlook:
            description: |
              Assesses the potential direction of a long-term credit rating over the intermediate term, which is generally up to two years for investment grade and generally up to one year for speculative grade.
            type:
              blueId: 8STyBvSNBUVRcziJ5ApHvpPRYRvyJTGTsrM6RAFpGJE
          scale:
            description: |
              Specifies the credit rating scale, with a typical distinction between short term, long term. FpML doesn't specify a default scheme, which is hence not specified as an enumeration as part of the CDM.
            type:
              blueId: HTDqFgte5VF88dLHnCZMjvyetfxfTAKxf9r8ciErE7Vg
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EQxsMYMc9VvECVVKm2ZJuGuMzgL8yDytdszpjwY14Yy1
            attributesAdded: []
