name: Blue Repository
packages:
  - name: Common
    types:
      - status: dev
        content:
          name: Currency
          description: ISO 4217 currency code (e.g., USD, EUR).
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: CBnZ7aaNetj9KEqXpUWj5jvjKbmviLivP98T2EiyxiYc
            attributesAdded: []
      - status: dev
        content:
          name: Document
          description: |
            Broad base type for semantic documents that describe what they are directly.
            Use the top-level `kind` field for business-level meaning on top of the
            concrete document family type.
          kind:
            description: Human-readable business meaning for this document.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
            attributesAdded: []
      - status: dev
        content:
          name: Document Anchor
          description: |
            One named connection point where matching documents can link in.
            Anchor entries are typically used inline inside `Common/Document Anchors`
            and can describe the expected matching document shape through `template`.
          template:
            description: |
              Optional Blue document-shaped template describing what matches this anchor.
              It may be a minimal `{ type, kind }` hint or a richer nested document shape.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Bu4KzxxpJuHvET1RTBzioDXpWcqmvYzmqGRiDKmktHUo
            attributesAdded: []
      - status: dev
        content:
          name: Document Anchors
          description: |
            Dictionary-like container of named document anchors.
            The container is typed, while named entries can stay inline and do not need
            to repeat `type: Common/Document Anchor` in public document shape.
          type:
            blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
          keyType:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          valueType:
            blueId: Bu4KzxxpJuHvET1RTBzioDXpWcqmvYzmqGRiDKmktHUo
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3KRfhgbFdvyW9SGuKiq3WxWF9bHSATEb8tMso8Pykpre
            attributesAdded: []
      - status: dev
        content:
          name: Named Event
          description: |
            Lightweight conversation event identified by the instance `name` field.
            Use it to emit, forward, or match a well-known signal
            without introducing a dedicated repository event type.
          type:
            blueId: 5Wz4G9qcnBJnntYRkz4dgLK5bSuoMpYJZj4j5M59z4we
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GrD4wCAmKoK8rm8Pztmv9GkFBRwJy4zpDUzDWHtsEJCX
            attributesAdded: []
      - status: dev
        content:
          name: Payment
          description: |
            Broad document family for a value-moving or value-committing document.
            Use the top-level `kind` to describe the payment intent,
            such as `Invoice Settlement`, `Payout`, or `Milestone Payment`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DoDF7Hm2Ss7ikirPwXZ7KFiWNmdwtb53vHCSwYFbCdPk
            attributesAdded: []
      - status: dev
        content:
          name: PermissionGrant
          description: |
            Broad document family for documents whose main purpose is granting or revoking authority.
            Use the top-level `kind` to describe the business permission shape,
            such as `Single Document Permission Grant` or `Linked Documents Permission Grant`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EHTR6jFrqbmjPf7dNSJUsGUJrgr5kLh62QiT2bxD6KRp
            attributesAdded: []
      - status: dev
        content:
          name: Profile
          description: |
            Broad document family for a public-facing identity or presence.
            Use the top-level `kind` to describe the specific profile,
            such as `Business Profile`, `Creator Profile`, or `Directory Listing`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EWfk8qkKZYqqTyeLs4wLJTfPCLufZBiNGFQY4M4PLv99
            attributesAdded: []
      - status: dev
        content:
          name: Record
          description: |
            Broad document family for a single item that belongs somewhere.
            Use the top-level `kind` to express the specific business meaning, such as
            `Shopping Order`, `Comment`, `Invoice`, or `Report`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: J18rFf6VX3ADe5gTnqmL4wXtivLkzrRXLPPhnoghnjzB
            attributesAdded: []
      - status: dev
        content:
          name: Relationship
          description: |
            Broad document family for a shared document between parties.
            Use the top-level `kind` to describe the specific relationship shape,
            such as `Service Agreement`, `Partnership Proposal`, or `Legal Engagement`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 29BmTvgmhh9x7t2tGd38GqTH3b9v9rgqsuE21K73i86g
            attributesAdded: []
      - status: dev
        content:
          name: Request
          description: |
            Broad document family for a request for something from a provider or participant.
            Use the top-level `kind` to describe the specific request,
            such as `Legal Review Request`, `Service Request`, or `Intake Request`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Ccj91K18JfH77i8bawJzR9GpRWXYf598uPjggxZU7Shd
            attributesAdded: []
      - status: dev
        content:
          name: Response
          description: |
            Broad document family for a response to a request.
            Use the top-level `kind` to describe the specific response,
            such as `Legal Review Response`, `Report Delivery`, or `Intake Response`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: cLkohDeea8vefzVvUwsQ56BwUfedXpqeoD66PvRe7LB
            attributesAdded: []
      - status: dev
        content:
          name: Service
          description: |
            Broad document family for a document that is itself a service offering.
            Use the top-level `kind` to describe the specific offering,
            such as `Legal Service`, `Tutoring Service`, or `Analytics Service`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
          categories:
            description: Optional broad categories used to help humans discover the service.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: ALFnjBeqP1hupQrZGddqbi276GkwnuPtkQjiFLjU716A
            attributesAdded: []
      - status: dev
        content:
          name: Space
          description: |
            Broad document family for a long-lived place in some reality.
            Use it directly as the document `type` and express business meaning through
            the top-level `kind`, such as `Online Shop`, `Legal Office`, or `Research Lab`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
          website:
            description: Optional primary website or canonical public URL for this space.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          anchors:
            description: Optional named connection points where matching documents can link in.
            type:
              blueId: 3KRfhgbFdvyW9SGuKiq3WxWF9bHSATEb8tMso8Pykpre
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Bdyasci5huobiunZqkShQUiWzCyHLhY4fpMkG4YF5BiS
            attributesAdded: []
      - status: dev
        content:
          name: Task
          description: |
            Broad document family for a bounded unit of work over time.
            Use the top-level `kind` to describe the business task,
            such as `Weekly Report`, `Inbox Monitoring`, or `Order Triage`.
          type:
            blueId: Co5guWscbTav1tmXvQPb4k3wtrsQEdxjDaj6WPPWpPo8
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FfJjBeSAe4JWfA5FVnPDgL9pzLPYELskQnBSanPC9E8L
            attributesAdded: []
      - status: dev
        content:
          name: Timestamp
          description: ISO 8601 timestamp with timezone offset (for example, 2025-01-10T09:30:00Z, 2025-01-10T10:30:00+01:00, or 2025-01-10T09:30:00.123456Z).
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GQaGqFxHDz64L1c9QkCbz52ths6bMVtpHnw4QDngzQYs
            attributesAdded: []
  - name: Conversation
    types:
      - status: dev
        content:
          name: Accept Change Operation
          description: Operation to accept a previously proposed change.
          type:
            blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: APk3siB8g9pvWLG3qyqtGjRNNGB7RDpFWQtG4epj5Avv
            attributesAdded: []
      - status: dev
        content:
          name: Accept Change Workflow
          description: Applies a previously proposed change and removes its proposal state.
          type:
            blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
          postfix:
            description: Optional postfix used while building proposed change state key.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          steps:
            items:
              - name: Prepare
                type:
                  blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                code:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: |
                    const invalid = (reason) => ({
                      changeset: [],
                      events: [{ type: 'Conversation/Proposed Change Invalid', reason }]
                    });

                    const isArray = Array.isArray;

                    const postfixNode = canon.at(currentContractCanonical, '/postfix');
                    const postfixValue =
                      typeof postfixNode?.value === 'string' ? postfixNode.value : '';
                    const proposedPath = '/proposedChange' + postfixValue;

                    const change = document(proposedPath);
                    if (!change) {
                      return invalid('no proposed change at ' + proposedPath);
                    }

                    const requestChangeset = isArray(change?.changeset) ? change.changeset : [];
                    const sectionChanges = change.sectionChanges;

                    const entryPath = (entry) => `${entry?.path || ''}`;
                    const isContractsPath = (p) => p === '/contracts' || p.startsWith('/contracts/');
                    const isProposedChangePath = (p) => p.startsWith('/proposedChange');

                    const contracts = document('/contracts') || {};
                    const policy = Object.values(contracts).find((c) => c?.requireSectionChanges !== undefined);
                    const policyEnabled = !!policy && policy.requireSectionChanges !== false;

                    if (
                      policyEnabled &&
                      requestChangeset.some((e) => isContractsPath(entryPath(e)))
                    ) {
                      return invalid('changeset cannot modify /contracts when Contracts Change Policy is enabled');
                    }

                    if (requestChangeset.some((e) => isProposedChangePath(entryPath(e)))) {
                      return invalid('changeset cannot modify /proposedChange');
                    }

                    const escapePointer = (value) =>
                      `${value}`.split('~').join('~0').split('/').join('~1');

                    const contractPtr = (key) => '/contracts/' + escapePointer(key);

                    const isMetaKey = (key) =>
                      key === 'type' || key === 'keyType' || key === 'valueType' || key === 'description';

                    const contractKeysFromMap = (contractsMap) =>
                      Object.keys(contractsMap || {}).filter((k) => !isMetaKey(k));

                    const normalizeSection = (section, contractKeys) => ({
                      ...(section || {}),
                      type: 'Conversation/Document Section',
                      relatedContracts: (section?.relatedContracts?.length ? section.relatedContracts : contractKeys)
                    });

                    const hasMatchingRelatedContracts = (section, contractKeys) => {
                      const related = isArray(section?.relatedContracts)
                        ? section.relatedContracts.map((value) => `${value}`)
                        : [];
                      if (!related.length) {
                        return true;
                      }
                      if (related.length !== contractKeys.length) {
                        return false;
                      }
                      const relatedMap = {};
                      for (const value of related) {
                        const key = `${value}`;
                        relatedMap[key] = (relatedMap[key] || 0) + 1;
                      }
                      if (Object.keys(relatedMap).length !== contractKeys.length) {
                        return false;
                      }
                      for (const key of contractKeys) {
                        if (!relatedMap[key]) {
                          return false;
                        }
                      }
                      return true;
                    };

                    const sectionChangeset = [];
                    const seenSectionKeys = {};
                    const seenContractKeys = {};
                    const existingContractKeys = {};
                    for (const key of Object.keys(contracts || {}).filter((k) => !isMetaKey(k))) {
                      existingContractKeys[key] = true;
                    }

                    const trackSectionKey = (sectionKey) => {
                      if (seenSectionKeys[sectionKey]) {
                        return invalid(`section key duplicated in sectionChanges: ${sectionKey}`);
                      }
                      seenSectionKeys[sectionKey] = true;
                      return null;
                    };

                    const trackContractKey = (sectionKey, contractKey) => {
                      const existingSection = seenContractKeys[contractKey];
                      if (existingSection && existingSection !== sectionKey) {
                        return invalid(`contract key used by multiple sections in request: ${contractKey}`);
                      }
                      seenContractKeys[contractKey] = sectionKey;
                      return null;
                    };

                    const addList = isArray(sectionChanges?.add) ? sectionChanges.add : [];
                    for (const entry of addList) {
                      const sectionKey = `${entry?.sectionKey || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.add is missing sectionKey');

                      const sectionKeyDup = trackSectionKey(sectionKey);
                      if (sectionKeyDup) return sectionKeyDup;

                      if (existingContractKeys[sectionKey]) {
                        return invalid(`contract key already exists at ${contractPtr(sectionKey)}`);
                      }

                      const contractsMap = entry?.contracts || {};
                      const contractKeys = contractKeysFromMap(contractsMap).map((key) => `${key}`);

                      if (!hasMatchingRelatedContracts(entry?.section, contractKeys)) {
                        return invalid('relatedContracts must match contracts');
                      }

                      for (const key of contractKeys) {
                        if (existingContractKeys[key]) {
                          return invalid(`contract key already exists at ${contractPtr(key)}`);
                        }
                        const dup = trackContractKey(sectionKey, key);
                        if (dup) return dup;
                      }

                      for (const key of contractKeys) {
                        sectionChangeset.push({ op: 'add', path: contractPtr(key), val: contractsMap[key] });
                      }

                      sectionChangeset.push({
                        op: 'add',
                        path: contractPtr(sectionKey),
                        val: normalizeSection(entry?.section, contractKeys)
                      });
                    }

                    const modifyList = isArray(sectionChanges?.modify) ? sectionChanges.modify : [];
                    for (const entry of modifyList) {
                      const sectionKey = `${entry?.sectionKey || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.modify is missing sectionKey');

                      const sectionKeyDup = trackSectionKey(sectionKey);
                      if (sectionKeyDup) return sectionKeyDup;

                      const existingRelated = isArray(contracts?.[sectionKey]?.relatedContracts)
                        ? contracts[sectionKey].relatedContracts.map((value) => `${value}`)
                        : [];
                      const existingRelatedMap = {};
                      for (const value of existingRelated) {
                        existingRelatedMap[`${value}`] = true;
                      }

                      const contractsMap = entry?.contracts || {};
                      const contractKeys = contractKeysFromMap(contractsMap).map((key) => `${key}`);

                      if (!hasMatchingRelatedContracts(entry?.section, contractKeys)) {
                        return invalid('relatedContracts must match contracts');
                      }

                      for (const key of contractKeys) {
                        const dup = trackContractKey(sectionKey, key);
                        if (dup) return dup;
                        if (existingContractKeys[key] && !existingRelatedMap[key]) {
                          return invalid(`contract key already exists at ${contractPtr(key)}`);
                        }
                      }

                      for (const key of contractKeys) {
                        sectionChangeset.push({ op: 'add', path: contractPtr(key), val: contractsMap[key] });
                      }

                      for (const oldKey of existingRelated) {
                        if (contractKeys.indexOf(oldKey) === -1) {
                          sectionChangeset.push({ op: 'remove', path: contractPtr(oldKey) });
                        }
                      }

                      sectionChangeset.push({
                        op: 'add',
                        path: contractPtr(sectionKey),
                        val: normalizeSection(entry?.section, contractKeys)
                      });
                    }

                    const removeList = isArray(sectionChanges?.remove) ? sectionChanges.remove : [];
                    for (const entry of removeList) {
                      const sectionKey = `${entry?.sectionKey || entry || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.remove is missing sectionKey');

                      const related = isArray(contracts?.[sectionKey]?.relatedContracts)
                        ? contracts[sectionKey].relatedContracts
                        : [];

                      for (const key of related) {
                        sectionChangeset.push({ op: 'remove', path: contractPtr(key) });
                      }
                      sectionChangeset.push({ op: 'remove', path: contractPtr(sectionKey) });
                    }

                    const combined = sectionChangeset.concat(requestChangeset);

                    if (combined.length === 0) {
                      return invalid('no changes provided');
                    }

                    return {
                      changeset: combined.concat({ op: 'remove', path: proposedPath })
                    };
              - name: Apply
                type:
                  blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                changeset:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: ${steps.Prepare.changeset}
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: BAYbnfs8WkdH33UwCvmsuoAq6MyU6ha4KSTZPaeMp9kN
            attributesAdded: []
      - status: stable
        content:
          name: Actor
          description: |
            Conversation type for attributing timeline entries to a person, service, or system. Intended solely for display/attribution; carries no runtime behavior.
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: CN5efWVizJbRsMCw8YWRfT2q9vM9XfeGDN9wFvYcvMnQ
            attributesAdded: []
      - status: dev
        content:
          name: Actor Policy
          description: Policy marker describing allowed actor and source categories for operations.
          type:
            blueId: 7QACj919YMRvFCTELCf6jfQTp41RVhtHdE6bPazLUZQ6
          operations:
            description: Per-operation actor/source constraints keyed by operation name.
            type:
              blueId: G7fBT9PSod1RfHLHkpafAGBDVAJMrMhAMY51ERcyXNrj
            keyType:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            valueType:
              requiresActor:
                description: Required actor category ("principal" | "agent" | "any").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              requiresSource:
                description: Required source category ("browserSession" | "apiCall" | "documentRequest").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
              excludeSource:
                description: Disallowed source category ("browserSession" | "apiCall" | "documentRequest").
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EeWqP1Tw9WXo5nq8kx93FuTw9HRqpv34mbWFjH72nR7o
            attributesAdded: []
      - status: dev
        content:
          name: Agent Actor
          description: Base actor type for a non-human actor exercising delegated authority.
          type:
            blueId: CN5efWVizJbRsMCw8YWRfT2q9vM9XfeGDN9wFvYcvMnQ
          onBehalfOf:
            description: Actor whose authority this agent is using.
            type:
              blueId: CN5efWVizJbRsMCw8YWRfT2q9vM9XfeGDN9wFvYcvMnQ
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FM1K89eMHRDN6vHtHfGwFNojmgvSnACuYdtc3qQ6qPYB
            attributesAdded: []
      - status: dev
        content:
          name: API Call
          description: Source describing a programmatic API request.
          type:
            blueId: 6ADCPYXkusrp4dL1FC126L2ccuzYfqGdBf1w6EXh2hnC
          apiKeyId:
            description: Identifier of the API credential used for the request.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HCTXeqkKBbVbsa3WfN2bPFSX7mthbtZ6ZhzByf9VDJJs
            attributesAdded: []
      - status: dev
        content:
          name: Browser Session
          description: Source describing an authenticated browser session.
          type:
            blueId: 6ADCPYXkusrp4dL1FC126L2ccuzYfqGdBf1w6EXh2hnC
          uiSessionNonce:
            description: Opaque nonce identifying the UI session.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 8UVUYbhSVBAx7BAupgjSeeFuuyrgdFcGbaXBitEZD9B1
            attributesAdded: []
      - status: dev
        content:
          name: Change Operation
          description: Operation that applies a changeset immediately without proposal/accept.
          type:
            blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
          request:
            type:
              blueId: FW7iYkzig4fepCdwfCdgNJw4DQ1fKwnAUf3YpjgfTPmG
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Hd5uuFjqxyw5mrFPgJf2mcatij8ddtmGAMJu9ij5K1tc
            attributesAdded: []
      - status: dev
        content:
          name: Change Request
          description: Payload for propose and direct change operations.
          summary:
            description: Human-readable summary of the requested change. Required when proposal is created.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          changeset:
            description: RFC 6902 patch entries outside /contracts (blocked by policy if it touches /contracts).
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: Bz49DbfqKC1yJeCfv5RYPZUKTfb7rtZnmreCaz4RsXn5
          sectionChanges:
            description: Section-based /contracts mutations (required when Contracts Change Policy is enabled).
            type:
              blueId: DEmFwGa1sWm2BKhrN98LREKiB8j8B8kFAo7KBkkaojnN
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FW7iYkzig4fepCdwfCdgNJw4DQ1fKwnAUf3YpjgfTPmG
            attributesAdded: []
      - status: dev
        content:
          name: Change Workflow
          description: Applies a requested changeset immediately to the document.
          type:
            blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
          request:
            description: Expected request payload for this workflow.
            type:
              blueId: FW7iYkzig4fepCdwfCdgNJw4DQ1fKwnAUf3YpjgfTPmG
          steps:
            items:
              - name: Prepare
                type:
                  blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                code:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: |
                    const invalid = (reason) => ({
                      changeset: [],
                      events: [{ type: 'Conversation/Proposed Change Invalid', reason }]
                    });

                    const isArray = Array.isArray;

                    const change = event.message.request;

                    const summary = change?.summary;
                    if (!summary || typeof summary !== 'string') {
                      return invalid('summary is missing');
                    }

                    const requestChangeset = isArray(change?.changeset) ? change.changeset : [];
                    const sectionChanges = change.sectionChanges;

                    const entryPath = (entry) => `${entry?.path || ''}`;
                    const isContractsPath = (p) => p === '/contracts' || p.startsWith('/contracts/');
                    const isProposedChangePath = (p) => p.startsWith('/proposedChange');

                    const contracts = document('/contracts') || {};
                    const policy = Object.values(contracts).find((c) => c?.requireSectionChanges !== undefined);
                    const policyEnabled = !!policy && policy.requireSectionChanges !== false;

                    if (
                      policyEnabled &&
                      requestChangeset.some((e) => isContractsPath(entryPath(e)))
                    ) {
                      return invalid('changeset cannot modify /contracts when Contracts Change Policy is enabled');
                    }

                    if (requestChangeset.some((e) => isProposedChangePath(entryPath(e)))) {
                      return invalid('changeset cannot modify /proposedChange');
                    }

                    const escapePointer = (value) =>
                      `${value}`.split('~').join('~0').split('/').join('~1');

                    const contractPtr = (key) => '/contracts/' + escapePointer(key);

                    const isMetaKey = (key) =>
                      key === 'type' || key === 'keyType' || key === 'valueType' || key === 'description';

                    const contractKeysFromMap = (contractsMap) =>
                      Object.keys(contractsMap || {}).filter((k) => !isMetaKey(k));

                    const normalizeSection = (section, contractKeys) => ({
                      ...(section || {}),
                      type: 'Conversation/Document Section',
                      relatedContracts: (section?.relatedContracts?.length ? section.relatedContracts : contractKeys)
                    });

                    const hasMatchingRelatedContracts = (section, contractKeys) => {
                      const related = isArray(section?.relatedContracts)
                        ? section.relatedContracts.map((value) => `${value}`)
                        : [];
                      if (!related.length) {
                        return true;
                      }
                      if (related.length !== contractKeys.length) {
                        return false;
                      }
                      const relatedMap = {};
                      for (const value of related) {
                        const key = `${value}`;
                        relatedMap[key] = (relatedMap[key] || 0) + 1;
                      }
                      if (Object.keys(relatedMap).length !== contractKeys.length) {
                        return false;
                      }
                      for (const key of contractKeys) {
                        if (!relatedMap[key]) {
                          return false;
                        }
                      }
                      return true;
                    };

                    const sectionChangeset = [];
                    const seenSectionKeys = {};
                    const seenContractKeys = {};
                    const existingContractKeys = {};
                    for (const key of Object.keys(contracts || {}).filter((k) => !isMetaKey(k))) {
                      existingContractKeys[key] = true;
                    }

                    const trackSectionKey = (sectionKey) => {
                      if (seenSectionKeys[sectionKey]) {
                        return invalid(`section key duplicated in sectionChanges: ${sectionKey}`);
                      }
                      seenSectionKeys[sectionKey] = true;
                      return null;
                    };

                    const trackContractKey = (sectionKey, contractKey) => {
                      const existingSection = seenContractKeys[contractKey];
                      if (existingSection && existingSection !== sectionKey) {
                        return invalid(`contract key used by multiple sections in request: ${contractKey}`);
                      }
                      seenContractKeys[contractKey] = sectionKey;
                      return null;
                    };

                    const addList = isArray(sectionChanges?.add) ? sectionChanges.add : [];
                    for (const entry of addList) {
                      const sectionKey = `${entry?.sectionKey || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.add is missing sectionKey');

                      const sectionKeyDup = trackSectionKey(sectionKey);
                      if (sectionKeyDup) return sectionKeyDup;

                      if (existingContractKeys[sectionKey]) {
                        return invalid(`contract key already exists at ${contractPtr(sectionKey)}`);
                      }

                      const contractsMap = entry?.contracts || {};
                      const contractKeys = contractKeysFromMap(contractsMap).map((key) => `${key}`);

                      if (!hasMatchingRelatedContracts(entry?.section, contractKeys)) {
                        return invalid('relatedContracts must match contracts');
                      }

                      for (const key of contractKeys) {
                        if (existingContractKeys[key]) {
                          return invalid(`contract key already exists at ${contractPtr(key)}`);
                        }
                        const dup = trackContractKey(sectionKey, key);
                        if (dup) return dup;
                      }

                      for (const key of contractKeys) {
                        sectionChangeset.push({ op: 'add', path: contractPtr(key), val: contractsMap[key] });
                      }

                      sectionChangeset.push({
                        op: 'add',
                        path: contractPtr(sectionKey),
                        val: normalizeSection(entry?.section, contractKeys)
                      });
                    }

                    const modifyList = isArray(sectionChanges?.modify) ? sectionChanges.modify : [];
                    for (const entry of modifyList) {
                      const sectionKey = `${entry?.sectionKey || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.modify is missing sectionKey');

                      const sectionKeyDup = trackSectionKey(sectionKey);
                      if (sectionKeyDup) return sectionKeyDup;

                      const existingRelated = isArray(contracts?.[sectionKey]?.relatedContracts)
                        ? contracts[sectionKey].relatedContracts.map((value) => `${value}`)
                        : [];
                      const existingRelatedMap = {};
                      for (const value of existingRelated) {
                        existingRelatedMap[`${value}`] = true;
                      }

                      const contractsMap = entry?.contracts || {};
                      const contractKeys = contractKeysFromMap(contractsMap).map((key) => `${key}`);

                      if (!hasMatchingRelatedContracts(entry?.section, contractKeys)) {
                        return invalid('relatedContracts must match contracts');
                      }

                      for (const key of contractKeys) {
                        const dup = trackContractKey(sectionKey, key);
                        if (dup) return dup;
                        if (existingContractKeys[key] && !existingRelatedMap[key]) {
                          return invalid(`contract key already exists at ${contractPtr(key)}`);
                        }
                      }

                      for (const key of contractKeys) {
                        sectionChangeset.push({ op: 'add', path: contractPtr(key), val: contractsMap[key] });
                      }

                      for (const oldKey of existingRelated) {
                        if (contractKeys.indexOf(oldKey) === -1) {
                          sectionChangeset.push({ op: 'remove', path: contractPtr(oldKey) });
                        }
                      }

                      sectionChangeset.push({
                        op: 'add',
                        path: contractPtr(sectionKey),
                        val: normalizeSection(entry?.section, contractKeys)
                      });
                    }

                    const removeList = isArray(sectionChanges?.remove) ? sectionChanges.remove : [];
                    for (const entry of removeList) {
                      const sectionKey = `${entry?.sectionKey || entry || ''}`;
                      if (!sectionKey) return invalid('sectionChanges.remove is missing sectionKey');

                      const related = isArray(contracts?.[sectionKey]?.relatedContracts)
                        ? contracts[sectionKey].relatedContracts
                        : [];

                      for (const key of related) {
                        sectionChangeset.push({ op: 'remove', path: contractPtr(key) });
                      }
                      sectionChangeset.push({ op: 'remove', path: contractPtr(sectionKey) });
                    }

                    const combined = sectionChangeset.concat(requestChangeset);

                    if (combined.length === 0) {
                      return invalid('no changes provided');
                    }

                    return { changeset: combined };
              - name: Apply
                type:
                  blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                changeset:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: ${steps.Prepare.changeset}
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 5cwVBvBpQWLmYmpAMfXVt7mGrrZDZinBkdgJ61oT2FGR
            attributesAdded: []
      - status: stable
        content:
          name: Chat Message
          description: |
            Conversation event representing a single chat message exchanged between participants.
          type:
            blueId: 5Wz4G9qcnBJnntYRkz4dgLK5bSuoMpYJZj4j5M59z4we
