                                                      value: true
                                        - $call:
                                            function:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: asObject
                                            args:
                                              val:
                                                $event:
