          type:
            blueId: 67WiBLmgNLGfxz7EcReXicgopEBUqYcX6mFGe6YRXatw
          onBehalfOf:
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          targetSessionId:
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          links:
            type:
              blueId: DsDibGYwridS8uYoUcwFbBHa49UFAA7MtLNboXrXudmn
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7MTCgNo4iWnxoVhqJytiApkZYmrDPRZWUeCBPtfhZJma
            attributesAdded: []
      - status: dev
        content:
          name: Linked Documents Permission Grant To Account
          type:
            blueId: FMWYekdjwkDnoM2YfHmwuUATHZovSgmDEvSVTmyVmbHc
          contracts:
            granterChannel:
              description: Granter/owner’s timeline
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            granteeChannel:
              description: Grantee’s timeline
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            revokeAccessChannel:
              description: Either grant side can invoke revoke on this grant document.
              type:
                blueId: 4FE7wU8cnFsb7gEcgQk8vTGYZHLqvJH6Yjsv2TXovgr2
              channels:
                items:
                  - type:
                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                    value: granterChannel
                  - type:
                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                    value: granteeChannel
            initLifecycleChannel:
              type:
                blueId: 2DXGQUiQBQ6CT89jwAsTAXaEPhLgiSXhKCGh9Q7Hv3MQ
              event:
                type:
                  blueId: Ht1o66MTLKf7JmnEiR27rRLSwdz8FUTgf2mGPNuLSDUL
            revoke:
              description: Granter or grantee indicates the grant should be revoked (MyOS Admin will handle).
              type:
                blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: revokeAccessChannel
              request:
                description: Optional human-readable reason
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
            revokeImpl:
              type:
                blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
              operation:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: revoke
              steps:
                items:
                  - name: EmitRevokeRequested
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $appendEvent:
                            type:
                              blueId: BKyVzxDr2rJp7weHvuzyrgSJ42ATwN3SizPchqu7QMVc
                            reason:
                              $event:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: /message/request
                        - $return:
                            events:
                              $events:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
            validateOnInit:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: initLifecycleChannel
              steps:
                items:
                  - name: ValidateBasicShape
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    entry:
                      type:
                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                      value: validate
                    functions:
                      asList:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                                kind:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: list
                            then:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            else:
                              items: []
                      asObject:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                                kind:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: object
                            then:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            else:
                              $emptyObject:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
                      isNonEmptyText:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $and:
                            items:
                              - $isKind:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: val
                                  kind:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: text
                              - $truthy:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                      isMetaKey:
                        args:
                          key:
                            description: BEX helper argument.
                        expr:
                          $or:
                            items:
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: description
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: type
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: keyType
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: valueType
                      hasBadSingleOps:
                        args:
                          ops:
                            description: BEX helper argument.
                        expr:
                          $some:
                            in:
                              $call:
                                function:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: asList
                                args:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: ops
                            item:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: opName
                            where:
                              $not:
                                $call:
                                  function:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: isNonEmptyText
                                  args:
                                    val:
                                      $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: opName
                      validate:
                        do:
                          items:
                            - $let:
                                vars:
                                  issues:
                                    items: []
                                  target:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /targetSessionId
                                  granterId:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /contracts/granterChannel/accountId
                                  granteeId:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /contracts/granteeChannel/accountId
                                  links:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: asObject
                                      args:
                                        val:
                                          $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /links
                                  anchorCount:
                                    type:
                                      blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                    value: 0
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: target
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: targetSessionId is missing or invalid
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: granterId
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: granterChannel must be bound to an accountId
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: granteeId
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: granteeChannel must be bound to an accountId
                            - $if:
                                cond:
                                  $eq:
                                    items:
                                      - $size:
                                          $keys:
                                            $var:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: links
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: links is missing or invalid
                            - $forEach:
                                in:
                                  $keys:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: links
                                item:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: anchor
                                do:
                                  items:
                                    - $if:
                                        cond:
                                          $not:
                                            $call:
                                              function:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: isMetaKey
                                              args:
                                                key:
                                                  $var:
                                                    type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: anchor
                                        then:
                                          items:
                                            - $set:
                                                name: anchorCount
                                                expr:
                                                  $add:
                                                    items:
                                                      - $var:
                                                          type:
                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                          value: anchorCount
                                                      - type:
                                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                                        value: 1
                                            - $let:
                                                order:
                                                  items:
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: perms
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: singleOps
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: hasSingle
                                                vars:
                                                  perms:
                                                    $call:
                                                      function:
                                                        type:
                                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                        value: asObject
                                                      args:
                                                        val:
                                                          $get:
                                                            object:
                                                              $var:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: links
                                                            key:
                                                              $var:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: anchor
                                                  singleOps:
                                                    $choose:
                                                      cond:
                                                        $exists:
                                                          $var:
                                                            name: perms
                                                            path:
                                                              type:
                                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                              value: /singleOps
                                                      then:
                                                        $var:
                                                          name: perms
                                                          path:
                                                            type:
                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                            value: /singleOps
                                                      else:
                                                        items: []
                                                  hasSingle:
                                                    $gt:
                                                      items:
                                                        - $size:
                                                            $call:
                                                              function:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: asList
                                                              args:
                                                                val:
                                                                  $var:
                                                                    type:
                                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                    value: singleOps
                                                        - type:
                                                            blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                                          value: 0
                                            - $if:
                                                cond:
                                                  $ne:
                                                    items:
                                                      - $var:
                                                          name: perms
                                                          path:
                                                            type:
                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                            value: /read
                                                      - type:
                                                          blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                                        value: true
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].read must be true'
                                            - $if:
                                                cond:
                                                  $call:
                                                    function:
                                                      type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: hasBadSingleOps
                                                    args:
                                                      ops:
                                                        $var:
                                                          type:
                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                          value: singleOps
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].singleOps must contain only non-empty strings'
                                            - $if:
                                                cond:
                                                  $and:
                                                    items:
                                                      - $eq:
                                                          items:
                                                            - $var:
                                                                name: perms
                                                                path:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: /allOps
                                                            - type:
                                                                blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                                              value: true
                                                      - $var:
                                                          type:
                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                          value: hasSingle
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].allOps=true and singleOps are mutually exclusive'
                            - $if:
                                cond:
                                  $eq:
                                    items:
                                      - $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: anchorCount
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: links must have at least one anchor entry
                            - $if:
                                cond:
                                  $gt:
                                    items:
                                      - $size:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: issues
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: Cm9gL7QQ4CDhi18VKg5PfK11Xy6CLVJawoa88BTTy9ZU
                                        issues:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: issues
                                else:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: Gqf8h8GKR98kdptTXPABstPSc5ezuKGRsTQ8w1QDcSnQ
                            - $return:
                                events:
                                  $events:
                                    type:
                                      blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                    value: true
          targetSessionId:
            description: Base document session id whose anchors define the scope of this grant.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          granterDocumentSessionId:
            description: |
              Optional. If set, MyOS should evaluate authority as this document session
              (principalType='document', granteeId=documentId of this session),
              instead of the granter accountId.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          links:
            description: Map from anchor name to permissions that will be granted for documents linked to the base document via that anchor.
            type:
              blueId: DsDibGYwridS8uYoUcwFbBHa49UFAA7MtLNboXrXudmn
        versions:
          - repositoryVersionIndex: 1
            typeBlueId: 14HJjMexrCjNLdaqdaTrByotfkDnCjbztbg45iu6gRtu
            attributesAdded: []
      - status: dev
        content:
          name: Linked Documents Permission Grant To Document
          type:
            blueId: FMWYekdjwkDnoM2YfHmwuUATHZovSgmDEvSVTmyVmbHc
          contracts:
            granterChannel:
              description: Granter/owner’s timeline (direct grant-document revoke lives here).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            initLifecycleChannel:
              type:
                blueId: 2DXGQUiQBQ6CT89jwAsTAXaEPhLgiSXhKCGh9Q7Hv3MQ
              event:
                type:
                  blueId: Ht1o66MTLKf7JmnEiR27rRLSwdz8FUTgf2mGPNuLSDUL
            revoke:
              description: Granter requests revocation on the grant document. Grantee-document self-revoke uses the existing revoke-request event with grantDocumentId emitted from the grantee document itself.
              type:
                blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: granterChannel
              request:
                description: Optional human-readable reason
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
            revokeImplGranter:
              type:
                blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
              operation:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: revoke
              steps:
                items:
                  - name: EmitRevokeRequested
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $appendEvent:
                            type:
                              blueId: BKyVzxDr2rJp7weHvuzyrgSJ42ATwN3SizPchqu7QMVc
                            reason:
                              $event:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: /message/request
                        - $return:
                            events:
                              $events:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
            validateOnInit:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: initLifecycleChannel
              steps:
                items:
                  - name: ValidateBasicShape
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    entry:
                      type:
                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                      value: validate
                    functions:
                      asList:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                                kind:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: list
                            then:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            else:
                              items: []
                      asObject:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                                kind:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: object
                            then:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            else:
                              $emptyObject:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
                      isNonEmptyText:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $and:
                            items:
                              - $isKind:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: val
                                  kind:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: text
                              - $truthy:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: val
                      isMetaKey:
                        args:
                          key:
                            description: BEX helper argument.
                        expr:
                          $or:
                            items:
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: description
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: type
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: keyType
                              - $eq:
                                  items:
                                    - $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: key
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: valueType
                      hasBadSingleOps:
                        args:
                          ops:
                            description: BEX helper argument.
                        expr:
                          $some:
                            in:
                              $call:
                                function:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: asList
                                args:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: ops
                            item:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: opName
                            where:
                              $not:
                                $call:
                                  function:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: isNonEmptyText
                                  args:
                                    val:
                                      $var:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: opName
                      validate:
                        do:
                          items:
                            - $returnIf:
                                cond:
                                  $eq:
                                    items:
                                      - $document:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: /skipValidation
                                      - type:
                                          blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                        value: true
                                expr:
                                  events:
                                    items: []
                            - $let:
                                vars:
                                  issues:
                                    items: []
                                  target:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /targetSessionId
                                  granterId:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /contracts/granterChannel/accountId
                                  granteeDocumentId:
                                    $document:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: /granteeDocumentId
                                  links:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: asObject
                                      args:
                                        val:
                                          $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /links
                                  anchorCount:
                                    type:
                                      blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                    value: 0
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: target
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: targetSessionId is missing or invalid
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: granterId
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: granterChannel must be bound to an accountId
                            - $if:
                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: granteeDocumentId
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: granteeDocumentId must be a non-empty string
                            - $if:
                                cond:
                                  $eq:
                                    items:
                                      - $size:
                                          $keys:
                                            $var:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: links
                                      - type:
                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                        value: 0
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: links is missing or invalid
                            - $forEach:
                                in:
                                  $keys:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: links
                                item:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: anchor
                                do:
                                  items:
                                    - $if:
                                        cond:
                                          $not:
                                            $call:
                                              function:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: isMetaKey
                                              args:
                                                key:
                                                  $var:
                                                    type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: anchor
                                        then:
                                          items:
                                            - $set:
                                                name: anchorCount
                                                expr:
                                                  $add:
                                                    items:
                                                      - $var:
                                                          type:
                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                          value: anchorCount
                                                      - type:
                                                          blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                                        value: 1
                                            - $let:
                                                order:
                                                  items:
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: perms
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: singleOps
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: hasSingle
                                                vars:
                                                  perms:
                                                    $call:
                                                      function:
                                                        type:
                                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                        value: asObject
                                                      args:
                                                        val:
                                                          $get:
                                                            object:
                                                              $var:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: links
                                                            key:
                                                              $var:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: anchor
                                                  singleOps:
                                                    $choose:
                                                      cond:
                                                        $exists:
                                                          $var:
                                                            name: perms
                                                            path:
                                                              type:
                                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                              value: /singleOps
                                                      then:
                                                        $var:
                                                          name: perms
                                                          path:
                                                            type:
                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                            value: /singleOps
                                                      else:
                                                        items: []
                                                  hasSingle:
                                                    $gt:
                                                      items:
                                                        - $size:
                                                            $call:
                                                              function:
                                                                type:
                                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                value: asList
                                                              args:
                                                                val:
                                                                  $var:
                                                                    type:
                                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                    value: singleOps
                                                        - type:
                                                            blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
                                                          value: 0
                                            - $if:
                                                cond:
                                                  $ne:
                                                    items:
                                                      - $var:
                                                          name: perms
                                                          path:
                                                            type:
                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                            value: /read
                                                      - type:
                                                          blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                                        value: true
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                          value: '''].read must be true'
                                            - $if:
                                                cond:
                                                  $call:
                                                    function:
                                                      type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: hasBadSingleOps
                                                    args:
                                                      ops:
                                                        $var:
                                                          type:
                                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                          value: singleOps
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                                  value: issues
