                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: asText
                                      args:
                                        val:
                                          $event:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /message/request/rejectedAt
                                  currentDecisionStatus:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: asText
                                      args:
                                        val:
                                          $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /clientDecisionStatus
                                  alreadyDecided:
                                    $or:
                                      items:
                                        - $eq:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: currentDecisionStatus
                                              - type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: accepted
                                        - $eq:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: currentDecisionStatus
                                              - type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: rejected
                                  transactionStatus:
                                    $call:
                                      function:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: asText
                                      args:
                                        val:
                                          $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /transactionIdentificationStatus
                                  canReject:
                                    $and:
                                      items:
                                        - $eq:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: transactionStatus
                                              - type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: identified
                                        - $eq:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: currentDecisionStatus
                                              - type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: pending
                                  discardReason:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: canReject
                                      then:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: ''
                                      else:
                                        $choose:
                                          cond:
                                            $var:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: alreadyDecided
                                          then:
                                            $concat:
                                              items:
                                                - type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: PayNote already
                                                - type:
                                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                  value: ' '
                                                - $var:
                                                    type:
                                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                    value: currentDecisionStatus
                                          else:
                                            $choose:
                                              cond:
                                                $eq:
                                                  items:
                                                    - $var:
                                                        type:
                                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                        value: transactionStatus
                                                    - type:
                                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                      value: failed
                                              then:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: Transaction identification failed
                                              else:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: Transaction not identified
                                  nextDecisionStatus:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: canReject
                                      then:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: rejected
                                      else:
                                        $choose:
                                          cond:
                                            $truthy:
                                              $var:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: currentDecisionStatus
                                          then:
                                            $var:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: currentDecisionStatus
                                          else:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: pending
                                  nextRejectedAt:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: canReject
                                      then:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: rejectedAt
                                      else:
                                        $call:
                                          function:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: asText
                                          args:
                                            val:
                                              $document:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: /clientRejectedAt
                                  nextDeliveryStatus:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: canReject
                                      then:
                                        type:
                                          blueId: 6tenJidVxJRDqxtYM4xGs6fxD2E7MVvGQwv5rF4HnGsh
                                        mode:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: terminated
                                      else:
                                        $default:
                                          items:
                                            - $document:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: /deliveryStatus
                                            - type:
                                                blueId: CE3FgdBrYRhs4Vvz93ArW8TvzWgQvouEyuJ72bGiidXS
                                              mode:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: pending
                                  nextDeliveryError:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
