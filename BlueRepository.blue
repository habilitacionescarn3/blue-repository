              Indicates the role of the party in an regulatory initial margin call instruction (i.e Pledgor party or Secured party).
            type:
              blueId: 4uJVRvwwVNEj9rBzrw3MG5hDWu6VEQFjKX3TkVNmZtxQ
          regMarginType:
