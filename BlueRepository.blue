                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: lifecycle
              steps:
                items:
                  - name: Initialize Bootstrap Status
                    type:
                      blueId: 6bU2jWm3F6GaCXSLpdxiNjRbf9XcQDzH1NUsroHz4x8U
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /bootstrapStatus
                          val:
                            type:
                              blueId: 5BQB6Hsr3qxMsZikHdqd2LGeKdQafEQ4jo6TBqm9JZuB
            handleParticipantResolved:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: triggeredEventsChannel
              event:
                type:
                  blueId: BswjhjkdTDksVCcc8ijoU2RWcPam7Rphcecc67HJjZRi
              steps:
                items:
                  - name: Update Participant State
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $if:
                            cond:
                              $not:
                                $exists:
                                  $event:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: /channelName
                            then:
                              items:
                                - $return:
                                    changeset:
                                      items: []
                                    events:
                                      items: []
                        - $let:
                            order:
                              items:
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: channelName
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: accountStatus
                            vars:
                              channelName:
                                $event:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: /channelName
                              accountStatus:
                                $default:
                                  items:
                                    - $event:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: /participant/status/accountStatus
                                    - type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: Unknown
                        - $appendChange:
                            op:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: replace
                            path:
                              $pointerJoin:
                                items:
                                  - type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: participantsState
                                  - $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: channelName
                            val:
                              accountStatus:
                                $var:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: accountStatus
                              errorMessage:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: ''
                        - $return:
                            changeset:
                              $changeset:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
            handleTargetDocumentSessionStarted:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: triggeredEventsChannel
