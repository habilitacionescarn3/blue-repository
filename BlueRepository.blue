            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/datetime/AdjustableOrAdjustedOrRelativeDate
          description: |
            This Rosetta class specifies the date as either an unadjusted, adjusted or relative date. It supplements the features of the AdjustableOrAdjustedDate to support the credit default swap option premium, which uses the relative date construct.
          adjustedDate:
            description: |
              The date once the adjustment has been performed. (Note that this date may change if the business center holidays change).
            type:
              blueId: HTDqFgte5VF88dLHnCZMjvyetfxfTAKxf9r8ciErE7Vg
          dateAdjustments:
            description: |
              The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers.
            type:
              blueId: 8ZhZC2EwhTqHnDvvcr2ZW4iwCBJM57NcLAqPCd8shypq
          relativeDate:
            description: A date specified as some offset to another date (the anchor date).
            type:
              blueId: 4JvKSv6NGWh8hqfN6miPYiWwfE3g61v9yBhQuXc8tB8z
          unadjustedDate:
            description: A date subject to adjustment.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 8VijgDyT9t9CiNbNQYVbdE1whbL9Q9DTRMZpCocVhSxF
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/datetime/AdjustableOrRelativeDate
          description: |
            A class giving the choice between defining a date as an explicit date together with applicable adjustments or as relative to some other (anchor) date.
          adjustableDate:
            description: |
              A date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.
            type:
              blueId: GKy9ctegTJLwNAwxTMo1WX9xQCvWbzwntin4VStfEfDi
          relativeDate:
            description: A date specified as some offset to another date (the anchor date).
            type:
              blueId: GagRkiFg7C2PG1ce2M6QYaKL99fY3TTLH3DBbZp4Fduc
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 2Dr79mc7tDo84pCgLDhmSAuay1naC42UUovCTcaMjY5R
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/datetime/AdjustableOrRelativeDates
          description: |
            A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates.
          adjustableDates:
            description: |
              A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.
            type:
              blueId: 5JcKEFUStAenXhdmeTHE6nvpuhEjPvsvuge4TX2AuQrA
          relativeDates:
            description: A series of dates specified as some offset to another series of dates (the anchor dates).
            type:
              blueId: DXynKUQNFZU7oUmvsh7mUrjs7JL5RKXrrmkH9hZr99CL
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: AiYMNnHZT7DJNXi1wScVgJSGHkgj5i6eH6jUgQoxX9Bw
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/datetime/AdjustableRelativeOrPeriodicDates
          description: |
            A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates, or as a calculation period schedule.
          adjustableDates:
            description: |
              A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.
            type:
              blueId: 5JcKEFUStAenXhdmeTHE6nvpuhEjPvsvuge4TX2AuQrA
          periodicDates:
            description: A calculation period schedule.
            type:
              blueId: JBENwei996PNTBkNZUR1ojomCwz48ULaZEJoeaXxukmT
          relativeDates:
            description: A series of dates specified as some offset to another series of dates (the anchor dates).
            type:
              blueId: DXynKUQNFZU7oUmvsh7mUrjs7JL5RKXrrmkH9hZr99CL
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 4EkR94oSN87arjWhzEQUZELGM8at9SvDoSZ3LKbE12sg
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/datetime/AdjustedRelativeDateOffset
          description: |
            A type defining a date (referred to as the derived date) as a relative offset from another date (referred to as the anchor date) plus optional date adjustments.
          adjustedDate:
            description: |
              The date once the adjustment has been performed. (Note that this date may change if the business center holidays change).
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          businessCenters:
            type:
              blueId: H53mV1d8rMzhefLZH8WzGchozyQA28cbwNpBHGmVA9ti
          businessCentersReference:
            description: |
              A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not.
            type:
              blueId: 7ACnecbuWHtBLYhrw8BaioS3DSUQFiDskjpaDNspEmof
          businessDayConvention:
            description: |
              The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent).
            type:
              blueId: UEYhmdmBmLhrdtL1ThGtACP6Ljtvao5EVBeQdbiB2XJ
          dateRelativeTo:
            description: |
              Specifies the anchor as an href attribute. The href attribute value is a pointer style reference to the element or component elsewhere in the document where the anchor date is defined.
            type:
              blueId: 6r7X1t4mk8pzhtyij1QDYaoMrseQxsRdHuJTw8dJaEk2
          dayType:
            description: |
              In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included.
            type:
              blueId: EPBWZ9jBx984Q99bnqB2NAqBTKrAr4mJWCYnwcFgnivq
          period:
            description: |
              A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day).
            type:
              blueId: DLZBHc2QwPj4my2QeZffRBsJxbqMSJzN3PScqxr9C1Yj
          periodMultiplier:
            description: |
              A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days.
            type:
              blueId: E2LM6qgzWG9ttagq2xTmiZkgYEAgkYedFCmU9v7NnVEq
          relativeDateAdjustments:
            description: |
              The business day convention and financial business centers used for adjusting the relative date if it would otherwise fall on a day that is not a business date in the specified business centers.
            type:
              blueId: 8ZhZC2EwhTqHnDvvcr2ZW4iwCBJM57NcLAqPCd8shypq
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: GagRkiFg7C2PG1ce2M6QYaKL99fY3TTLH3DBbZp4Fduc
            attributesAdded: []
