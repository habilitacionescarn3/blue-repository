      - status: stable
        content:
          name: Frequency
          description: |
            A class for defining a date frequency, e.g. one day, three months, through the combination of an integer value and a standardized period value that is specified as part of an enumeration.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/base/datetime
          period:
            description: A time period, e.g. a day, week, month, year or term of the stream.
            type:
              blueId: Eswj6CdGqkuScnc6DBZYTs1ZdfjwbdCXe2b71T7JXMLm
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          periodMultiplier:
            description: |
              A time period multiplier, e.g. 1, 2, or 3. If the period value is T (Term) then period multiplier must contain the value 1.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: 9oAFpaZmZoU5msdeRmJqmKkHYzAK5TUS4Y1RBFzqrPFn
            attributesAdded: []
      - status: stable
        content:
          name: FundProductTypeEnum
