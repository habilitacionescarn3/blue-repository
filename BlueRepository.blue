      - status: stable
        content:
          name: CounterpartyPosition
          description: A Position describes the accumulated effect of a set of securities or financial transactions.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/event/position
          collateral:
            description: Represents the collateral obligations of a party.
            type:
              blueId: H13o9y8FDLQ2PAJuQtwBUVnqJnULLyHosektAQe8e3yC
          contractDetails:
            description: Represents information specific to trades or positions involving contractual products.
            type:
              blueId: CjfBmwvchPmwgm4eHJpNPMqryQAi686wY5nk5mRh56YX
          executionDetails:
            description: Defines specific attributes that relate to trade or position executions.
            type:
              blueId: 3pQXn9D3a6rPNgHREFN2ZaZwnMAVja8RM5vebLyvZUki
          openDateTime:
            description: The date and time when the position was opened.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          party:
            description: The parties involved in the position, including the Clearing Organization.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: AVN4ESaeQMFu31gp5PDiR55P6nWzHRiWZR2pKxQS5d6W
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          partyRole:
            description: Represents the role each specified party takes in the position.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: HjRiCP4U2kbina9KzZmsLbxfxuEKtL8de46X5Pvi5j4Q
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          positionBase:
            description: Encapsulates the core constituents that characterize a position.
            type:
              blueId: FhCmi92P8iKsnZPP6scsD5AeDwwPxFHkMyBfKrDSDnoh
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          positionIdentifier:
            description: |
              Represents the identifier(s) that uniquely identify a position for an identity issuer. A position can include multiple identifiers, for example an internal position identifer and a UTI (Unique Trade Identifier).
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: CqbA4C789vc7YHieJFX1dSWuNt3f7LkGCNjSSGF9ZfUB
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          tradeReference:
            description: Reference to all the trades that constitute the position.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: HijkmoFFK7RWn5r1Hv7QiAx6jqwPnfnDZNR1RPEoFgW7
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
