            attributesAdded: []
      - status: stable
        content:
          name: SettlementCentreEnum
          description: Defines the settlement centre for a securities transaction.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
