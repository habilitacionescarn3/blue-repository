      - status: stable
        content:
          name: cdm/product/collateral/CollateralInterestHandlingParameters
          description: |
            Represents parameters that describe how calculated interest amounts are handled, i.e. are they transferred/distributed, or is the collateral balance adjusted, is netting done, and any other special handling.
          accrueInterestOnUnsettledInterest:
            description: |
              Indicates whether interest accruing on unsettled interest amount is included (continues to be accrued) in the following period.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
          alternativeProvision:
            description: Specifies an alternative to interest amount, when the alternative provision clause is specified.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          alternativeToInterestAmount:
            description: Specifies the alternative to interest amounts.
            type:
              blueId: DpVYkkJKuVne3rcRtkfcsA1c5rBQibEFY4ujWCibD9jS
          cutoffTime:
            description: Specifies the time of day that interest needs to be confirmed by.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          includeAccrualInMarginCalc:
            description: Indicates whether or not to include the open interest accrual in the margin calculation.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            schema:
              required: true
          interestAmountApplication:
            description: The application of Interest Amount with respect to the Delivery Amount and the Return Amount.
            type:
              blueId: 7kes2FB65JuXjGdz6Lp6zhm95qL5DTCjDxCKwSm8USPV
          interestPaymentHandling:
            description: Specifies how the collateral interest is to be handled.
            type:
              blueId: sKqpZrkqt2VYmFSkbB7RRDetUKe7PJhYfsksQL6utY4
            schema:
              required: true
          interestRolloverLimit:
            description: Specifies the level below which the interest will be rolled over.
            type:
              blueId: CV1DAoEgGqnEeJtvUszvVHPatrrZQE6M5vVad2MX3ssq
          netInterestWithMarginCalls:
            description: |
              Indicates whether the interest amount may be offset against any margin call deliver or return amounts?   (aka 'net payments' indicator).
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            schema:
              required: true
          netPostedAndHeldInterest:
            description: |
              Indicates whether to net Held and Posted Interest Payments (i.e. whether interest payable for a period can be netted with interest receivable).
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            schema:
              required: true
          notification:
            description: Specifies the terms describing notification requirements.
            type:
              blueId: AYFPdhUATGeD5Kaw7pwDQbqnwnGZ2DyM7rk1rVn4M1uM
          onFullReturn:
            description: |
              Indicates the option that accrued interest should be calculated and distributed when a full return of collateral occurs.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            schema:
              required: true
          onPartialReturn:
            description: |
              Indicates the option that accrued interest should be calculated and distributed when a partial return collateral occurs.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            schema:
              required: true
          paymentBusinessCenter:
            description: Specifies applicable business centers for payments.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: Ftpos6LCMk31PB3e4E1siiMshU1M88BMeTNK4yRypXyL
            schema:
              minItems: 0
          writeoffLimit:
            description: Specifies the level below which the interest will be written off; if omitted write-off is not applicable.
            type:
              blueId: CV1DAoEgGqnEeJtvUszvVHPatrrZQE6M5vVad2MX3ssq
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: EcvzpLymGTG2HkooovYn4sPFjmSFWGF1uM1CeM6FfNgz
            attributesAdded: []
      - status: stable
