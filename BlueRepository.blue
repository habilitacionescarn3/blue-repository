                        - $appendChange:
                            op:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: replace
                            path:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: /initiatorSessionIds
                            val:
                              $event:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: /initiatorSessionIds
                        - $appendEvent:
                            type:
                              blueId: 8crrz93vvovMkh91qyLj6ajwEDAZw1DdTZ3NBjK6jaqV
                            status:
                              type:
                                blueId: BEc6aieqN1iaXT2bNQVag1a1cGygZCLCjXf3mvupetNg
                              mode:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
