            type:
              blueId: 796x89gqZi8yLKhDwKArGYcCuCbixQw7PQhuDpancqMn
            schema:
              required: true
          standardSettlementStyle:
            description: Settlement Style.
            type:
              blueId: 3gvWJxrxUUD4bdYMUZb5GWjJwHqshsA9ncx7VngcWSQG
          transferSettlementType:
            description: The qualification as to how the transfer will settle, e.g. a DvP settlement.
            type:
              blueId: BSQDJMfPWXBaqWYWPJCUYYLzftmLKsUbi3EyLhuh7Mr1
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: FRNg4ydc3F8rvwrqYRg8u7vigXiWiCjXAY9CFHc61QKA
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/common/settlement/SettlementCentreEnum
          description: Defines the settlement centre for a securities transaction.
          type:
            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
