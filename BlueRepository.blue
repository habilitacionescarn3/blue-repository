            type:
              blueId: FRSvW86AnukqsUtioAtNxLvGvH8hBV3m6J2YV3egXjjV
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          eventDeterminationDate:
            description: The date in which the credit event is determined by the Credit Derivatives Determinations Comitee.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          finalPrice:
            description: The final price resulting from the auction.
            type:
              blueId: wuC3RHpv6ahucWwxTgdeQyeUP8ecWQQqgMvSpx3Z543
          publiclyAvailableInformation:
            description: |
              A public information source, e.g. a particular newspaper or electronic news service, that may publish relevant information used in the determination of whether or not a credit event has occurred.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
