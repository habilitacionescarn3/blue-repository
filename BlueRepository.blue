      - status: stable
        content:
          name: Index
          description: |
            An Index is an Observable which is computed based on the prices, rates or valuations of a number of assets that are tracked in a standardized way.  Examples include equity market indices as well as indices on interest rates, inflation and credit instruments.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/observable/asset
          CreditIndex:
            description: |
              An index based on credit risk, typically composed using corporate debt instruments in a region or industry sector, e.g. the iTraxx indices.
            type:
              blueId: 4F6mUpV2LpFdnNaBRbB73cCAp6WBhyHEVpdsFLJY5osc
          EquityIndex:
            description: An index based on equity securities, e.g. the S&P 500.
            type:
              blueId: 9td8wxrr4VHiiiVNvYfRvHf45EJf2c4Vqxzmg2LHYZBX
          ForeignExchangeRateIndex:
            description: A rate based on the exchange of a pair of cash assets in specific currencies, e.g. USD versus GBP.
            type:
              blueId: HdxRMsB9JqVoHg9kKoC9DRb95BmDrCJMPYDCRPqFUkGq
          InterestRateIndex:
            description: An index based in interest rates or inflation rates in a certain market.
            type:
              blueId: 2Pgz6jV9R148z8wQjHPwAVuZiegfLy9gT7qsmqsUKuTq
          OtherIndex:
            description: An index created by a market participant which doesn't align with the other index types.
            type:
              blueId: 2RUDJ89m5VkV6iYfutaTstZ8wkMpjt8HjksUMVUpfxZU
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: DeVKbrFxpkLrJLp6obbqxxaMSeVsG4mwnFMbbwutoGF5
            attributesAdded: []
