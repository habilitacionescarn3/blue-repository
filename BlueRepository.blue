                          ops:
                            description: BEX helper argument.
                        expr:
                          $some:
                            in:
                              $call:
                                function:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: asList
                                args:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: ops
                            item:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: opName
                            where:
