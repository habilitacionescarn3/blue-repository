      - status: dev
        content:
          name: Single Document Permission Grant To Account
          type:
            blueId: Gm9rGd9RJMvBcPCwN7ybywVAtMAAngeAB82DZ2cQ6bAE
          targetSessionId:
            description: Target document session id to grant access to
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          granterDocumentSessionId:
            description: Optional. If set, MyOS should evaluate authority using this document session as the principal (instead of granter accountId).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          permissions:
            description: Rights to grant on the target session (READ required; allOps and singleOps are mutually exclusive; singleOps is optional but must be non-empty if provided).
            type:
              blueId: 5cZ3J1QiMJEJV4FV5kfSkeG2oJmweWCyJo3v2TSc3Xuw
          contracts:
            granterChannel:
              description: Granter/owner’s timeline
              type:
                blueId: 9gQuMoLckgwgvAfx1X8tzdHwMNfRcraG96PfT5TDbXeh
            granteeChannel:
              description: Grantee’s timeline
              type:
                blueId: 9gQuMoLckgwgvAfx1X8tzdHwMNfRcraG96PfT5TDbXeh
            revokeAccessChannel:
              description: Either grant side can invoke revoke on this grant document.
              type:
                blueId: ByQY8CFbj5JVoSuoutRmG5wJWfvAidg7q83zsQ3GTgD4
              channels:
                items:
                  - type:
                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                    value: granterChannel
                  - type:
                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                    value: granteeChannel
            initLifecycleChannel:
              type:
                blueId: H2aCCTUcLMTJozWkn7HPUjyFBFxamraw1q8DyWk87zxr
              event:
                type:
                  blueId: BrpmpNt5JkapeUvPqYcxgXZrHNZX3R757dRwuXXdfNM2
            revoke:
              description: Granter or grantee indicates the grant should be revoked (MyOS Admin will handle).
              type:
                blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: revokeAccessChannel
              request:
                description: Optional human-readable reason
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            revokeImpl:
              type:
                blueId: B5mVH4caQv9Hmzeb5ZmCtzYomooFzTdoCQ4mZVwHY3MS
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: revoke
              steps:
                items:
                  - name: EmitRevokeRequested
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    do:
                      items:
                        - $appendEvent:
                            type:
                              blueId: 2nRHhR7JeMKzs5wPKV6GMwbxbyvts5Boynzv6yNJxnQz
                            reason:
                              $event:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: /message/request
                        - $return:
                            events:
                              $events:
                                type:
                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                value: true
            validateOnInit:
              type:
                blueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: initLifecycleChannel
              steps:
                items:
                  - name: ValidateBasicShape
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    entry:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: validate
                    functions:
                      asList:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $choose:
                            cond:
                              $isKind:
                                val:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: val
                                kind:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: list
                            then:
                              $var:
                                type:
                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                value: val
                            else:
                              items: []
                      isNonEmptyText:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $and:
                            items:
                              - $isKind:
                                  val:
                                    $var:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: val
                                  kind:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: text
                              - $truthy:
                                  $var:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: val
                      hasBadSingleOps:
                        args:
                          ops:
                            description: BEX helper argument.
                        expr:
                          $some:
                            in:
                              $call:
                                function:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: asList
                                args:
                                  val:
                                    $var:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: ops
                            item:
                              type:
                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                              value: opName
                            where:
                              $not:
                                $call:
                                  function:
                                    type:
                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                    value: isNonEmptyText
                                  args:
                                    val:
                                      $var:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: opName
                      validate:
                        do:
                          items:
                            - $let:
                                order:
                                  items:
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: issues
                                    - type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: target
                                    - type:
