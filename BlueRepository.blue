                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            else:
                              items: []
                      isNonEmptyText:
                        args:
                          val:
                            description: BEX helper argument.
                        expr:
                          $and:
                            items:
                              - $isKind:
                                  val:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: val
                                  kind:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: text
