      - status: dev
        content:
          name: PayNote Delivery
          description: Tracks delivery of a PayNote through a deliverer (e.g., bank) to a receiver (payer - client).
          contracts:
            payNoteSender:
              description: Participant submitting the PayNote delivery (merchant or processor).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            payNoteDeliverer:
              description: Participant delivering and reporting status (e.g., bank).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            initLifecycleChannel:
              type:
                blueId: 2DXGQUiQBQ6CT89jwAsTAXaEPhLgiSXhKCGh9Q7Hv3MQ
              event:
                type:
                  blueId: Ht1o66MTLKf7JmnEiR27rRLSwdz8FUTgf2mGPNuLSDUL
            initialize:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: initLifecycleChannel
              steps:
                items:
                  - name: Initialize Delivery State
                    type:
                      blueId: 6bU2jWm3F6GaCXSLpdxiNjRbf9XcQDzH1NUsroHz4x8U
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /deliveryStatus
                          val:
                            type:
                              blueId: CE3FgdBrYRhs4Vvz93ArW8TvzWgQvouEyuJ72bGiidXS
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /transactionIdentificationStatus
                          val:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: pending
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /clientDecisionStatus
                          val:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: pending
                        - op:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: replace
                          path:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /deliveryError
                          val:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: ''
            updateTransactionIdentificationStatus:
              type:
                blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: payNoteDeliverer
              request:
                description: True when the transaction is identified.
                type:
                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
            updateTransactionIdentificationStatusImpl:
              type:
                blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
              operation:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: updateTransactionIdentificationStatus
              steps:
                items:
                  - name: ClassifyIdentificationResult
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $let:
                            order:
                              items:
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: identified
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: currentStatus
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: canUpdate
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: nextIdentificationStatus
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: nextDeliveryStatus
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: nextDeliveryError
                            vars:
                              identified:
                                $eq:
                                  items:
                                    - $event:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: /message/request
                                    - type:
                                        blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                      value: true
                              currentStatus:
                                $document:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: /transactionIdentificationStatus
                              canUpdate:
                                $not:
                                  $or:
                                    items:
                                      - $eq:
                                          items:
                                            - $document:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: /transactionIdentificationStatus
                                            - type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: identified
                                      - $eq:
                                          items:
                                            - $document:
                                                type:
                                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                                value: /transactionIdentificationStatus
                                            - type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: failed
                              nextIdentificationStatus:
                                $choose:
                                  cond:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: canUpdate
                                  then:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: identified
                                      then:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: identified
                                      else:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: failed
                                  else:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: currentStatus
                              nextDeliveryStatus:
                                $choose:
                                  cond:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: canUpdate
                                  then:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: identified
                                      then:
                                        type:
                                          blueId: 5BQB6Hsr3qxMsZikHdqd2LGeKdQafEQ4jo6TBqm9JZuB
                                        mode:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: active
                                      else:
                                        type:
                                          blueId: 6tenJidVxJRDqxtYM4xGs6fxD2E7MVvGQwv5rF4HnGsh
                                        mode:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: terminated
                                  else:
                                    $default:
                                      items:
                                        - $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /deliveryStatus
                                        - type:
                                            blueId: CE3FgdBrYRhs4Vvz93ArW8TvzWgQvouEyuJ72bGiidXS
                                          mode:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: pending
                              nextDeliveryError:
                                $choose:
                                  cond:
                                    $var:
                                      type:
                                        blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                      value: canUpdate
                                  then:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: identified
                                      then:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: ''
                                      else:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: Transaction identification failed
                                  else:
                                    $default:
                                      items:
                                        - $document:
                                            type:
                                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                            value: /deliveryError
                                        - type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: ''
                        - $appendChange:
                            op:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: replace
                            path:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: /transactionIdentificationStatus
                            val:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: nextIdentificationStatus
                        - $appendChange:
                            op:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: replace
                            path:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: /deliveryStatus
