            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          calculatedAmount:
            description: The amount of the cash flow that was computed, including any spreads and other processing.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          calculationPeriod:
            description: The calculation period for which the floating calculation was performed.
            type:
              blueId: 8HxGXBgYZPyirVyritWo12kVT2cL8N2ZjWmPRVFZXMRZ
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          calculationPeriodNotionalAmount:
            description: The notional in effect during the calculation period.
            type:
              blueId: AbAR9hDgkuDPyGUVbpg2virbQmHfou9H5TMSUKaAAQo3
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          floatingRate:
            description: |
              The details of the floating rate setting.  (If it is a calculated rate, details of that calculation will be inside that.
            type:
              blueId: 7hLDehftnAPCHiXGoxbzth7yZckVJV1Xhys6K3kfXCwA
          processingDetails:
            description: |
              Details fo the floating rate treatment after the rate is observed or calculated.  This will include details of things like multipliers, spreads, caps and floors, and the raw and treated rates.
            type:
              blueId: 4rYmZmkajnSzuUXxDdS4KBurqCWAhwJ1MvB32sABC32f
          spreadExclusiveCalculatedAMount:
            description: The amount of the cash flow excluding any spread, for subsequent processing.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          yearFraction:
            description: The fraction of a year that this calculation represents, according to the day count fraction method.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
