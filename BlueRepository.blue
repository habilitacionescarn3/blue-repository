      - status: dev
        content:
          name: PayNote
          description: |
            A document attached to exactly one transaction that governs what should happen with that transaction.
          kind:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: PayNote
          status:
            description: |
              Current lifecycle state of this PayNote. Expected values include: Pending, Accepted, Initiated, Secured, Completed, Cancelled, Reversed, Rejected, Failed.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          currency:
            description: ISO 4217 currency code.
            type:
              blueId: CBnZ7aaNetj9KEqXpUWj5jvjKbmviLivP98T2EiyxiYc
          amount:
            description: Amount values associated with this PayNote.
            expectedTotal:
              description: |
                The initially expected total amount in minor units.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            finalResolved:
              description: |
                The final resolved amount for completion, if known.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            secured:
              description: |
                Amount currently secured / under guarantor control.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            completed:
              description: |
                Amount already completed / finalized.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
            reversed:
              description: |
                Amount already reversed after completion.
              type:
                blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
          transactionDetails:
            description: |
              Transaction attachment information confirmed by the Guarantor.
          controls:
            completionLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            reversalLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            transactionDetailsUpdateLocked:
              type:
                blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
          payNoteInitialStateDescription:
            summary:
              description: |
                Short explanation of what this PayNote is for.
              type:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            details:
              description: |
                Full explanation of the process, conditions, and special rules. Markdown recommended.
              type:
                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          contracts:
            search:
              type:
                blueId: 5KdjguBmn7AwB9d8tjKxRh4xUHU9T8WDJ4dbaY6qgPvx
              kv:
                kind:
                  type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: /kind
            payerChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            payeeChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            guarantorChannel:
              type:
                blueId: DcoJyCh7XXxy1nR5xjy7qfkUgQ1GiZnKKSxh8DJusBSr
            initLifecycleChannel:
              type:
                blueId: H2aCCTUcLMTJozWkn7HPUjyFBFxamraw1q8DyWk87zxr
              event:
                type:
                  blueId: BrpmpNt5JkapeUvPqYcxgXZrHNZX3R757dRwuXXdfNM2
            initialize:
              type:
                blueId: 7X3LkN54Yp88JgZbppPhP6hM3Jqiqv8Z2i4kS7phXtQe
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: initLifecycleChannel
              steps:
                items:
                  - name: Resolve PayNote Runtime Defaults
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const fallback = (current, value) =>
                          current === null || current === undefined ? value : current;

                        return {
                          status: fallback(document('/status'), 'Pending'),
                          amountFinalResolved: fallback(document('/amount/finalResolved'), 0),
                          amountSecured: fallback(document('/amount/secured'), 0),
                          amountCompleted: fallback(document('/amount/completed'), 0),
                          amountReversed: fallback(document('/amount/reversed'), 0),
                          completionLocked: fallback(document('/controls/completionLocked'), false),
                          reversalLocked: fallback(document('/controls/reversalLocked'), false),
                          transactionDetailsUpdateLocked: fallback(
                            document('/controls/transactionDetailsUpdateLocked'),
                            false
                          ),
                          transactionDetails: fallback(document('/transactionDetails'), {}),
                        };
                  - name: Initialize PayNote Runtime State
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /status
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].status}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /amount/finalResolved
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].amountFinalResolved}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /amount/secured
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].amountSecured}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /amount/completed
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].amountCompleted}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /amount/reversed
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].amountReversed}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /controls/completionLocked
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].completionLocked}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /controls/reversalLocked
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].reversalLocked}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /controls/transactionDetailsUpdateLocked
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].transactionDetailsUpdateLocked}
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /transactionDetails
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Resolve PayNote Runtime Defaults'].transactionDetails}
            acceptPayNote:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: CfSpcRXYk2qwu1vNs9LL8rycBsxzL2R4LGyDdrDzwCjh
            acceptPayNoteImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: acceptPayNote
              steps:
                items:
                  - name: Mark PayNote Accepted
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /status
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: Accepted
                  - name: Emit PayNote Accepted
                    type:
                      blueId: 2bSWEoMSZwzf32Hnr4BDVsuq8NRjrWEpnhZvMZAJGhh2
                    event:
                      type:
                        blueId: CfSpcRXYk2qwu1vNs9LL8rycBsxzL2R4LGyDdrDzwCjh
            rejectPayNote:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: AdKfkwRfzRUxUKSzhRfYANsaUBNnz4u6JFWR66qhzyZe
            rejectPayNoteImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: rejectPayNote
              steps:
                items:
                  - name: Validate and Forward Rejection
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('PayNote rejection request must be an object.');
                        }

                        return { events: [request] };
                  - name: Mark PayNote Rejected
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /status
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: Rejected
            recordTransactionInitiated:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: 14UHCXtf9XLpi3Z3n4xbo1dmXRzfXnDEH23iVaechxzh
            recordTransactionInitiatedImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: recordTransactionInitiated
              steps:
                items:
                  - name: Merge Initiation Transaction Details
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('Transaction initiated payload must be an object.');
                        }

                        const current = document('/transactionDetails');
                        const next =
                          current && typeof current === 'object' && !Array.isArray(current)
                            ? { ...current }
                            : {};
                        const keys = Object.keys(request);
                        let index = 0;
                        while (index < keys.length) {
                          const key = keys[index];
                          if (key !== 'type') {
                            next[key] = request[key];
                          }
                          index += 1;
                        }

                        return { nextTransactionDetails: next, events: [request] };
                  - name: Update Initiation State
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /status
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: Initiated
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /transactionDetails
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Merge Initiation Transaction Details'].nextTransactionDetails}
            recordTransactionInitiationFailed:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: FSfMCJpFDcB9zNfrd4gDhaDXpFhaSNToGbAdxSkw55V7
            recordTransactionInitiationFailedImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: recordTransactionInitiationFailed
              steps:
                items:
                  - name: Mark Initiation Failed
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /status
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: Failed
                  - name: Emit Transaction Initiation Failed
                    type:
                      blueId: 2bSWEoMSZwzf32Hnr4BDVsuq8NRjrWEpnhZvMZAJGhh2
                    event:
                      type:
                        blueId: FSfMCJpFDcB9zNfrd4gDhaDXpFhaSNToGbAdxSkw55V7
                      reason:
                        type:
                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                        value: ${event.message.request.reason}
            confirmPayeeAssignment:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: 34v52X6nVj6muiD11W8nohLFn7DjT2RiaRYwjRNpq4v3
            confirmPayeeAssignmentImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: confirmPayeeAssignment
              steps:
                items:
                  - name: Merge Payee Assignment
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('Payee assignment payload must be an object.');
                        }
                        if (typeof request.payeeRef !== 'string') {
                          throw new Error('Payee assignment payload must include payeeRef.');
                        }

                        const current = document('/transactionDetails');
                        const next =
                          current && typeof current === 'object' && !Array.isArray(current)
                            ? { ...current }
                            : {};
                        next.payeeRef = request.payeeRef;

                        return { nextTransactionDetails: next, events: [request] };
                  - name: Update Payee Assignment
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /transactionDetails
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Merge Payee Assignment'].nextTransactionDetails}
            rejectPayeeAssignment:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: CNFxs2PfxjDh7HNCaehyxNJ8zAdLbmgTcH12rU8VA7yi
            rejectPayeeAssignmentImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: rejectPayeeAssignment
              steps:
                items:
                  - name: Emit Payee Assignment Rejected
                    type:
                      blueId: 2bSWEoMSZwzf32Hnr4BDVsuq8NRjrWEpnhZvMZAJGhh2
                    event:
                      type:
                        blueId: CNFxs2PfxjDh7HNCaehyxNJ8zAdLbmgTcH12rU8VA7yi
                      reason:
                        type:
                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                        value: ${event.message.request.reason}
            confirmTransactionDetailsUpdated:
              type:
                blueId: BoAiqVUZv9Fum3wFqaX2JnQMBHJLxJSo2V9U2UBmCfsC
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: guarantorChannel
              request:
                type:
                  blueId: EsyQj8xWb1Kf2ESjDq1UR6PK2hx4fpnyGiEWJ14ttC8a
            confirmTransactionDetailsUpdatedImpl:
              type:
                blueId: CGdxkNjPcsdescqLPz6SNLsMyak6demQQr7RoKNHbCyv
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: confirmTransactionDetailsUpdated
              steps:
                items:
                  - name: Merge Transaction Details Update
                    type:
                      blueId: ExZxT61PSpWHpEAtP2WKMXXqxEYN7Z13j7Zv36Dp99kS
                    code:
                      type:
                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                      value: |
                        const request =
                          event && event.message ? event.message.request : null;

                        if (!request || typeof request !== 'object' || Array.isArray(request)) {
                          throw new Error('Transaction details update payload must be an object.');
                        }
                        if (
                          !request.transactionDetails ||
                          typeof request.transactionDetails !== 'object' ||
                          Array.isArray(request.transactionDetails)
                        ) {
                          throw new Error(
                            'Transaction details update payload must include transactionDetails object.'
                          );
                        }

                        const current = document('/transactionDetails');
                        const next =
                          current && typeof current === 'object' && !Array.isArray(current)
                            ? { ...current }
                            : {};
                        const patch = request.transactionDetails;

                        const patchKeys = Object.keys(patch);
                        let index = 0;
                        while (index < patchKeys.length) {
                          const key = patchKeys[index];
                          next[key] = patch[key];
                          index += 1;
                        }

                        return { nextTransactionDetails: next, events: [request] };
                  - name: Apply Transaction Details Update
                    type:
                      blueId: FtHZJzH4hqAoGxFBjsmy1svfT4BwEBB4aHpFSZycZLLa
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /transactionDetails
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ${steps['Merge Transaction Details Update'].nextTransactionDetails}
