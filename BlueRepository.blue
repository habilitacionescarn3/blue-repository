            typeBlueId: C2Ec7JF7c6QV6kD3Wb7Mtfg9NJ7aemu5KqHaafpZuEvN
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/party/BusinessUnit
          description: A class to specify an organizational unit.
          contactInformation:
            description: |
              The contact information for such business unit, when different from the contact information associated with the party.
            type:
              blueId: 2vquTQrHfbG8GVEjvB7SAZfAmxeyh1hxQeEN1wjro58A
          identifier:
            description: An identifier used to uniquely identify the organizational unit
            type:
