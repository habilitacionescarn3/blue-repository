            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
          thresholdRate:
            description: A threshold rate. The threshold of 0.10% would be represented as 0.001
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
        versions:
