      - status: stable
        content:
          name: cdm/product/common/settlement/StandardSettlementStyleEnum
          description: |
            The enumerated values to specify whether a trade is settling using standard settlement instructions as well as whether it is a candidate for settlement netting.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Net
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: PairAndNet
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: Standard
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: StandardAndNet
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 7YFjahYdHYHERXt79M9mLJ1qKNxQPm89ieLFXUZ2KcwA
            attributesAdded: []
      - status: stable
        content:
          name: cdm/product/common/settlement/TransferSettlementEnum
          description: The enumeration values to specify how the transfer will settle, e.g. DvP.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
