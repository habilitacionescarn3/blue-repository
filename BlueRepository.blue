      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/CommodityProductDefinition
          description: Specifies the commodity underlier in the event that no ISDA Commodity Reference Price exists.
          commodityInfoPublisher:
            description: Specifies the publication where the commodity prices can be found.
            type:
              blueId: GpLEdBS7Wo3gH26kSqsDLo7RudnuHCXQQear34hMXeV7
          exchangeId:
            description: |
              Identifies the exchange from which the reference price should be sourced, using the scheme at the following url: http://www.fpml.org/coding-scheme/external/exchange-id-MIC-1-0
            type:
              blueId: F5GfdsSNcjLAm9anbfMQqxdxAFonErhU5UXFbQzq1zXY
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          priceSource:
            description: |
              Specifies a publication that provides the commodity price, including, where applicable the details of where in the publication the price is published.  Applicable when the commodity reference price is not a futures contract
            type:
              blueId: 7iVrwmxYPhEys3U1gW5XuLq4fFt7XbEdv4H1TSLxucq6
          referenceFramework:
            description: Specifies the type of commodity.
            type:
              blueId: 2LPZuZ9LPiKM2aCEuPCrJLd9Ui3gKomr2qL3fVuqDuMP
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: Gos89VTGy6DvLCuG5yT2kFBYMxBpaCGwUTNsNWRo54yH
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/CommodityReferenceFramework
          description: Specifies the type of commodity.
          capacityUnit:
            description: |
              Provides an enumerated value for a capacity unit, generally used in the context of defining quantities for commodities.
            type:
              blueId: ANaFxPMcbPKw8USLSD7mcUeT9DBz5q9BkYYt9GMjvDMz
          commodityName:
            description: |
              Identifies the commodity more specifically. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions SubAnnex A, including the subCommodity and additional qualifiers, but should be limited to 256 characters or less.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          currency:
            description: Defines the currency in which the commodity is priced.
            type:
              blueId: F5GfdsSNcjLAm9anbfMQqxdxAFonErhU5UXFbQzq1zXY
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          weatherUnit:
            description: |
              Provides an enumerated values for a weather unit, generally used in the context of defining quantities for commodities.
            type:
              blueId: aUWGFpq6gwDP6zaku6dz6bnhGWzX5a3YSgTLJzSqXiL
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 2LPZuZ9LPiKM2aCEuPCrJLd9Ui3gKomr2qL3fVuqDuMP
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/CreditRiskEnum
          description: Represents an enumeration list to identify tranched or untranched credit risk.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: TranchedCreditRisk
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                  value: UntranchedCreditRisk
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 4vgWSAqEkzGf7yiQ9rsm3s5Nk6Ncj4iT16wxhQXAwe8y
            attributesAdded: []
      - status: stable
