                blueId: 26w2LGCpoFHqcEpb22oJRodHCTew398PGc1WMLRevxqz
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: initLifecycleChannel
              steps:
                items:
                  - name: Initialize Delivery State
                    type:
                      blueId: FuD8hYGXvwBJGBzXhFB6DVtWHawt8hbpM6yT94H4p7cZ
                    changeset:
                      items:
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /deliveryStatus
                          val:
                            type:
                              blueId: Gqcw51QJT9NStqo2ka3E76tQ8UZie33F4yqdjwskav79
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /transactionIdentificationStatus
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: pending
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /clientDecisionStatus
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: pending
                        - op:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: replace
                          path:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: /deliveryError
                          val:
                            type:
                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                            value: ''
            updateTransactionIdentificationStatus:
              type:
                blueId: 9Fu3Rjq8hNKnZS71ZU8RXBBupZEa7Wb8z44GtzfSwjbr
              channel:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: payNoteDeliverer
              request:
                description: True when the transaction is identified.
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            updateTransactionIdentificationStatusImpl:
              type:
                blueId: B5mVH4caQv9Hmzeb5ZmCtzYomooFzTdoCQ4mZVwHY3MS
              operation:
                type:
                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                value: updateTransactionIdentificationStatus
              steps:
                items:
                  - name: ClassifyIdentificationResult
                    type:
                      blueId: MXnjrsiUgKPkinuRCVXEmnsBJhESt7HYZQPJH1eJvnJ
                    do:
                      items:
                        - $let:
                            order:
                              items:
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: identified
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: currentStatus
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: canUpdate
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: nextIdentificationStatus
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: nextDeliveryStatus
                                - type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: nextDeliveryError
                            vars:
                              identified:
                                $eq:
                                  items:
                                    - $event:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: /message/request
                                    - type:
                                        blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                      value: true
                              currentStatus:
                                $document:
                                  type:
                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                  value: /transactionIdentificationStatus
                              canUpdate:
                                $not:
                                  $or:
                                    items:
                                      - $eq:
                                          items:
                                            - $document:
                                                type:
                                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                value: /transactionIdentificationStatus
                                            - type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: identified
                                      - $eq:
                                          items:
                                            - $document:
                                                type:
                                                  blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                value: /transactionIdentificationStatus
                                            - type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: failed
                              nextIdentificationStatus:
                                $choose:
                                  cond:
                                    $var:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: canUpdate
                                  then:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: identified
                                      then:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: identified
                                      else:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: failed
                                  else:
                                    $var:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: currentStatus
                              nextDeliveryStatus:
                                $choose:
                                  cond:
                                    $var:
                                      type:
                                        blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                      value: canUpdate
                                  then:
                                    $choose:
                                      cond:
                                        $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: identified
                                      then:
                                        type:
                                          blueId: E6jaeVfFuyjB4YEZyp7fvUt8AJ7BmKr8WAM9oGDmhMbM
                                        mode:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: active
                                      else:
                                        type:
                                          blueId: Fh7VjkS1XTg9BzQWBQrvD9ePLUEZVR86FAhVbttw1Wxs
                                        mode:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: terminated
                                  else:
                                    $default:
                                      items:
                                        - $document:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: /deliveryStatus
                                        - type:
                                            blueId: Gqcw51QJT9NStqo2ka3E76tQ8UZie33F4yqdjwskav79
