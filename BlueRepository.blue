        content:
          name: cdm/base/math/AveragingCalculationMethodEnum
          description: Specifies enumerations for the type of averaging calculation.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
            enum:
              items:
                - type:
                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
