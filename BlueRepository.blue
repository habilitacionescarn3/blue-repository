          - repositoryVersionIndex: 0
            typeBlueId: 6FkJxLK4KiPuQ7LHqQDvpGSeaWMVr5dw4g2K9mBrnybJ
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/CollateralTaxonomyValue
          description: Specifies the collateral taxonomy value, either as a specified enumeration or as a string.
          eu_EMIR_EligibleCollateral:
            description: |
              Identifies European Union Eligible Collateral Assets classification categories based on EMIR Uncleared Margin Rules. Eligible Collateral asset classes for both initial margin (IM) and variation margin (VM) posted and collected between specified entities. Please note: EMIR regulation will detail which eligible collateral assets classes apply to each type of entity pairing (counterparty) and which apply to posting of IM and VM
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: JD6nBEcv7VVBDthKMnQ7bjvFeFys3igpBt4jJgWKqU6q
            schema:
              minItems: 0
          nonEnumeratedTaxonomyValue:
            description: Identifies the taxonomy value when not specified as an enumeration.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: HTDqFgte5VF88dLHnCZMjvyetfxfTAKxf9r8ciErE7Vg
            schema:
              minItems: 0
          uk_EMIR_EligibleCollateral:
            description: |
              Identifies United Kingdom Eligible Collateral Assets classification categories based on UK Onshored EMIR Uncleared Margin Rules Eligible Collateral asset classes for both initial margin (IM) and variation margin (VM) posted and collected between specified entities. Please note: UK EMIR regulation will detail which eligible collateral assets classes apply to each type of entity pairing (counterparty) and which apply to posting of IM and VM.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: AzXN6ztsTLkCn7bM8QH8xfhjrtrr3MVYuhKiVM2y7JUe
            schema:
              minItems: 0
          us_CFTC_PR_EligibleCollateral:
            description: |
              Identifies US Eligible Collateral Assets classification categories based on Uncleared Margin Rules published by the CFTC and the US Prudential Regulator. Note: While the same basic categories exist in the CFTC and US Prudential Regulators’ margin rules, the precise definitions or application of those rules could differ between the two rules.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 4uCFVBTnzc9vzmmzLSyG6TPxegT1i7fGFyiwSkSAhNNW
            schema:
              minItems: 0
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 46LCCSVXKexPjXtAyPSyNEvZuzGR66uVP8ccRPSrwJhs
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/Commodity
          description: Identifies a specific commodity by referencing a product identifier or by a product definition.
          commodityProductDefinition:
            description: Specifies the commodity underlier in the event that no ISDA Commodity Reference Benchmark exists.
            type:
              blueId: 42E8LjfyrvfiY3rzFn9ktgxtEHdG6eXmK5CyYGHUkotU
          deliveryDateReference:
            description: |
              Specifies the parameters for identifying the relevant contract date when the commodity reference price is a futures contract.
            type:
              blueId: 4ZskTzTzcVURodZiz2Xe1cU3ryAzGu9uwsf7Nc5DU4tA
          exchange:
            description: If the Asset is listed, defines the public exchange of the listing.
            type:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
          identifier:
            description: Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: B4oXDUH9jELDatvZSw3oWXtJefJ4ixYawEjxBMqSerth
            schema:
              minItems: 1
          isExchangeListed:
            description: Defines whether the Asset is listed on a public exchange.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
          priceQuoteType:
            description: |
              Describes the required quote type of the underlying price that will be observed. Example values include 'Bid, 'Ask', 'Settlement' (for a futures contract) and 'WeightedAverage' (for some published prices and indices).
            type:
              blueId: AH1BY9EazwZmuZ6LcxCKPZSzsejRaRpRinAqLmVsFTgc
            schema:
              required: true
          relatedExchange:
            description: Provides the related Exchanges, if applicable.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
            schema:
              minItems: 0
          taxonomy:
            description: |
              Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 9MYk7MRYjbMWPHe7v3WexZqePowTL8eRrW8TmNNEtzQJ
            schema:
              minItems: 0
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: VrWJzqq3ogdc8MhQ87P7nugRkiYR7sK4XS7wQzTvce3
            attributesAdded: []
