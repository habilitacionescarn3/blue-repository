                                                          value: hasSingle
                                                then:
                                                  items:
                                                    - $set:
                                                        name: issues
                                                        expr:
                                                          $listConcat:
                                                            items:
                                                              - $var:
                                                                  type:
                                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                  value: issues
                                                              - items:
                                                                  - $concat:
                                                                      items:
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: links['
                                                                        - $var:
                                                                            type:
                                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                            value: anchor
                                                                        - type:
                                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                                          value: '''].allOps=true and singleOps are mutually exclusive'
                            - $if:
                                cond:
                                  $eq:
                                    items:
                                      - $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: anchorCount
                                      - type:
                                          blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                                        value: 0
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                    value: links must have at least one anchor entry
                            - $if:
                                cond:
                                  $gt:
                                    items:
                                      - $size:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                      - type:
                                          blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                                        value: 0
                                then:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: 4JMVYn4GU5hEc6f9PVuTUD7zr4mUgeTyCF54rkjsYUFE
                                        issues:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                else:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: AuKN3wv7WZXJdonpPqP9TJCBqTfBssMj4f2G1ffyAs6E
                            - $return:
                                events:
                                  $events:
                                    type:
                                      blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                    value: true
