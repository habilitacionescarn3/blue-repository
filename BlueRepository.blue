      - status: stable
        content:
          name: ParametricDates
          description: Defines rules for the dates on which the price will be determined.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/product/common/schedule
          businessCenters:
