        content:
          name: AdjustableRelativeOrPeriodicDates
          description: |
            A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates, or as a calculation period schedule.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/base/datetime
          adjustableDates:
            description: |
              A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date.
            type:
              blueId: AG6NtvNFFwKWA7v6kDDiySGkSg45fwcTBYAoXYak7neg
          periodicDates:
            description: A calculation period schedule.
            type:
              blueId: 8USUw24QFafGyNSmnx7SR9PmGD3xLy9c34KdRRVQW1p5
          relativeDates:
            description: A series of dates specified as some offset to another series of dates (the anchor dates).
            type:
              blueId: G26P7eS3WvPxhoNpE1Ky1LvReJAvc2SUoYcjLksC2RhQ
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: 6NoYrXzLpXe7TDKgr7Xrnjuut4E5CwQJwWm5DHNDKxwB
            attributesAdded: []
      - status: stable
        content:
          name: AdjustedRelativeDateOffset
          description: |
            A type defining a date (referred to as the derived date) as a relative offset from another date (referred to as the anchor date) plus optional date adjustments.
          namespace:
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            value: cdm/base/datetime
          adjustedDate:
            description: |
              The date once the adjustment has been performed. (Note that this date may change if the business center holidays change).
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          businessCenters:
            type:
              blueId: HujWuka613tVBGR9SknuY73FEbD163xzBbEmUfRCTtF9
          businessCentersReference:
            description: |
              A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not.
            type:
              blueId: Gxef9Ao3kTD6W3FqiEvpaQ3PXH9nMAzm4B5vGBzJ41ZU
          businessDayConvention:
            description: |
              The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent).
            type:
              blueId: FYjKvmcTzRNBddpxNjEdu31EQrd26VAAYESVaWq8SfR4
          dateRelativeTo:
            description: |
              Specifies the anchor as an href attribute. The href attribute value is a pointer style reference to the element or component elsewhere in the document where the anchor date is defined.
            type:
              blueId: 3axYjghwt3K7wfSxjM4eXAjHbd3aziwcGyHmqeKub9cb
          dayType:
            description: |
              In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included.
            type:
              blueId: 8Utptv7prCHT9bj4UBzGdFdJC4pHSGJxAe4NehEFUsce
          period:
            description: |
              A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day).
            type:
              blueId: 7ncA67peeHVDE7ycaaQzkLneaP8b9kPUiGR6Gi7LBD91
          periodMultiplier:
            description: |
              A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days.
            type:
              blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
          relativeDateAdjustments:
            description: |
              The business day convention and financial business centers used for adjusting the relative date if it would otherwise fall on a day that is not a business date in the specified business centers.
            type:
              blueId: G6NRh7uJ9nHqamG4NyjfGcr5Wfk3qujsowe9hwpvpBNp
        versions:
          - repositoryVersionIndex: 3
            typeBlueId: 4Bn4UjJ5wyJD2wnAH9KECmxuQwXJQSheu8KjM7LicENA
            attributesAdded: []
