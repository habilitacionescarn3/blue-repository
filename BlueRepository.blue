                                cond:
                                  $not:
                                    $call:
                                      function:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: isNonEmptyText
                                      args:
                                        val:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: granteeDocumentId
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                    value: granteeDocumentId must be a non-empty string (originalBlueId)
                            - $if:
                                cond:
                                  $not:
                                    $isKind:
                                      val:
                                        $var:
                                          type:
                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                          value: perms
                                      kind:
                                        type:
                                          blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                        value: object
                                then:
                                  items:
                                    - $set:
                                        name: issues
                                        expr:
                                          $listConcat:
                                            items:
                                              - $var:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: issues
                                              - items:
                                                  - type:
                                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                    value: permissions block is missing
                                else:
                                  items:
                                    - $if:
                                        cond:
                                          $ne:
                                            items:
                                              - $var:
                                                  name: perms
                                                  path:
                                                    type:
                                                      blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                    value: /read
                                              - type:
                                                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                                value: true
                                        then:
                                          items:
                                            - $set:
                                                name: issues
                                                expr:
                                                  $listConcat:
                                                    items:
                                                      - $var:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: issues
                                                      - items:
                                                          - type:
                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                            value: permissions.read must be true for SDPG
                                    - $if:
                                        cond:
                                          $call:
                                            function:
                                              type:
                                                blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                              value: hasBadSingleOps
                                            args:
                                              ops:
                                                $var:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: singleOps
                                        then:
                                          items:
                                            - $set:
                                                name: issues
                                                expr:
                                                  $listConcat:
                                                    items:
                                                      - $var:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: issues
                                                      - items:
                                                          - type:
                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                            value: permissions.singleOps must contain only non-empty strings
                                    - $if:
                                        cond:
                                          $and:
                                            items:
                                              - $eq:
                                                  items:
                                                    - $var:
                                                        name: perms
                                                        path:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: /allOps
                                                    - type:
                                                        blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                                      value: true
                                              - $var:
                                                  type:
                                                    blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                  value: hasSingle
                                        then:
                                          items:
                                            - $set:
                                                name: issues
                                                expr:
                                                  $listConcat:
                                                    items:
                                                      - $var:
                                                          type:
                                                            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                          value: issues
                                                      - items:
                                                          - type:
                                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                                            value: permissions.allOps=true and permissions.singleOps are mutually exclusive
                            - $if:
                                cond:
                                  $gt:
                                    items:
                                      - $size:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                      - type:
                                          blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                                        value: 0
                                then:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: HTd3TkLwKaALYryVRrwnTTnF3rUzF5yrqzKg2ChrcaE9
                                        issues:
                                          $var:
                                            type:
                                              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
                                            value: issues
                                else:
                                  items:
                                    - $appendEvent:
                                        type:
                                          blueId: 6EYcrXJUBiocfFddndoEx1RdAnXuGr3XTxwGoBDdv5x6
                            - $return:
                                events:
                                  $events:
                                    type:
                                      blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                                    value: true
