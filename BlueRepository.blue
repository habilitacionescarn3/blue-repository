  - name: Workflows
    types:
      - status: dev
        content:
          name: Accept Change Operation
          description: |
            Operation marker for accepting a previously stored proposed change. Acceptance means the document should apply the
            changes contained in proposal state and remove the proposal record once the processor has committed the change.

            This operation is part of the proposal/accept/reject workflow family. It separates review from mutation: Propose Change
            captures a request, Accept Change applies it, and Reject Change discards it. The corresponding Accept Change Workflow
            performs validation, policy checks, translation of sectionChanges, and final Update Document patching.
          type:
            blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 1z2ACPaKnxqsMGMtYW54y17uSrutGg5Sbum9RcPtxrb
            attributesAdded: []
      - status: dev
        content:
          name: Accept Change Workflow
          description: Applies a previously proposed change and removes its proposal state.
          type:
            blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
          postfix:
            description: Optional postfix used while building proposed change state key.
            type:
              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
          steps:
            items:
              - name: Prepare
                type:
                  blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                entry:
                  type:
                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                  value: prepare
                functions:
                  invalid:
                    args:
                      reason:
                        description: BEX helper argument.
                    expr:
                      changeset:
                        items: []
                      events:
                        items:
                          - type:
                              blueId: 6jcAKEeVpGCPenpSnfwwamL2iTHBACRXPFQjEDU5pX1y
                            reason:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: reason
                  asList:
                    args:
                      val:
                        description: BEX helper argument.
                    expr:
                      $choose:
                        cond:
                          $isKind:
                            val:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            kind:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: list
                        then:
                          $var:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: val
                        else:
                          items: []
                  asObject:
                    args:
                      val:
                        description: BEX helper argument.
                    expr:
                      $choose:
                        cond:
                          $isKind:
                            val:
                              $var:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: val
                            kind:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: object
                        then:
                          $var:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: val
                        else:
                          $emptyObject:
                            type:
                              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                            value: true
                  isMetaKey:
                    args:
                      key:
                        description: BEX helper argument.
                    expr:
                      $or:
                        items:
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: key
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: type
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: key
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: keyType
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: key
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: valueType
                          - $eq:
                              items:
                                - $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: key
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: description
                  contractKeys:
                    args:
                      contractsMap:
                        description: BEX helper argument.
                    expr:
                      $filter:
                        in:
                          $keys:
                            $call:
                              function:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: asObject
                              args:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: contractsMap
                        item:
                          type:
                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                          value: contractKey
                        where:
                          $not:
                            $call:
                              function:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: isMetaKey
                              args:
                                key:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: contractKey
                  keySetObject:
                    args:
                      keys:
                        description: BEX helper argument.
                    expr:
                      $objectFromEntries:
                        $map:
                          in:
                            $call:
                              function:
                                type:
                                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                value: asList
                              args:
                                val:
                                  $var:
                                    type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: keys
                          item:
                            type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: key
                          expr:
                            key:
                              $text:
                                $var:
                                  type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: key
                            val:
                              type:
                                blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                              value: true
                  contractPath:
                    args:
                      key:
                        description: BEX helper argument.
                    expr:
                      $pointerJoin:
                        items:
                          - type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: contracts
                          - $var:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: key
                  isContractsPatchEntry:
                    args:
                      entry:
                        description: BEX helper argument.
                    expr:
                      $or:
                        items:
                          - $eq:
                              items:
                                - $text:
                                    $default:
                                      items:
                                        - $var:
                                            name: entry
                                            path:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: /path
                                        - type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: ''
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: /contracts
                          - $startsWith:
                              items:
                                - $text:
                                    $default:
                                      items:
                                        - $var:
                                            name: entry
                                            path:
                                              type:
                                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                              value: /path
                                        - type:
                                            blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                          value: ''
                                - type:
                                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                  value: /contracts/
                  isProposedChangePatchEntry:
                    args:
                      entry:
                        description: BEX helper argument.
                    expr:
                      $startsWith:
                        items:
                          - $text:
                              $default:
                                items:
                                  - $var:
                                      name: entry
                                      path:
                                        type:
                                          blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                        value: /path
                                  - type:
                                      blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                                    value: ''
                          - type:
                              blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                            value: /proposedChange
                  hasMatchingRelatedContracts:
                    args:
                      section:
                        description: BEX helper argument.
                      contractKeys:
                        description: BEX helper argument.
                    do:
                      items:
                        - $let:
                            order:
