      - status: dev
        content:
          name: Contracts Change Policy
          description: |
            Marker contract that controls how the document's `contracts` map may be changed by coordination workflows. When
            `requireSectionChanges` is present and not false, workflows such as Change Workflow and Accept Change Workflow must
            reject raw changeset entries that directly target `/contracts`; callers must instead use structured `sectionChanges`.

            The purpose is reviewability and safety. Contract entries define runtime behavior, channels, handlers, policies,
            sections, and operations. Arbitrary low-level patches to `/contracts` are hard for humans and agents to audit. By
            requiring Document Section Changes, this marker forces contract edits to be grouped by section with explicit related
            contracts and section metadata.

            This marker is interpreted by the coordination change workflows, not by the Blue Language. A processor or workflow that
            does not support this policy should treat it according to its must-understand and contract capability rules.
          type:
            blueId: 6zqbYGDGrMv5ReuEsjyzyyjjuqVnqDZxtY7RsPXdBTNy
          requireSectionChanges:
            description: Policy flag; when present and not false, /contracts changes must use sectionChanges. Set false to allow direct changeset edits.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: CECcZ2xesYWUD4qZNFzDWYjWoMU6W55jEEoJHK8MWZct
            attributesAdded: []
      - status: dev
        content:
          name: Customer Consent
          description: Generic customer consent granted to a grantee (e.g., merchant).
          contracts:
            granteeChannel:
              description: Grantee (e.g., merchant MyOS timeline).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            granterChannel:
              description: Granter (customer represented by the bank; customer has no MyOS account).
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            guarantorChannel:
              description: Bank/admin channel.
              type:
                blueId: DwLMXCJcg3AL4GHW1SjraxoNDPpswXH6RHsx4fNDT6rg
            initLifecycleChannel:
              type:
                blueId: 2DXGQUiQBQ6CT89jwAsTAXaEPhLgiSXhKCGh9Q7Hv3MQ
              event:
                type:
                  blueId: Ht1o66MTLKf7JmnEiR27rRLSwdz8FUTgf2mGPNuLSDUL
            initialize:
              type:
                blueId: MyaXwTXty7ZujV89fT5STJvXpEr1W59puqdK2XM9ALv
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: initLifecycleChannel
              steps:
                items:
                  - name: Initialize
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $appendChange:
                            op:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: replace
                            path:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: /consentStatus
                            val:
                              type:
                                blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                              value: granted
                        - $return:
                            changeset:
                              $changeset:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
                            events:
                              $events:
                                type:
                                  blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
                                value: true
            revokeConsent:
              description: Customer revokes the consent.
              type:
                blueId: 316voisXnp8BqLs7BNjjypfn3UG2FSpgFxS6pFqHbf66
              channel:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: granterChannel
              request:
                reason:
                  type:
                    blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                revokedAt:
                  type:
                    blueId: 47EN5A1B1ZXXdXMEoURVJquMSjdDuKFNDjMrkvVxoVJk
            revokeConsentImpl:
              type:
                blueId: AWnvWVtp3g7B67iM6ZFETo1zri5yVikh8i53Q6PAPkqz
              operation:
                type:
                  blueId: GX7CFUmSDrE2MzptunLCCdZwnuwwrenRQqEnHL4x3uoC
                value: revokeConsent
              steps:
                items:
                  - name: Capture
                    type:
                      blueId: 4qGDz5yJxXc9dr8bsBE1B2Tg4AWuR4qHPU9H6T29m3KZ
                    do:
                      items:
                        - $let:
                            order:
