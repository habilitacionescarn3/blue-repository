      - status: stable
        content:
          name: QuantifierEnum
          description: Represents the enumerated values to specify a logical quantification, i.e. either All or Any.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          namespace:
