            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/MoneyBound
          description: The money bound is defined as a money amount and whether the bound is inclusive.
          inclusive:
            description: |
              Whether the money amount bound is inclusive, e.g. for a lower bound, false would indicate greater than, whereas true would indicate greater than or equal to.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          money:
            description: The money amount to be used as the bound, e.g. 1,000 USD.
            type:
              blueId: 5RCy7NwpdTs7j96evsc93hof8nESXDM5u4q3ykG6dXvE
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HqUegcGfdAEK5srxpQGsXa5P43vCM9hADmhrJX7ii9fi
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/MoneyRange
          description: The money range defined as either a lower and upper money bound, or both.
          lowerBound:
            description: The lower bound of a money range, e.g. greater than or equal to 1,000 USD.
            type:
              blueId: HqUegcGfdAEK5srxpQGsXa5P43vCM9hADmhrJX7ii9fi
          upperBound:
            description: The upper bound of a money range, e.g. less than 10,000 USD.
            type:
              blueId: HqUegcGfdAEK5srxpQGsXa5P43vCM9hADmhrJX7ii9fi
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: DKKgVj4h6rghgaMZrdFzPJpGQfNdR8YrcHenPgFkvjQ1
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/NonNegativeQuantity
          description: |
            Specifies a quantity as a non-negative number, which condition is enforced through a data rule that only applies to the extending class.
          datedValue:
            description: |
              A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 4Goc1Ax7PdSp2KoLBDYnqrtvCeRBneZD8E97GQazSXQv
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          frequency:
            description: |
              Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels.
            type:
              blueId: JCn7SJcxSE4UKZYvi2YchB4nwjTsdYKvhCc7RnYogigz
          multiplier:
            description: |
              Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons).
            type:
              blueId: BCRUUCDz5YoH72WRdFUdE8hpNrxmqAyK6QzZdV91WaHp
          unit:
            description: |
              Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit).
            type:
              blueId: 7UDCVn3tDYHeQBU818n6bFdccjBeDPrc6GddKWkT4WDu
          val:
            description: |
              Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: BbfKyr9mpdQ8cuNvCP78fS2o4Rc7gQZ1GdcbnyD6grzK
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/NonNegativeQuantitySchedule
          datedValue:
            description: |
              A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value.
            type:
              blueId: 6aehfNAxHLC1PHHoDr3tYtFH3RWNbiWdFancJ1bypXEY
            itemType:
              blueId: 4Goc1Ax7PdSp2KoLBDYnqrtvCeRBneZD8E97GQazSXQv
            schema:
              minItems:
                type:
                  blueId: 5WNMiV9Knz63B4dVY5JtMyh3FB4FSGqv7ceScvuapdE1
                value: 0
          frequency:
            description: |
              Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels.
            type:
              blueId: JCn7SJcxSE4UKZYvi2YchB4nwjTsdYKvhCc7RnYogigz
          multiplier:
            description: |
              Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons).
            type:
              blueId: BCRUUCDz5YoH72WRdFUdE8hpNrxmqAyK6QzZdV91WaHp
          unit:
            description: |
              Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit).
            type:
              blueId: 7UDCVn3tDYHeQBU818n6bFdccjBeDPrc6GddKWkT4WDu
          val:
            description: |
              Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3aukDRc2UqShaPzsHHg8ry28kkvETMb95rfAeM65GH1Q
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/NonNegativeStep
          description: |
            A class defining a step date and non-negative step value pair. This step definitions are used to define varying rate or amount schedules, e.g. a notional amortisation or a step-up coupon schedule.
          stepDate:
            description: |
              The date on which the associated stepValue becomes effective. This day may be subject to adjustment in accordance with a business day convention.
            type:
              blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          stepValue:
            description: |
              The non-negative rate or amount which becomes effective on the associated stepDate. A rate of 5% would be represented as 0.05.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 3tHmP4cU3vsQunFDGwaDERxB8ZVg7AVLYj29XjgxbaNd
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/NumberBound
          description: The number bound is defined as a number and whether the bound is inclusive.
          inclusive:
            description: |
              Whether the number bound is inclusive, e.g. for a lower bound, false would indicate greater than, whereas true would indicate greater than or equal to.
            type:
              blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
          number:
            description: The number to be used as the bound, e.g. 5.
            type:
              blueId: 7pwXmXYCJtWnd348c2JQGBkm9C4renmZRwxbfaypsx5y
            schema:
              required:
                type:
                  blueId: 4EzhSubEimSQD3zrYHRtobfPPWntUuhEz8YcdxHsi12u
                value: true
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: AT5JtWQz9LEbYiYD2utqkpNY5Kg4aUBGiVFJZ5Vuhj9S
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/NumberRange
          description: The number range defined as either a lower and upper number bound, or both.
          lowerBound:
            description: The lower bound of a number range, e.g. greater than or equal to 5.
            type:
              blueId: AT5JtWQz9LEbYiYD2utqkpNY5Kg4aUBGiVFJZ5Vuhj9S
          upperBound:
            description: The upper bound of a number range, e.g. less than 10.
            type:
              blueId: AT5JtWQz9LEbYiYD2utqkpNY5Kg4aUBGiVFJZ5Vuhj9S
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: HeV5hUrnbKo6ccs1jqoxC5k85Qng7uvpVxMGApHXK7nN
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/math/QuantifierEnum
          description: Represents the enumerated values to specify a logical quantification, i.e. either All or Any.
          type:
            blueId: DLRQwz7MQeCrzjy9bohPNwtCxKEBbKaMK65KBrwjfG6K
          schema:
