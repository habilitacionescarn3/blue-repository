          name: cdm/base/staticdata/asset/common/Instrument
          description: A type of Asset that is issued by one party to one or more others.
          ListedDerivative:
            description: A securitized derivative on another asset that is created by an exchange.
            type:
              blueId: BRguGmoK69E2QqgFfbDWc1f6YVqxFzv3auepNc48tdFR
          Loan:
            description: An Asset that represents a loan or borrow obligation.
            type:
              blueId: ByX5xzV8skV8bxwB7jTPa5FXEzKdm3SxrkmkC22W4nz5
          Security:
            description: An Asset that is issued by a party to be held by or transferred to others.
            type:
              blueId: 5R9o4hMGFG6JsprSkPFoQuMmr2FvfKQchfGbxtSgy2JY
        versions:
          - repositoryVersionIndex: 0
            typeBlueId: 6pomFByRysSRpLwQEWHeqiGU8sc3DrBMjCiuHEuQ1iPB
            attributesAdded: []
      - status: stable
        content:
          name: cdm/base/staticdata/asset/common/InstrumentBase
          description: Defines the common attributes for all Instrument data types.
          exchange:
            description: If the Asset is listed, defines the public exchange of the listing.
            type:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
          identifier:
            description: Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: B4oXDUH9jELDatvZSw3oWXtJefJ4ixYawEjxBMqSerth
            schema:
              minItems: 1
          instrumentType:
            description: Identifies the type of an instrument using an enumerated list.
            type:
              blueId: EmkPx4XLJeffJqq9EbwZicZCxqAhVBpDz1vu6eP1oTYj
            schema:
              required: true
          isExchangeListed:
            description: Defines whether the Asset is listed on a public exchange.
            type:
              blueId: AwvXD961fmnmqcSQhjMA7r15HpVh39cefb6ZTyUz2Fm2
          relatedExchange:
            description: Provides the related Exchanges, if applicable.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 6LRw3aCeJHKD7qGzs2HvJDoQiMs8QddUf5wSr4oagtuS
            schema:
              minItems: 0
          taxonomy:
            description: |
              Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object.
            type:
              blueId: 8DSFoWG9MqRSUhStqoPLrwVQiYByRh18NWbDEarN8MKF
            itemType:
              blueId: 9MYk7MRYjbMWPHe7v3WexZqePowTL8eRrW8TmNNEtzQJ
            schema:
              minItems: 0
