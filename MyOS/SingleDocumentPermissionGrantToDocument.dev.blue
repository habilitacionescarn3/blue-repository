name: Single Document Permission Grant To Document
type: MyOS/MyOS Admin Base

# ----------------- Document fields -----------------
targetSessionId:
  type: Text
  description: Target document session id to grant access to

granteeDocumentId:
  type: Text
  description: Required original document id (blueId) that will act as the grantee principal ('document').

granterDocumentSessionId:
  type: Text
  description: Optional. If set, MyOS should evaluate authority using this document session as the principal (instead of granter accountId).

permissions:
  type: MyOS/Single Document Permission Set
  description: Rights to grant on the target session (READ required; allOps and singleOps are mutually exclusive; singleOps is optional but must be non-empty if provided).

skipValidation:
  type: Boolean
  description: If true, the validation will be skipped (MyOS Admin won't be triggered to create permission grant).

# ---------- Contracts (participants, operations, workflows) ----------
contracts:
  granterChannel:
    type: MyOS/MyOS Timeline Channel
    description: Granter/owner’s timeline (direct grant-document revoke lives here).

  initLifecycleChannel:
    type: Core/Lifecycle Event Channel
    event:
      type: Core/Document Processing Initiated

  revoke:
    type: Coordination/Operation
    description: Granter requests revocation on the grant document. Grantee-document self-revoke uses the existing revoke-request event with grantDocumentId emitted from the grantee document itself.
    channel: granterChannel
    request:
      type: Text
      description: Optional human-readable reason

  revokeImplGranter:
    type: Coordination/Sequential Workflow Operation
    operation: revoke
    steps:
      - name: EmitRevokeRequested
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: MyOS/Single Document Permission Revoke Requested
              reason:
                $event: /message/request
          - $return:
              events:
                $events: true

  validateOnInit:
    type: Coordination/Sequential Workflow
    channel: initLifecycleChannel
    steps:
      - name: ValidateBasicShape
        type: Coordination/Compute
        entry: validate
        functions:
          asList:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: list
                then:
                  $var: val
                else: []
          isNonEmptyText:
            args:
              val:
                description: BEX helper argument.
            expr:
              $and:
                - $isKind:
                    val:
                      $var: val
                    kind: text
                - $truthy:
                    $var: val
          hasBadSingleOps:
            args:
              ops:
                description: BEX helper argument.
            expr:
              $some:
                in:
                  $call:
                    function: asList
                    args:
                      val:
                        $var: ops
                item: opName
                where:
                  $not:
                    $call:
                      function: isNonEmptyText
                      args:
                        val:
                          $var: opName
          validate:
            do:
              - $returnIf:
                  cond:
                    $eq:
                      - $document: /skipValidation
                      - true
                  expr:
                    events: []
              - $let:
                  order:
                    - issues
                    - target
                    - granterId
                    - granteeDocumentId
                    - perms
                    - singleOps
                    - hasSingle
                  vars:
                    issues: []
                    target:
                      $document: /targetSessionId
                    granterId:
                      $document: /contracts/granterChannel/accountId
                    granteeDocumentId:
                      $document: /granteeDocumentId
                    perms:
                      $document: /permissions
                    singleOps:
                      $choose:
                        cond:
                          $exists:
                            $document: /permissions/singleOps
                        then:
                          $document: /permissions/singleOps
                        else: []
                    hasSingle:
                      $gt:
                        - $size:
                            $call:
                              function: asList
                              args:
                                val:
                                  $var: singleOps
                        - 0
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: target
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - targetSessionId is missing or invalid
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: granterId
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - granterChannel must be bound to an accountId
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: granteeDocumentId
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - granteeDocumentId must be a non-empty string (originalBlueId)
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var: perms
                        kind: object
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - permissions block is missing
                  else:
                    - $if:
                        cond:
                          $ne:
                            - $var:
                                name: perms
                                path: /read
                            - true
                        then:
                          - $set:
                              name: issues
                              expr:
                                $listConcat:
                                  - $var: issues
                                  - - permissions.read must be true for SDPG
                    - $if:
                        cond:
                          $call:
                            function: hasBadSingleOps
                            args:
                              ops:
                                $var: singleOps
                        then:
                          - $set:
                              name: issues
                              expr:
                                $listConcat:
                                  - $var: issues
                                  - - permissions.singleOps must contain only non-empty strings
                    - $if:
                        cond:
                          $and:
                            - $eq:
                                - $var:
                                    name: perms
                                    path: /allOps
                                - true
                            - $var: hasSingle
                        then:
                          - $set:
                              name: issues
                              expr:
                                $listConcat:
                                  - $var: issues
                                  - - permissions.allOps=true and permissions.singleOps are mutually exclusive
              - $if:
                  cond:
                    $gt:
                      - $size:
                          $var: issues
                      - 0
                  then:
                    - $appendEvent:
                        type: MyOS/Single Document Permission Invalid
                        issues:
                          $var: issues
                  else:
                    - $appendEvent:
                        type: MyOS/Single Document Permission Validated
              - $return:
                  events:
                    $events: true
