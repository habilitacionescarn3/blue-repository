name: Linked Documents Permission Grant To Account
type: MyOS/MyOS Admin Base

# ----------------- Document fields -----------------

targetSessionId:
  type: Text
  description: Base document session id whose anchors define the scope of this grant.

granterDocumentSessionId:
  type: Text
  description: |
    Optional. If set, MyOS should evaluate authority as this document session
    (principalType='document', granteeId=documentId of this session),
    instead of the granter accountId.

links:
  type: MyOS/Linked Documents Permission Set
  description: Map from anchor name to permissions that will be granted for documents linked to the base document via that anchor.

# ----------------- Contracts -----------------

contracts:
  granterChannel:
    type: MyOS/MyOS Timeline Channel
    description: Granter/owner’s timeline

  granteeChannel:
    type: MyOS/MyOS Timeline Channel
    description: Grantee’s timeline

  revokeAccessChannel:
    type: Coordination/Composite Timeline Channel
    description: Either grant side can invoke revoke on this grant document.
    channels:
      - granterChannel
      - granteeChannel

  initLifecycleChannel:
    type: Core/Lifecycle Event Channel
    event:
      type: Core/Document Processing Initiated

  revoke:
    type: Coordination/Operation
    description: Granter or grantee indicates the grant should be revoked (MyOS Admin will handle).
    channel: revokeAccessChannel
    request:
      type: Text
      description: Optional human-readable reason

  revokeImpl:
    type: Coordination/Sequential Workflow Operation
    operation: revoke
    steps:
      - name: EmitRevokeRequested
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: MyOS/Linked Documents Permission Revoke Requested
              reason:
                $event: /message/request
          - $return:
              events:
                $events: true

  validateOnInit:
    type: Coordination/Sequential Workflow
    channel: initLifecycleChannel
    steps:
      - name: ValidateBasicShape
        type: Coordination/Compute
        entry: validate
        functions:
          asList:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: list
                then:
                  $var: val
                else: []
          asObject:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: object
                then:
                  $var: val
                else:
                  $emptyObject: true
          isNonEmptyText:
            args:
              val:
                description: BEX helper argument.
            expr:
              $and:
                - $isKind:
                    val:
                      $var: val
                    kind: text
                - $truthy:
                    $var: val
          isMetaKey:
            args:
              key:
                description: BEX helper argument.
            expr:
              $or:
                - $eq:
                    - $var: key
                    - description
                - $eq:
                    - $var: key
                    - type
                - $eq:
                    - $var: key
                    - keyType
                - $eq:
                    - $var: key
                    - valueType
          hasBadSingleOps:
            args:
              ops:
                description: BEX helper argument.
            expr:
              $some:
                in:
                  $call:
                    function: asList
                    args:
                      val:
                        $var: ops
                item: opName
                where:
                  $not:
                    $call:
                      function: isNonEmptyText
                      args:
                        val:
                          $var: opName
          validate:
            do:
              - $let:
                  order:
                    - issues
                    - target
                    - granterId
                    - granteeId
                    - links
                    - anchorCount
                  vars:
                    issues: []
                    target:
                      $document: /targetSessionId
                    granterId:
                      $document: /contracts/granterChannel/accountId
                    granteeId:
                      $document: /contracts/granteeChannel/accountId
                    links:
                      $call:
                        function: asObject
                        args:
                          val:
                            $document: /links
                    anchorCount: 0
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: target
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - targetSessionId is missing or invalid
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: granterId
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - granterChannel must be bound to an accountId
              - $if:
                  cond:
                    $not:
                      $call:
                        function: isNonEmptyText
                        args:
                          val:
                            $var: granteeId
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - granteeChannel must be bound to an accountId
              - $if:
                  cond:
                    $eq:
                      - $size:
                          $keys:
                            $var: links
                      - 0
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - links is missing or invalid
              - $forEach:
                  in:
                    $keys:
                      $var: links
                  item: anchor
                  do:
                    - $if:
                        cond:
                          $not:
                            $call:
                              function: isMetaKey
                              args:
                                key:
                                  $var: anchor
                        then:
                          - $set:
                              name: anchorCount
                              expr:
                                $add:
                                  - $var: anchorCount
                                  - 1
                          - $let:
                              order:
                                - perms
                                - singleOps
                                - hasSingle
                              vars:
                                perms:
                                  $call:
                                    function: asObject
                                    args:
                                      val:
                                        $get:
                                          object:
                                            $var: links
                                          key:
                                            $var: anchor
                                singleOps:
                                  $choose:
                                    cond:
                                      $exists:
                                        $var:
                                          name: perms
                                          path: /singleOps
                                    then:
                                      $var:
                                        name: perms
                                        path: /singleOps
                                    else: []
                                hasSingle:
                                  $gt:
                                    - $size:
                                        $call:
                                          function: asList
                                          args:
                                            val:
                                              $var: singleOps
                                    - 0
                          - $if:
                              cond:
                                $ne:
                                  - $var:
                                      name: perms
                                      path: /read
                                  - true
                              then:
                                - $set:
                                    name: issues
                                    expr:
                                      $listConcat:
                                        - $var: issues
                                        - - $concat:
                                              - "links['"
                                              - $var: anchor
                                              - "'].read must be true"
                          - $if:
                              cond:
                                $call:
                                  function: hasBadSingleOps
                                  args:
                                    ops:
                                      $var: singleOps
                              then:
                                - $set:
                                    name: issues
                                    expr:
                                      $listConcat:
                                        - $var: issues
                                        - - $concat:
                                              - "links['"
                                              - $var: anchor
                                              - "'].singleOps must contain only non-empty strings"
                          - $if:
                              cond:
                                $and:
                                  - $eq:
                                      - $var:
                                          name: perms
                                          path: /allOps
                                      - true
                                  - $var: hasSingle
                              then:
                                - $set:
                                    name: issues
                                    expr:
                                      $listConcat:
                                        - $var: issues
                                        - - $concat:
                                              - "links['"
                                              - $var: anchor
                                              - "'].allOps=true and singleOps are mutually exclusive"
              - $if:
                  cond:
                    $eq:
                      - $var: anchorCount
                      - 0
                  then:
                    - $set:
                        name: issues
                        expr:
                          $listConcat:
                            - $var: issues
                            - - links must have at least one anchor entry
              - $if:
                  cond:
                    $gt:
                      - $size:
                          $var: issues
                      - 0
                  then:
                    - $appendEvent:
                        type: MyOS/Linked Documents Permission Invalid
                        issues:
                          $var: issues
                  else:
                    - $appendEvent:
                        type: MyOS/Linked Documents Permission Validated
              - $return:
                  events:
                    $events: true
