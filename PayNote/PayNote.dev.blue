name: PayNote
description: >
  A document attached to exactly one transaction that governs what should happen
  with that transaction.
kind: PayNote

status:
  type: Text
  description: >
    Current lifecycle state of this PayNote.
    Expected values include:
    Pending, Accepted, Initiated, Secured, Completed,
    Cancelled, Reversed, Rejected, Failed.

currency:
  type: Common/Currency
  description: ISO 4217 currency code.

amount:
  description: Amount values associated with this PayNote.
  expectedTotal:
    type: Integer
    description: >
      The initially expected total amount in minor units.
  finalResolved:
    type: Integer
    description: >
      The final resolved amount for completion, if known.
  secured:
    type: Integer
    description: >
      Amount currently secured / under guarantor control.
  completed:
    type: Integer
    description: >
      Amount already completed / finalized.
  reversed:
    type: Integer
    description: >
      Amount already reversed after completion.

transactionDetails:
  description: >
    Transaction attachment information confirmed by the Guarantor.

controls:
  completionLocked:
    type: Boolean
  reversalLocked:
    type: Boolean
  transactionDetailsUpdateLocked:
    type: Boolean

payNoteInitialStateDescription:
  summary:
    type: Text
    description: >
      Short explanation of what this PayNote is for.
  details:
    type: Text
    description: >
      Full explanation of the process, conditions, and special rules.
      Markdown recommended.

contracts:
  search:
    type: MyOS/Search Contract
    kv:
      kind: /kind

  payerChannel:
    type: Core/Channel

  payeeChannel:
    type: Core/Channel
    # May remain unbound initially if payee/recipient is unresolved.

  guarantorChannel:
    type: Core/Channel

  initLifecycleChannel:
    type: Core/Lifecycle Event Channel
    event:
      type: Core/Document Processing Initiated

  initialize:
    type: Coordination/Sequential Workflow
    channel: initLifecycleChannel
    steps:
      - name: ResolveRuntimeDefaults
        type: Coordination/Compute
        do:
          - $appendChange:
              op: add
              path: /status
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /status
                  then:
                    $document: /status
                  else: Pending
          - $appendChange:
              op: add
              path: /amount/finalResolved
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /amount/finalResolved
                  then:
                    $document: /amount/finalResolved
                  else: 0
          - $appendChange:
              op: add
              path: /amount/secured
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /amount/secured
                  then:
                    $document: /amount/secured
                  else: 0
          - $appendChange:
              op: add
              path: /amount/completed
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /amount/completed
                  then:
                    $document: /amount/completed
                  else: 0
          - $appendChange:
              op: add
              path: /amount/reversed
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /amount/reversed
                  then:
                    $document: /amount/reversed
                  else: 0
          - $appendChange:
              op: add
              path: /controls/completionLocked
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /controls/completionLocked
                  then:
                    $document: /controls/completionLocked
                  else: false
          - $appendChange:
              op: add
              path: /controls/reversalLocked
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /controls/reversalLocked
                  then:
                    $document: /controls/reversalLocked
                  else: false
          - $appendChange:
              op: add
              path: /controls/transactionDetailsUpdateLocked
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /controls/transactionDetailsUpdateLocked
                  then:
                    $document: /controls/transactionDetailsUpdateLocked
                  else: false
          - $appendChange:
              op: add
              path: /transactionDetails
              val:
                $choose:
                  cond:
                    $exists:
                      $document: /transactionDetails
                  then:
                    $document: /transactionDetails
                  else:
                    $emptyObject: true
          - $return:
              changeset:
                $changeset: true

  # --- Guarantor operations ---
  acceptPayNote:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/PayNote Accepted

  acceptPayNoteImpl:
    type: Coordination/Sequential Workflow Operation
    operation: acceptPayNote
    steps:
      - name: Mark PayNote Accepted
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Accepted

      - name: Emit PayNote Accepted
        type: Coordination/Trigger Event
        event:
          type: PayNote/PayNote Accepted

  rejectPayNote:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/PayNote Rejected

  rejectPayNoteImpl:
    type: Coordination/Sequential Workflow Operation
    operation: rejectPayNote
    steps:
      - name: ValidateForwardAndReject
        type: Coordination/Compute
        do:
          - $let:
              name: request
              expr:
                $event: /message/request
          - $if:
              cond:
                $not:
                  $isKind:
                    val:
                      $var: request
                    kind: object
              then:
                - $fail: PayNote rejection request must be an object.
          - $appendEvent:
              $var: request
          - $appendChange:
              op: replace
              path: /status
              val: Rejected
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  recordTransactionInitiated:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Transaction Initiated

  recordTransactionInitiatedImpl:
    type: Coordination/Sequential Workflow Operation
    operation: recordTransactionInitiated
    steps:
      - name: MergeInitiationTransactionDetails
        type: Coordination/Compute
        entry: merge
        functions:
          asObject:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: object
                then:
                  $var: val
                else:
                  $emptyObject: true
          objectWithoutType:
            args:
              val:
                description: BEX helper argument.
            expr:
              $objectFromEntries:
                $map:
                  in:
                    $filter:
                      in:
                        $keys:
                          $call:
                            function: asObject
                            args:
                              val:
                                $var: val
                      item: key
                      where:
                        $ne:
                          - $var: key
                          - type
                  item: key
                  expr:
                    key:
                      $text:
                        $var: key
                    val:
                      $get:
                        object:
                          $call:
                            function: asObject
                            args:
                              val:
                                $var: val
                        key:
                          $var: key
          merge:
            do:
              - $let:
                  order:
                    - request
                    - nextTransactionDetails
                  vars:
                    request:
                      $event: /message/request
                    nextTransactionDetails:
                      $merge:
                        - $call:
                            function: asObject
                            args:
                              val:
                                $choose:
                                  cond:
                                    $exists:
                                      $document: /transactionDetails
                                  then:
                                    $document: /transactionDetails
                                  else:
                                    $emptyObject: true
                        - $call:
                            function: objectWithoutType
                            args:
                              val:
                                $event: /message/request
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var: request
                        kind: object
                  then:
                    - $fail: Transaction initiated payload must be an object.
              - $appendEvent:
                  $var: request
              - $appendChange:
                  op: replace
                  path: /status
                  val: Initiated
              - $appendChange:
                  op: replace
                  path: /transactionDetails
                  val:
                    $var: nextTransactionDetails
              - $return:
                  changeset:
                    $changeset: true
                  events:
                    $events: true

  recordTransactionInitiationFailed:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Transaction Initiation Failed

  recordTransactionInitiationFailedImpl:
    type: Coordination/Sequential Workflow Operation
    operation: recordTransactionInitiationFailed
    steps:
      - name: Mark Initiation Failed
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Failed

      - name: Emit Transaction Initiation Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Transaction Initiation Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  confirmPayeeAssignment:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payee Assignment Confirmed

  confirmPayeeAssignmentImpl:
    type: Coordination/Sequential Workflow Operation
    operation: confirmPayeeAssignment
    steps:
      - name: MergePayeeAssignment
        type: Coordination/Compute
        entry: merge
        functions:
          asObject:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: object
                then:
                  $var: val
                else:
                  $emptyObject: true
          merge:
            do:
              - $let:
                  order:
                    - request
                    - nextTransactionDetails
                  vars:
                    request:
                      $event: /message/request
                    nextTransactionDetails:
                      $merge:
                        - $call:
                            function: asObject
                            args:
                              val:
                                $choose:
                                  cond:
                                    $exists:
                                      $document: /transactionDetails
                                  then:
                                    $document: /transactionDetails
                                  else:
                                    $emptyObject: true
                        - payeeRef:
                            $event: /message/request/payeeRef
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var: request
                        kind: object
                  then:
                    - $fail: Payee assignment payload must be an object.
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var:
                            name: request
                            path: /payeeRef
                        kind: text
                  then:
                    - $fail: Payee assignment payload must include payeeRef.
              - $appendEvent:
                  $var: request
              - $appendChange:
                  op: replace
                  path: /transactionDetails
                  val:
                    $var: nextTransactionDetails
              - $return:
                  changeset:
                    $changeset: true
                  events:
                    $events: true

  rejectPayeeAssignment:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payee Assignment Rejected

  rejectPayeeAssignmentImpl:
    type: Coordination/Sequential Workflow Operation
    operation: rejectPayeeAssignment
    steps:
      - name: Emit Payee Assignment Rejected
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payee Assignment Rejected
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  confirmTransactionDetailsUpdated:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Transaction Details Updated

  confirmTransactionDetailsUpdatedImpl:
    type: Coordination/Sequential Workflow Operation
    operation: confirmTransactionDetailsUpdated
    steps:
      - name: MergeTransactionDetailsUpdate
        type: Coordination/Compute
        entry: merge
        functions:
          asObject:
            args:
              val:
                description: BEX helper argument.
            expr:
              $choose:
                cond:
                  $isKind:
                    val:
                      $var: val
                    kind: object
                then:
                  $var: val
                else:
                  $emptyObject: true
          merge:
            do:
              - $let:
                  order:
                    - request
                    - patch
                    - nextTransactionDetails
                  vars:
                    request:
                      $event: /message/request
                    patch:
                      $event: /message/request/transactionDetails
                    nextTransactionDetails:
                      $merge:
                        - $call:
                            function: asObject
                            args:
                              val:
                                $choose:
                                  cond:
                                    $exists:
                                      $document: /transactionDetails
                                  then:
                                    $document: /transactionDetails
                                  else:
                                    $emptyObject: true
                        - $call:
                            function: asObject
                            args:
                              val:
                                $event: /message/request/transactionDetails
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var: request
                        kind: object
                  then:
                    - $fail: Transaction details update payload must be an object.
              - $if:
                  cond:
                    $not:
                      $isKind:
                        val:
                          $var: patch
                        kind: object
                  then:
                    - $fail: Transaction details update payload must include transactionDetails object.
              - $appendEvent:
                  $var: request
              - $appendChange:
                  op: replace
                  path: /transactionDetails
                  val:
                    $var: nextTransactionDetails
              - $return:
                  changeset:
                    $changeset: true
                  events:
                    $events: true
  rejectTransactionDetailsUpdate:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Transaction Details Update Rejected

  rejectTransactionDetailsUpdateImpl:
    type: Coordination/Sequential Workflow Operation
    operation: rejectTransactionDetailsUpdate
    steps:
      - name: Emit Transaction Details Update Rejected
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Transaction Details Update Rejected
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  failTransactionDetailsUpdate:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Transaction Details Update Failed

  failTransactionDetailsUpdateImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failTransactionDetailsUpdate
    steps:
      - name: Emit Transaction Details Update Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Transaction Details Update Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  secureFunds:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Funds Secured

  secureFundsImpl:
    type: Coordination/Sequential Workflow Operation
    operation: secureFunds
    steps:
      - name: SecureFunds
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /status
              val: Secured
          - $appendChange:
              op: replace
              path: /amount/secured
              val:
                $event: /message/request/amountSecured
          - $appendEvent:
              type: PayNote/Funds Secured
              amountSecured:
                $event: /message/request/amountSecured
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  declineSecureFunds:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Funds Securing Declined

  declineSecureFundsImpl:
    type: Coordination/Sequential Workflow Operation
    operation: declineSecureFunds
    steps:
      - name: Mark Funds Securing Declined
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Rejected

      - name: Emit Funds Securing Declined
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Funds Securing Declined
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  failSecureFunds:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Funds Securing Failed

  failSecureFundsImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failSecureFunds
    steps:
      - name: Mark Funds Securing Failed
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Failed

      - name: Emit Funds Securing Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Funds Securing Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  completePayment:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completed

  completePaymentImpl:
    type: Coordination/Sequential Workflow Operation
    operation: completePayment
    steps:
      - name: CompletePayment
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /status
              val: Completed
          - $appendChange:
              op: replace
              path: /amount/completed
              val:
                $event: /message/request/amountCompleted
          - $appendEvent:
              type: PayNote/Payment Completed
              amountCompleted:
                $event: /message/request/amountCompleted
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  declineCompletePayment:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completion Declined

  declineCompletePaymentImpl:
    type: Coordination/Sequential Workflow Operation
    operation: declineCompletePayment
    steps:
      - name: Mark Payment Completion Declined
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Rejected

      - name: Emit Payment Completion Declined
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Completion Declined
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  failCompletePayment:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completion Failed

  failCompletePaymentImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failCompletePayment
    steps:
      - name: Mark Payment Completion Failed
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Failed

      - name: Emit Payment Completion Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Completion Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  cancelBeforeCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Cancelled Before Completion

  cancelBeforeCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: cancelBeforeCompletion
    steps:
      - name: Mark Cancelled Before Completion
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Cancelled

      - name: Emit Payment Cancelled Before Completion
        type: Coordination/Trigger Event
        event:
          type: PayNote/Payment Cancelled Before Completion

  declineCancelBeforeCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Cancellation Declined

  declineCancelBeforeCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: declineCancelBeforeCompletion
    steps:
      - name: Mark Payment Cancellation Declined
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Rejected

      - name: Emit Payment Cancellation Declined
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Cancellation Declined
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  failCancelBeforeCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Cancellation Failed

  failCancelBeforeCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failCancelBeforeCompletion
    steps:
      - name: Mark Payment Cancellation Failed
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Failed

      - name: Emit Payment Cancellation Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Cancellation Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  reverseAfterCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Reversed After Completion

  reverseAfterCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: reverseAfterCompletion
    steps:
      - name: ReverseAfterCompletion
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /status
              val: Reversed
          - $appendChange:
              op: replace
              path: /amount/reversed
              val:
                $event: /message/request/amountReversed
          - $appendEvent:
              type: PayNote/Payment Reversed After Completion
              amountReversed:
                $event: /message/request/amountReversed
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  declineReverseAfterCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Reversal Declined

  declineReverseAfterCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: declineReverseAfterCompletion
    steps:
      - name: Mark Payment Reversal Declined
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Rejected

      - name: Emit Payment Reversal Declined
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Reversal Declined
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  failReverseAfterCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Reversal Failed

  failReverseAfterCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failReverseAfterCompletion
    steps:
      - name: Mark Payment Reversal Failed
        type: Coordination/Update Document
        changeset:
          - op: replace
            path: /status
            val: Failed

      - name: Emit Payment Reversal Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Reversal Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  resolveFinalAmount:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Final Amount Resolved

  resolveFinalAmountImpl:
    type: Coordination/Sequential Workflow Operation
    operation: resolveFinalAmount
    steps:
      - name: ResolveFinalAmount
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /amount/finalResolved
              val:
                $event: /message/request/finalAmount
          - $appendEvent:
              type: PayNote/Final Amount Resolved
              finalAmount:
                $event: /message/request/finalAmount
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  rejectFinalAmountResolution:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Final Amount Resolution Rejected

  rejectFinalAmountResolutionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: rejectFinalAmountResolution
    steps:
      - name: Emit Final Amount Resolution Rejected
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Final Amount Resolution Rejected
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  lockPaymentCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completion Locked

  lockPaymentCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: lockPaymentCompletion
    steps:
      - name: LockPaymentCompletion
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /controls/completionLocked
              val: true
          - $appendEvent:
              type: PayNote/Payment Completion Locked
              lockedAt:
                $event: /message/request/lockedAt
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  unlockPaymentCompletion:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completion Unlocked

  unlockPaymentCompletionImpl:
    type: Coordination/Sequential Workflow Operation
    operation: unlockPaymentCompletion
    steps:
      - name: UnlockPaymentCompletion
        type: Coordination/Compute
        do:
          - $appendChange:
              op: replace
              path: /controls/completionLocked
              val: false
          - $appendEvent:
              type: PayNote/Payment Completion Unlocked
              unlockedAt:
                $event: /message/request/unlockedAt
          - $return:
              changeset:
                $changeset: true
              events:
                $events: true

  failPaymentCompletionLockChange:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Completion Lock Change Failed

  failPaymentCompletionLockChangeImpl:
    type: Coordination/Sequential Workflow Operation
    operation: failPaymentCompletionLockChange
    steps:
      - name: Emit Payment Completion Lock Change Failed
        type: Coordination/Compute
        do:
          - $appendEvent:
              type: PayNote/Payment Completion Lock Change Failed
              reason:
                $event: /message/request/reason
          - $return:
              events:
                $events: true

  lockPaymentReversal:
    type: Coordination/Operation
    channel: guarantorChannel
    request:
      type: PayNote/Payment Reversal Locked

