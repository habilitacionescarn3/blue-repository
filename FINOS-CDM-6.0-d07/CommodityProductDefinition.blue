name: cdm/base/staticdata/asset/common/CommodityProductDefinition
description: Specifies the commodity underlier in the event that no ISDA Commodity Reference Price exists.
commodityInfoPublisher:
  description: Specifies the publication where the commodity prices can be found.
  type: FINOS-CDM-6.0-d07/cdm/base/staticdata/asset/common/CommodityInformationPublisherEnum
exchangeId:
  description: |
    Identifies the exchange from which the reference price should be sourced, using the scheme at the following url: http://www.fpml.org/coding-scheme/external/exchange-id-MIC-1-0
  type: FINOS-CDM-6.0-d07/com/rosetta/model/FieldWithMetaString
  schema:
    required: true
priceSource:
  description: |
    Specifies a publication that provides the commodity price, including, where applicable the details of where in the publication the price is published.  Applicable when the commodity reference price is not a futures contract
  type: FINOS-CDM-6.0-d07/cdm/base/staticdata/asset/common/PriceSource
referenceFramework:
  description: Specifies the type of commodity.
  type: FINOS-CDM-6.0-d07/cdm/base/staticdata/asset/common/CommodityReferenceFramework
  schema:
    required: true
